# DATABASE
DB_USER=postgres
DB_HOST=localhost
DB_NAME=metapharsic_erp
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# JWT & AUTHENTICATION
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_this_immediately
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRATION=7d

# SERVER
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# 2FA
TOTP_WINDOW=2
TOTP_STEP=30

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# EMAIL (for 2FA OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@metapharsic.com

# SECURITY
BCRYPT_ROUNDS=10              # Password hashing rounds (10=50-100ms, 12=150-300ms)
                              # Rounds 10-11 recommended for balance of speed and security
SESSION_SECRET=your_session_secret_min_32_chars
HELMET_ENABLED=true

# LOGGING
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CRYPTO
ENCRYPTION_KEY=your_32_character_encryption_key
