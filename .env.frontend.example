# Frontend Environment Configuration
# Copy this file to .env.local and configure for your environment

# ========================================
# Backend API Configuration
# ========================================
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# ========================================
# Authentication Configuration
# ========================================
# JWT expiration times (in seconds)
VITE_JWT_EXPIRATION=86400        # 24 hours (access token)
VITE_REFRESH_TOKEN_EXPIRATION=604800  # 7 days (refresh token)

# 2FA Configuration
VITE_2FA_ENABLED=true
VITE_TOTP_WINDOW=2               # Tolerance window for TOTP
VITE_BACKUP_CODES_COUNT=8        # Number of backup codes

# ========================================
# Security Configuration
# ========================================
VITE_ENABLE_SECURITY_LOGS=true
VITE_LOG_LEVEL=debug             # debug|info|warn|error
VITE_CLEAR_AUTH_ON_ERROR=false   # Auto-logout on auth errors

# Session Configuration
VITE_SESSION_TIMEOUT=1800000     # 30 minutes (in milliseconds)
VITE_WARN_BEFORE_SESSION_TIMEOUT=300000  # 5 minutes warning

# ========================================
# Feature Flags
# ========================================
VITE_ENABLE_DEMO_MODE=false      # Enable demo/test accounts
VITE_ENABLE_PWA=false            # Enable Progressive Web App
VITE_ENABLE_OFFLINE_MODE=false   # Enable offline functionality

# ========================================
# Development Configuration
# ========================================
VITE_DEBUG_MODE=false            # Enable debug features
VITE_MOCK_API=false              # Mock API calls (prevent backend calls)
VITE_VERBOSE_ERRORS=true         # Show detailed error messages

# ========================================
# Monitoring & Telemetry
# ========================================
VITE_ENABLE_ANALYTICS=false      # Enable usage analytics
VITE_SENTRY_DSN=                 # Sentry error tracking (optional)
VITE_ENV=development             # Environment: development|staging|production

# ========================================
# Feature Configuration
# ========================================
# Rate Limiting
VITE_MAX_FAILED_ATTEMPTS=5       # Max failed login attempts
VITE_FAILED_ATTEMPT_TIMEOUT=15   # Minutes before reset

# Password Policy
VITE_PASSWORD_MIN_LENGTH=8
VITE_REQUIRE_SPECIAL_CHARS=true
VITE_REQUIRE_NUMBERS=true
VITE_REQUIRE_UPPERCASE=true

# ========================================
# Application Configuration
# ========================================
VITE_APP_NAME=Metapharsic ERP
VITE_APP_VERSION=1.0.0
VITE_SUPPORT_EMAIL=support@metapharsic.com

# ========================================
# Notes:
# - Never commit this file to version control
# - Each developer should have their own .env.local
# - Production values should be set via CI/CD secrets
# - Update VITE_API_URL for different deployment targets
# ========================================
