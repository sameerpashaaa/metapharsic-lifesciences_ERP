                >
                  <Menu size={20} />
                </button>
                <h1 className="text-lg font-bold text-slate-800 hidden sm:block tracking-tight">
                  {getPageTitle(activeTab)}
                </h1>
              </div>

              {/* Global Search Mockup */}
              <div className="hidden md:flex flex-1 max-w-md mx-8 relative">
                  <div className="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                      <Search size={16} className="text-slate-400" />
                  </div>
                  <input 
                    type="text" 
                    className="block w-full pl-10 pr-3 py-1.5 border border-slate-200 rounded-xl leading-5 bg-white/50 text-slate-900 placeholder-slate-400 focus:outline-none focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all sm:text-sm shadow-inner"
                    placeholder="Search system (Cmd+K)" 
                  />
                  <div className="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                     <div className="bg-slate-200 rounded px-1.5 py-0.5 text-[10px] font-bold text-slate-500 border border-slate-300">⌘K</div>
                  </div>
              </div>
                          
              {/* Current Module Shortcut Indicator */}
              <div className="flex items-center gap-1 text-xs text-slate-500">
                <span>{getPageTitle(activeTab)}:</span>
                <kbd className="px-1.5 py-0.5 bg-slate-100 border border-slate-300 rounded text-[10px] font-mono font-bold">Ctrl</kbd>
                <span>+</span>
                <kbd className="px-1.5 py-0.5 bg-slate-100 border border-slate-300 rounded text-[10px] font-mono font-bold">{getShortcutKeyForTab(activeTab)}</kbd>
              </div>
                          
              {/* Help and Navigation Shortcuts */}
              <div className="flex items-center gap-1 text-xs text-slate-500">
                <span>Shortcuts:</span>
                <kbd className="px-1.5 py-0.5 bg-slate-100 border border-slate-300 rounded text-[10px] font-mono font-bold">Ctrl</kbd>
                <span>+</span>
                <kbd className="px-1.5 py-0.5 bg-slate-100 border border-slate-300 rounded text-[10px] font-mono font-bold">?</kbd>
                <span>Help</span>
              </div>

              <div className="flex items-center gap-5">
                <button className="relative p-2 rounded-xl hover:bg-white/50 text-slate-600 transition-all hover:text-blue-600 hover:shadow-sm">
                  <Bell size={20} />
                  <span className="absolute top-2 right-2.5 w-1.5 h-1.5 bg-red-500 rounded-full border border-white shadow-sm"></span>
                </button>
                
                <div className="h-6 w-px bg-slate-300 mx-1"></div>
                
                {/* Button to toggle module navigation */}
                <button
                  onClick={() => setShowModuleNavigation(!showModuleNavigation)}
                  className="p-2 rounded-xl hover:bg-white/50 text-slate-600 hover:text-blue-600 transition-all shadow-sm border border-transparent hover:border-slate-200"
                  aria-label="Module navigation"
                >
                  <Menu size={20} />
                </button>
                
                <div className="h-6 w-px bg-slate-300 mx-1"></div>
                
                <MenuOptions 
                  onCreateNewCompany={handleCreateNewCompany}
                  onRestoreDefaultDemo={handleRestoreDefaultDemo}
                  onRestoreMyDemo={handleRestoreMyDemo}
                  onDeleteSavedPassword={handleDeleteSavedPassword}
                  onChangeOperatorPowers={handleChangeOperatorPowers}
                  onChangeERPVersion={handleChangeERPVersion}
                  onBillRetail={handleBillRetail}
                  onBillWholesale={handleBillWholesale}
                  onSalesReturnExpiry={handleSalesReturnExpiry}
                  onPurchaseReturnExpiry={handlePurchaseReturnExpiry}
                  onReceiptPayment={handleReceiptPayment}
                  onCashBankBook={handleCashBankBook}
                  onLedgerAccount={handleLedgerAccount}
                  onOutstanding={handleOutstanding}
                  onStockStatus={handleStockStatus}
                  onStockSalesAnalysis={handleStockSalesAnalysis}
                  onReorder={handleReorder}
                  onSalesBook={handleSalesBook}
                  onDispatchSummary={handleDispatchSummary}
                  onBillTagging={handleBillTagging}
                  onDailyAnalysis={handleDailyAnalysis}
                  onTodaysGrossProfit={handleTodaysGrossProfit}
                />
                
                <div className="h-6 w-px bg-slate-300 mx-1"></div>
                
                <div className="text-right hidden sm:block">
                   <p className="text-xs font-bold text-slate-800 leading-tight">Metapharsic</p>
                   <div className="flex items-center justify-end gap-1.5">
                      <div className="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></div>
                      <p className="text-[9px] text-slate-500 font-medium uppercase tracking-wide">Enterprise</p>
                   </div>
                </div>
              </div>
            </header>

            {/* Main Content Area */}
            <main className="flex-1 overflow-auto p-4 sm:p-6 relative scroll-smooth">
                {/* Background decoration */}
                <div className="absolute top-0 left-0 w-full h-64 bg-gradient-to-b from-blue-50/50 to-transparent -z-10 pointer-events-none"></div>
                <div className="max-w-[1600px] mx-auto">
                    {renderContent()}
                </div>
            </main>
          </div>
        </div>
      </div>
    
      <KeyboardShortcutsHelp 
        isOpen={showShortcutsHelp} 
        onClose={() => setShowShortcutsHelp(false)} 
      />
    </div>
  );
};

const App: React.FC = () => {
  return (
    <AuthProvider>
      <CompanyProvider>
        <KeyboardShortcutProvider>
          <AppContent />
        </KeyboardShortcutProvider>
      </CompanyProvider>
    </AuthProvider>
  );
};

export default App;
