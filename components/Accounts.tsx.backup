      },
      liabilities: {
        currentItems: [
          { accountId: 'L2001', accountName: 'Sundry Creditors', currentYear: 280000, previousYear: 320000, variance: -40000, percentageOfTotal: 85.0 },
          { accountId: 'L2201', accountName: 'GST Payable', currentYear: 49500, previousYear: 28000, variance: 21500, percentageOfTotal: 15.0 },
        ],
        fixedItems: [
          { accountId: 'L2101', accountName: 'Bank Loan - HDFC', currentYear: 500000, previousYear: 550000, variance: -50000, percentageOfTotal: 100 },
        ],
