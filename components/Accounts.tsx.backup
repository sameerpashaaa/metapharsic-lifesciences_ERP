      },
      {
        id: 'BR002',
        bankAccountId: 'A1003',
        bankName: 'SBI',
        accountNumber: '38045678901',
        reconciliationDate: '2024-04-30',
        bankStatementBalance: 98500,
        bookBalance: 100000,
        differences: [
          { id: 'D001', type: 'Bank Charge', description: 'Monthly charges not recorded', amount: 500, status: 'Pending' },
          { id: 'D002', type: 'Interest', description: 'Interest credited by bank', amount: 1000, status: 'Pending' },
        ],
        isReconciled: false,
        reconciliationNotes: 'Pending adjustments for bank charges and interest',
        status: 'In Progress',
        createdAt: '2024-04-30',
        createdBy: 'Accountant'
      },
    ];

    setChartOfAccounts(demoChartOfAccounts);
    setJournalVouchers(demoJournalVouchers);
    setGeneralLedger(demoGeneralLedger);
    setTrialBalance(demoTrialBalance);
    setBalanceSheet(demoBalanceSheet);
    setProfitLoss(demoProfitLoss);
    setCostCenters(demoCostCenters);
    setBankReconciliations(demoBankReconciliation);
    setAuditTrail(demoGeneralLedger);
    
    // Save demo data to localStorage for persistence
    saveAccountingData(
      demoChartOfAccounts,
      demoJournalVouchers,
      demoGeneralLedger,
      demoTrialBalance,
      demoBalanceSheet,
      demoProfitLoss,
      demoCostCenters,
      demoBankReconciliation,
      demoGeneralLedger
    );
  };

  // Filter Logic
  const filteredParties = useMemo(() => {
    return parties.filter(p => {
        const matchesSearch = p.name.toLowerCase().includes(searchTerm.toLowerCase()) || p.city.toLowerCase().includes(searchTerm.toLowerCase());
        const matchesType = partyTypeFilter === 'All' || p.type === partyTypeFilter;
        return matchesSearch && matchesType;
    });
  }, [parties, searchTerm, partyTypeFilter]);

  const selectedParty = parties.find(p => p.id === selectedPartyId);

  // Totals
  const totalReceivables = parties.filter(p => p.currentBalance > 0).reduce((acc, p) => acc + p.currentBalance, 0);
  const totalPayables = parties.filter(p => p.currentBalance < 0).reduce((acc, p) => acc + Math.abs(p.currentBalance), 0);
  const totalExpensesMonth = expenses.reduce((acc, e) => acc + e.amount, 0);

  // Handlers
  const handlePayment = (e: React.FormEvent) => {
    e.preventDefault();
    if (!selectedPartyId || !paymentAmount) return;

    const amount = parseFloat(paymentAmount);
    
    // Update Ledger
    const newEntry = {
        id: `L-${Date.now()}`,
        date: new Date().toISOString().split('T')[0],
        voucherType: transactionType,
        voucherNo: `VCH-${Date.now().toString().slice(-4)}`,
        debit: transactionType === 'Payment' ? amount : 0,
        credit: transactionType === 'Receipt' ? amount : 0,
        balance: 0, // Calculated below
        narration: `Manual ${transactionType} - ${paymentMode} - ${paymentRef}`
    };

    setParties(prevParties => prevParties.map(p => {
        if (p.id === selectedPartyId) {
            const newBalance = transactionType === 'Receipt' 
                ? p.currentBalance - amount 
                : p.currentBalance + amount; // Logic differs based on Party Type but keeping simple: Receipt reduces Debt, Payment reduces Credit liability (usually negative balance)
            
            // For simple math: 
            // Debtor (+Balance): Receipt reduces balance. Payment increases balance (refund?)
            // Creditor (-Balance): Payment reduces negative balance (moves to 0). Receipt increases negative balance.
            
            // Simplified: Receipt = Credit the party. Payment = Debit the party.
            const updatedBalance = p.currentBalance + (transactionType === 'Payment' ? amount : -amount);

            return {
                ...p,
                currentBalance: updatedBalance,
                ledger: [...p.ledger, { ...newEntry, balance: updatedBalance } as any]
            };
        }
        return p;
    }));

    setShowPaymentModal(false);
    setPaymentAmount('');
    setPaymentRef('');
  };

  // Print Invoice Handlers
  const handlePrintInvoice = (invoice: SalesInvoice) => {
    setInvoiceToPrint(invoice);
    setShowPrintModal(true);
  };

  const printInvoice = () => {
    const printWindow = window.open('', '_blank');
    if (!printWindow || !invoiceToPrint) return;

    const printContent = document.getElementById('printable-invoice');
    if (!printContent) return;

    printWindow.document.write(`
      <!DOCTYPE html>
      <html>
      <head>
        <title>Invoice #${invoiceToPrint.id} - Metapharsic Pharma</title>
        <style>
          @media print {
            body { margin: 0; padding: 20px; font-family: 'Segoe UI', Arial, sans-serif; }
            .no-print { display: none !important; }
          }
          body { font-family: 'Segoe UI', Arial, sans-serif; color: #1e293b; line-height: 1.6; }
          .invoice-container { max-width: 800px; margin: 0 auto; border: 2px solid #0f172a; padding: 30px; }
          .header { text-align: center; border-bottom: 3px double #0f172a; padding-bottom: 20px; margin-bottom: 20px; }
          .company-name { font-size: 28px; font-weight: bold; color: #0f172a; margin-bottom: 5px; }
          .company-tagline { font-size: 14px; color: #64748b; margin-bottom: 10px; }
          .company-details { font-size: 12px; color: #475569; }
          .invoice-title { font-size: 24px; font-weight: bold; text-align: center; margin: 20px 0; color: #0f172a; text-transform: uppercase; letter-spacing: 2px; }
          .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
          .info-box { border: 1px solid #e2e8f0; padding: 15px; border-radius: 8px; }
          .info-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
          .info-value { font-size: 14px; font-weight: 600; color: #0f172a; }
          .items-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
          .items-table th { background: #0f172a; color: white; padding: 12px 8px; text-align: left; font-size: 12px; text-transform: uppercase; }
          .items-table td { padding: 10px 8px; border-bottom: 1px solid #e2e8f0; font-size: 13px; }
          .items-table tr:nth-child(even) { background: #f8fafc; }
          .text-right { text-align: right; }
          .text-center { text-align: center; }
          .summary-section { margin-top: 20px; border-top: 2px solid #0f172a; padding-top: 20px; }
          .summary-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed #e2e8f0; }
          .summary-row.total { font-size: 18px; font-weight: bold; color: #0f172a; border-top: 2px solid #0f172a; border-bottom: none; margin-top: 10px; padding-top: 15px; }
          .footer { margin-top: 40px; text-align: center; font-size: 12px; color: #64748b; }
          .signature-section { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 60px; }
          .signature-box { border-top: 1px solid #0f172a; padding-top: 10px; text-align: center; }
          .gst-info { background: #f1f5f9; padding: 10px; border-radius: 6px; margin: 15px 0; font-size: 12px; }
          .qr-placeholder { width: 100px; height: 100px; border: 2px dashed #cbd5e1; display: flex; align-items: center; justify-content: center; margin: 10px auto; font-size: 10px; color: #64748b; }
        </style>
      </head>
      <body>
        ${printContent.innerHTML}
        <script>
          window.onload = function() {
            window.print();
            window.close();
          };
        </script>
      </body>
      </html>
    `);
    printWindow.document.close();
  };

  const downloadInvoicePDF = () => {
    // In a real implementation, this would generate a PDF
    // For now, we'll trigger print to PDF
    printInvoice();
  };

  // Chart of Accounts Handlers
  const handleAddAccount = () => {
    if (!newAccount.accountCode || !newAccount.accountName) return;
    
    // Check for duplicate account code
    const existingAccount = chartOfAccounts.find(acc => 
      acc.accountCode.toLowerCase() === newAccount.accountCode?.toLowerCase()
    );
    
    if (existingAccount) {
      alert(`Account code '${newAccount.accountCode}' already exists. Please use a different code.`);
      return;
    }
    
    const account: ChartOfAccount = {
      id: `A-${Date.now()}`,
      accountCode: newAccount.accountCode,
      accountName: newAccount.accountName,
      accountType: newAccount.accountType as AccountType,
      openingBalance: newAccount.openingBalance || 0,
      openingBalanceDate: newAccount.openingBalanceDate || new Date().toISOString().split('T')[0],
      description: newAccount.description || '',
      isActive: newAccount.isActive ?? true,
      reconciliationStatus: 'Balanced',
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
      createdBy: 'Current User'
    };
    
    const updatedAccounts = [...chartOfAccounts, account];
    setChartOfAccounts(updatedAccounts);
    
    // Also add an entry to General Ledger for the opening balance
    if (account.openingBalance > 0) {
      const glEntry: GeneralLedgerEntry = {
        id: `GL-${Date.now()}`,
        accountId: account.id,
        accountCode: account.accountCode,
        accountName: account.accountName,
        date: account.openingBalanceDate,
        voucherId: `OPEN-${Date.now()}`,
        voucherType: 'Opening',
        voucherNo: `OP/${account.accountCode}/${new Date().getFullYear()}`,
        debit: account.accountType === 'Asset' || account.accountType === 'Expense' ? account.openingBalance : 0,
        credit: account.accountType === 'Liability' || account.accountType === 'Equity' || account.accountType === 'Income' ? account.openingBalance : 0,
        runningBalance: account.openingBalance,
        narration: `Opening balance for ${account.accountName}`,
        createdAt: new Date().toISOString(),
        createdBy: 'Current User',
        isApproved: true
      };
      const updatedLedger = [...generalLedger, glEntry];
      setGeneralLedger(updatedLedger);
      
      // Update audit trail
      const updatedAuditTrail = [...auditTrail, glEntry];
      setAuditTrail(updatedAuditTrail);
      
      // Save all data to localStorage
      saveAccountingData(
        updatedAccounts,
        journalVouchers,
        updatedLedger,
        trialBalance,
        balanceSheet,
        profitLoss,
        costCenters,
        bankReconciliations,
        updatedAuditTrail
      );
    } else {
      // Save without GL entry if no opening balance
      saveAccountingData(
        updatedAccounts,
        journalVouchers,
        generalLedger,
        trialBalance,
        balanceSheet,
        profitLoss,
        costCenters,
        bankReconciliations,
        auditTrail
      );
    }
    
    setShowAccountModal(false);
    setNewAccount({
      accountCode: '',
      accountName: '',
      accountType: 'Asset',
      openingBalance: 0,
      openingBalanceDate: new Date().toISOString().split('T')[0],
      description: '',
      isActive: true
    });
  };

  return (
    <div className="flex flex-col h-[calc(100vh-2rem)] gap-4 animate-fadeIn">
       <div className="flex justify-between items-center">
            <div>
                <h2 className="text-2xl font-bold text-slate-800">Financial Accounting</h2>
                <p className="text-slate-500 text-sm">Ledgers, Outstanding & Cash Flow (Marg Style)</p>
            </div>
            <div className="bg-white border border-slate-200 rounded-lg p-1 flex flex-wrap gap-1">
                <button onClick={() => setActiveTab('CHART_OF_ACCOUNTS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'CHART_OF_ACCOUNTS' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Chart of Accounts</button>
                <button onClick={() => setActiveTab('JOURNAL_VOUCHERS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'JOURNAL_VOUCHERS' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Journal Vouchers</button>
                <button onClick={() => setActiveTab('GENERAL_LEDGER')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'GENERAL_LEDGER' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>General Ledger</button>
                <button onClick={() => setActiveTab('TRIAL_BALANCE')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'TRIAL_BALANCE' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Trial Balance</button>
                <button onClick={() => setActiveTab('BALANCE_SHEET')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'BALANCE_SHEET' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Balance Sheet</button>
                <button onClick={() => setActiveTab('PROFIT_LOSS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'PROFIT_LOSS' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>P&L Statement</button>
                <button onClick={() => setActiveTab('COST_CENTERS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'COST_CENTERS' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Cost Centers</button>
                <button onClick={() => setActiveTab('BANK_RECONCILIATION')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'BANK_RECONCILIATION' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Bank Recon</button>
                <button onClick={() => setActiveTab('AUDIT_TRAIL')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'AUDIT_TRAIL' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Audit Trail</button>
                                <button onClick={() => setActiveTab('AI_REPORTS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'AI_REPORTS' ? 'bg-purple-600 text-white' : 'text-purple-600 hover:bg-purple-50'}`}><Bot size={14} className="inline mr-1" /> AI Reports</button>
                                                <button onClick={() => setActiveTab('POWER_BI_REPORTS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'POWER_BI_REPORTS' ? 'bg-green-600 text-white' : 'text-green-600 hover:bg-green-50'}`}><FileSpreadsheet size={14} className="inline mr-1" /> Power BI Excel</button>
                                                                <button onClick={() => setActiveTab('GST_FILING')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'GST_FILING' ? 'bg-blue-600 text-white' : 'text-blue-600 hover:bg-blue-50'}`}><FileText size={14} className="inline mr-1" /> GST Filing</button>
                                                                                <button onClick={() => setActiveTab('TDS_MANAGEMENT')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'TDS_MANAGEMENT' ? 'bg-orange-600 text-white' : 'text-orange-600 hover:bg-orange-50'}`}><Calculator size={14} className="inline mr-1" /> TDS</button>
                                                                                                <button onClick={() => setActiveTab('MULTI_CURRENCY')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'MULTI_CURRENCY' ? 'bg-teal-600 text-white' : 'text-teal-600 hover:bg-teal-50'}`}><DollarSign size={14} className="inline mr-1" /> Forex</button>
                                                                                                                <button onClick={() => setActiveTab('BUDGETING')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'BUDGETING' ? 'bg-purple-600 text-white' : 'text-purple-600 hover:bg-purple-50'}`}><Target size={14} className="inline mr-1" /> Budget</button>
                                                                                                                                <button onClick={() => setActiveTab('FIXED_ASSETS')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'FIXED_ASSETS' ? 'bg-amber-600 text-white' : 'text-amber-600 hover:bg-amber-50'}`}><Building2 size={14} className="inline mr-1" /> Assets</button>
                <button onClick={() => setActiveTab('PARTIES')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'PARTIES' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Party Ledger</button>
                <button onClick={() => setActiveTab('INVOICES')} className={`px-3 py-1.5 text-sm font-medium rounded transition-colors ${activeTab === 'INVOICES' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}>Invoices</button>
            </div>
       </div>

       {/* Top Stats */}
       <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div className="bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
              <div>
                  <p className="text-slate-500 text-xs font-bold uppercase">Total Receivables (Dr)</p>
                  <h3 className="text-xl font-bold text-green-600">₹{totalReceivables.toLocaleString()}</h3>
              </div>
              <div className="p-2 bg-green-50 text-green-600 rounded-lg"><ArrowUpRight size={20} /></div>
          </div>
          <div className="bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
              <div>
                  <p className="text-slate-500 text-xs font-bold uppercase">Total Payables (Cr)</p>
                  <h3 className="text-xl font-bold text-red-600">₹{totalPayables.toLocaleString()}</h3>
              </div>
              <div className="p-2 bg-red-50 text-red-600 rounded-lg"><ArrowDownLeft size={20} /></div>
          </div>
          <div className="bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
              <div>
                  <p className="text-slate-500 text-xs font-bold uppercase">Net Cash Flow</p>
                  <h3 className="text-xl font-bold text-blue-600">₹{(totalReceivables - totalPayables).toLocaleString()}</h3>
              </div>
              <div className="p-2 bg-blue-50 text-blue-600 rounded-lg"><Wallet size={20} /></div>
          </div>
           <div className="bg-white p-4 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
              <div>
                  <p className="text-slate-500 text-xs font-bold uppercase">Expenses (Oct)</p>
                  <h3 className="text-xl font-bold text-orange-600">₹{totalExpensesMonth.toLocaleString()}</h3>
              </div>
              <div className="p-2 bg-orange-50 text-orange-600 rounded-lg"><PieChart size={20} /></div>
          </div>
       </div>

       {/* LEDGER VIEW (Marg Style Split) */}
       {activeTab === 'PARTIES' && (
           <div className="flex-1 flex flex-col lg:flex-row gap-4 overflow-hidden">
               {/* Party List */}
               <div className="w-full lg:w-1/3 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col">
                    <div className="p-4 border-b border-slate-100 space-y-3">
                        <div className="relative">
                            <Search className="absolute left-3 top-2.5 text-slate-400" size={18} />
                            <input
                            type="text"
                            placeholder="Search Party / City..."
                            className="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-1 focus:ring-primary outline-none"
                            value={searchTerm}
                            onChange={(e) => setSearchTerm(e.target.value)}
                            />
                        </div>
                        <div className="flex gap-2">
                            {['All', 'Debtor', 'Creditor'].map(type => (
                                <button
                                    key={type}
                                    onClick={() => setPartyTypeFilter(type as any)}
                                    className={`flex-1 py-1 text-xs font-medium rounded border ${partyTypeFilter === type ? 'bg-slate-800 text-white border-slate-800' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`}
                                >
                                    {type === 'Debtor' ? 'Customers' : type === 'Creditor' ? 'Suppliers' : 'All'}
                                </button>
                            ))}
                        </div>
                    </div>
                    <div className="flex-1 overflow-y-auto divide-y divide-slate-100">
                        {filteredParties.map(party => (
                            <div 
                                key={party.id}
                                onClick={() => setSelectedPartyId(party.id)}
                                className={`p-4 cursor-pointer transition-colors hover:bg-slate-50 ${selectedPartyId === party.id ? 'bg-blue-50 border-l-4 border-blue-500' : ''}`}
                            >
                                <div className="flex justify-between items-start mb-1">
                                    <h4 className="font-semibold text-slate-800 text-sm">{party.name}</h4>
                                    <span className="text-[10px] text-slate-500 font-mono bg-slate-100 px-1 rounded">{party.city}</span>
                                </div>
                                <div className="flex justify-between items-center mt-2">
                                    <span className="text-xs text-slate-400">{party.route || 'General'}</span>
                                    <span className={`font-bold text-sm ${party.currentBalance >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                                        {Math.abs(party.currentBalance).toLocaleString()} {party.currentBalance >= 0 ? 'Dr' : 'Cr'}
                                    </span>
                                </div>
                            </div>
                        ))}
                    </div>
               </div>

               {/* Ledger Detail View */}
               <div className="flex-1 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col overflow-hidden">
                    {selectedParty ? (
                        <>
                             <div className="p-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center">
                                <div>
                                    <h2 className="text-lg font-bold text-slate-800">{selectedParty.name}</h2>
                                    <p className="text-xs text-slate-500 flex items-center gap-2">
                                        <MapPin size={12}/> {selectedParty.city} • {selectedParty.mobile} • GST: {selectedParty.gstin}
                                    </p>
                                </div>
                                <div className="text-right">
                                     <p className="text-xs text-slate-500">Current Balance</p>
                                     <h3 className={`text-xl font-bold ${selectedParty.currentBalance >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                                         {Math.abs(selectedParty.currentBalance).toLocaleString()} {selectedParty.currentBalance >= 0 ? 'Dr' : 'Cr'}
                                     </h3>
                                </div>
                             </div>
                             
                             <div className="flex-1 overflow-y-auto">
                                 <table className="w-full text-left text-sm">
                                     <thead className="bg-white text-slate-500 border-b border-slate-200 sticky top-0 font-bold text-xs uppercase">
                                         <tr>
                                             <th className="p-3">Date</th>
                                             <th className="p-3">Particulars</th>
                                             <th className="p-3">Vch Type</th>
                                             <th className="p-3 text-right text-green-700">Debit</th>
                                             <th className="p-3 text-right text-red-700">Credit</th>
                                             <th className="p-3 text-right">Balance</th>
                                         </tr>
                                     </thead>
                                     <tbody className="divide-y divide-slate-100">
                                         {selectedParty.ledger.map((entry, idx) => (
                                             <tr key={idx} className="hover:bg-slate-50">
                                                 <td className="p-3 text-slate-600 font-mono text-xs">{entry.date}</td>
                                                 <td className="p-3">
                                                     <div className="font-medium text-slate-800">{entry.voucherNo}</div>
                                                     <div className="text-[10px] text-slate-400">{entry.narration}</div>
                                                 </td>
                                                 <td className="p-3 text-xs">{entry.voucherType}</td>
                                                 <td className="p-3 text-right font-medium text-slate-700">{entry.debit ? `₹${entry.debit.toLocaleString()}` : '-'}</td>
                                                 <td className="p-3 text-right font-medium text-slate-700">{entry.credit ? `₹${entry.credit.toLocaleString()}` : '-'}</td>
                                                 <td className="p-3 text-right font-bold text-slate-800">
                                                     {Math.abs(entry.balance).toLocaleString()} {entry.balance >= 0 ? 'Dr' : 'Cr'}
                                                 </td>
                                             </tr>
                                         ))}
                                     </tbody>
                                 </table>
                             </div>

                             <div className="p-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                                {canEdit && (
                                    <>
                                        <button 
                                            onClick={() => { setTransactionType('Payment'); setShowPaymentModal(true); }}
                                            className="bg-white border border-red-200 text-red-700 px-4 py-2 rounded-lg text-sm font-bold hover:bg-red-50 transition-colors shadow-sm flex items-center gap-2"
                                        >
                                            <ArrowUpRight size={16} /> Payment
                                        </button>
                                        <button 
                                            onClick={() => { setTransactionType('Receipt'); setShowPaymentModal(true); }}
                                            className="bg-white border border-green-200 text-green-700 px-4 py-2 rounded-lg text-sm font-bold hover:bg-green-50 transition-colors shadow-sm flex items-center gap-2"
                                        >
                                            <ArrowDownLeft size={16} /> Receipt
                                        </button>
                                    </>
                                )}
                             </div>
                        </>
                    ) : (
                        <div className="flex flex-col items-center justify-center h-full text-slate-400">
                            <User size={48} className="mb-4 opacity-20" />
                            <p>Select a Party to view Ledger Account</p>
                        </div>
                    )}
               </div>
           </div>
       )}

       {/* AGING ANALYSIS VIEW */}
       {activeTab === 'AGING' && (
           <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 overflow-hidden flex flex-col">
               <div className="p-4 border-b border-slate-100 bg-slate-50 font-bold text-slate-700">
                   Outstanding Aging Analysis (Debtors)
               </div>
               <div className="flex-1 overflow-auto">
                   <table className="w-full text-left text-sm">
                       <thead className="bg-white text-xs font-bold text-slate-500 uppercase border-b border-slate-100">
                           <tr>
                               <th className="p-4">Party Name</th>
                               <th className="p-4 text-right">Total Due</th>
                               <th className="p-4 text-right text-green-600">0-30 Days</th>
                               <th className="p-4 text-right text-orange-600">31-60 Days</th>
                               <th className="p-4 text-right text-red-600">60+ Days</th>
                           </tr>
                       </thead>
                       <tbody className="divide-y divide-slate-100">
                           {parties.filter(p => p.type === 'Debtor' && p.currentBalance > 0).map(party => (
                               <tr key={party.id} className="hover:bg-slate-50">
                                   <td className="p-4 font-medium text-slate-800">{party.name}</td>
                                   <td className="p-4 text-right font-bold">₹{party.currentBalance.toLocaleString()}</td>
                                   {/* Mock logic for aging split */}
                                   <td className="p-4 text-right">₹{(party.currentBalance * 0.6).toLocaleString()}</td>
                                   <td className="p-4 text-right">₹{(party.currentBalance * 0.3).toLocaleString()}</td>
                                   <td className="p-4 text-right font-bold text-red-600">₹{(party.currentBalance * 0.1).toLocaleString()}</td>
                               </tr>
                           ))}
                       </tbody>
                   </table>
               </div>
           </div>
       )}

       {/* CASH BOOK VIEW */}
       {activeTab === 'CASHBOOK' && (
           <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 p-8 text-center flex flex-col items-center justify-center">
               <Wallet size={64} className="text-slate-300 mb-4"/>
               <h3 className="text-xl font-bold text-slate-600">Daily Cash Book</h3>
               <p className="text-slate-500 max-w-md mt-2">Track daily cash inflows (Sales) and outflows (Expenses/Petty Cash). View closing balance for physical cash verification.</p>
               <div className="mt-6 p-4 bg-slate-50 rounded-lg border border-slate-200 inline-block text-left min-w-[300px]">
                   <div className="flex justify-between mb-2">
                       <span className="text-sm text-slate-600">Opening Cash</span>
                       <span className="font-bold">₹12,500</span>
                   </div>
                   <div className="flex justify-between mb-2 text-green-600">
                       <span className="text-sm">Today's Receipt</span>
                       <span className="font-bold">+ ₹45,000</span>
                   </div>
                   <div className="flex justify-between mb-2 text-red-600">
                       <span className="text-sm">Today's Payment</span>
                       <span className="font-bold">- ₹18,200</span>
                   </div>
                   <div className="border-t border-slate-300 pt-2 flex justify-between mt-2">
                       <span className="text-sm font-bold text-slate-800">Closing Balance</span>
                       <span className="font-bold text-slate-900">₹39,300</span>
                   </div>
               </div>
           </div>
       )}

       {/* DETAILED INVOICES VIEW */}
       {activeTab === 'INVOICES' && (
           <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 overflow-hidden flex flex-col">
               <div className="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                   <h3 className="font-bold text-slate-800">Detailed Invoices</h3>
                   <div className="flex gap-2">
                       <div className="relative">
                           <Search className="absolute left-3 top-2.5 text-slate-400" size={16} />
                           <input
                               type="text"
                               placeholder="Search invoices, medicines, doctors..."
                               className="pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-lg focus:ring-1 focus:ring-primary outline-none text-sm w-64"
                               value={invoiceSearchTerm}
                               onChange={(e) => setInvoiceSearchTerm(e.target.value)}
                           />
                       </div>
                       <div className="flex gap-2">
                           <input
                               type="date"
                               className="px-3 py-2 border border-slate-200 rounded-lg text-sm"
                               value={invoiceDateFilter.start}
                               onChange={(e) => setInvoiceDateFilter({...invoiceDateFilter, start: e.target.value})}
                           />
                           <input
                               type="date"
                               className="px-3 py-2 border border-slate-200 rounded-lg text-sm"
                               value={invoiceDateFilter.end}
                               onChange={(e) => setInvoiceDateFilter({...invoiceDateFilter, end: e.target.value})}
                           />
                       </div>
                   </div>
               </div>
               <div className="flex-1 flex overflow-hidden">
                   {/* Invoice List */}
                   <div className="w-1/2 border-r border-slate-200 overflow-y-auto">
                       {invoices.map(invoice => {
                           // Find related data
                           const relatedProducts = invoice.items?.map((item: any) => 
                               products.find(p => p.id === item.productId)
                           ).filter(Boolean) || [];
                           
                           const relatedPcdPartner = pcdPartners.find(partner => 
                               partner.territory.toLowerCase().includes(invoice.customerName.toLowerCase()) ||
                               partner.name.toLowerCase().includes(invoice.customerName.toLowerCase())
                           );
                           
                           const relatedMr = medicalReps.find(mr => 
                               mr.name.toLowerCase().includes(invoice.doctorName.toLowerCase())
                           );
                           
                           return (
                               <div 
                                   key={invoice.id}
                                   onClick={() => setSelectedInvoice(invoice)}
                                   className={`p-4 border-b border-slate-100 cursor-pointer transition-colors ${selectedInvoice?.id === invoice.id ? 'bg-blue-50' : 'hover:bg-slate-50'}`}
                               >
                                   <div className="flex justify-between items-start">
                                       <div>
                                           <div className="font-bold text-slate-800">{invoice.id}</div>
                                           <div className="text-sm text-slate-600">{invoice.customerName}</div>
                                       </div>
                                       <div className="text-right">
                                           <div className="font-bold text-slate-800">₹{invoice.totalAmount?.toLocaleString() || '0'}</div>
                                           <div className="text-xs text-slate-500">{invoice.date}</div>
                                           <button 
                                               onClick={(e) => { e.stopPropagation(); handlePrintInvoice(invoice); }}
                                               className="mt-1 p-1.5 bg-blue-100 text-blue-700 rounded hover:bg-blue-200 transition-colors"
                                               title="Print Invoice"
                                           >
                                               <Printer size={14} />
                                           </button>
                                       </div>
                                   </div>
                                   <div className="mt-2 flex flex-wrap gap-1">
                                       {relatedProducts.slice(0, 3).map((product: any) => (
                                           <span key={product?.id} className="text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">
                                               {product?.name}
                                           </span>
                                       ))}
                                       {relatedProducts.length > 3 && (
                                           <span className="text-xs bg-slate-100 text-slate-600 px-2 py-1 rounded">
                                               +{relatedProducts.length - 3} more
                                           </span>
                                       )}
                                   </div>
                                   <div className="mt-2 flex gap-2 text-xs text-slate-500">
                                       {relatedMr && (
                                           <div className="flex items-center gap-1">
                                               <Briefcase size={12} />
                                               <span>{relatedMr.name}</span>
                                           </div>
                                       )}
                                       {relatedPcdPartner && (
                                           <div className="flex items-center gap-1">
                                               <MapPinned size={12} />
                                               <span>{relatedPcdPartner.territory}</span>
                                           </div>
                                       )}
                                       {invoice.doctorName && (
                                           <div className="flex items-center gap-1">
                                               <Stethoscope size={12} />
                                               <span>{invoice.doctorName}</span>
                                           </div>
                                       )}
                                   </div>
                               </div>
                           );
                       })}
                   </div>
                   
                   {/* Invoice Details */}
                   <div className="w-1/2 overflow-y-auto p-4">
                       {selectedInvoice ? (
                           <div className="space-y-6">
                               <div>
                                   <h4 className="font-bold text-lg text-slate-800 mb-4">Invoice #{selectedInvoice.id}</h4>
                                   <div className="grid grid-cols-2 gap-4 mb-6">
                                       <div>
                                           <h5 className="font-medium text-slate-700 mb-2">Customer</h5>
                                           <p className="text-slate-800">{selectedInvoice.customerName}</p>
                                           <p className="text-sm text-slate-600">{selectedInvoice.customerMobile}</p>
                                       </div>
                                       <div>
                                           <h5 className="font-medium text-slate-700 mb-2">Date & Time</h5>
                                           <p className="text-slate-800">{selectedInvoice.date} {selectedInvoice.time}</p>
                                       </div>
                                   </div>
                                   
                                   <div className="grid grid-cols-2 gap-4 mb-6">
                                       {selectedInvoice.doctorName && (
                                           <div>
                                               <h5 className="font-medium text-slate-700 mb-2 flex items-center gap-2">
                                                   <Stethoscope size={16} />
                                                   Prescribing Doctor
                                               </h5>
                                               <p className="text-slate-800">{selectedInvoice.doctorName}</p>
                                           </div>
                                       )}
                                       {selectedInvoice.patientName && (
                                           <div>
                                               <h5 className="font-medium text-slate-700 mb-2">Patient</h5>
                                               <p className="text-slate-800">{selectedInvoice.patientName}</p>
                                           </div>
                                       )}
                                   </div>
                                   
                                   {/* Related PCD Partner */}
                                   {pcdPartners.some(partner => 
                                       partner.territory.toLowerCase().includes(selectedInvoice.customerName.toLowerCase()) ||
                                       partner.name.toLowerCase().includes(selectedInvoice.customerName.toLowerCase())
                                   ) && (
                                       <div className="mb-6">
                                           <h5 className="font-medium text-slate-700 mb-2 flex items-center gap-2">
                                               <MapPinned size={16} />
                                               PCD Territory
                                           </h5>
                                           {pcdPartners.filter(partner => 
                                               partner.territory.toLowerCase().includes(selectedInvoice.customerName.toLowerCase()) ||
                                               partner.name.toLowerCase().includes(selectedInvoice.customerName.toLowerCase())
                                           ).map(partner => (
                                               <div key={partner.id} className="p-3 bg-slate-50 rounded-lg border border-slate-200">
                                                   <p className="font-medium text-slate-800">{partner.name}</p>
                                                   <p className="text-sm text-slate-600">Territory: {partner.territory}</p>
                                                   <p className="text-sm text-slate-500">Contact: {partner.contact}</p>
                                               </div>
                                           ))}
                                       </div>
                                   )}
                                   
                                   {/* Related Medical Representative */}
                                   {medicalReps.some(mr => 
                                       mr.name.toLowerCase().includes(selectedInvoice.doctorName.toLowerCase())
                                   ) && (
                                       <div className="mb-6">
                                           <h5 className="font-medium text-slate-700 mb-2 flex items-center gap-2">
                                               <Briefcase size={16} />
                                               Medical Representative
                                           </h5>
                                           {medicalReps.filter(mr => 
                                               mr.name.toLowerCase().includes(selectedInvoice.doctorName.toLowerCase())
                                           ).map(mr => (
                                               <div key={mr.id} className="p-3 bg-slate-50 rounded-lg border border-slate-200">
                                                   <p className="font-medium text-slate-800">{mr.name}</p>
                                                   <p className="text-sm text-slate-600">Area: {mr.assignedArea}</p>
                                                   <p className="text-sm text-slate-500">Contact: {mr.contact}</p>
                                               </div>
                                           ))}
                                       </div>
                                   )}
                                   
                                   {/* Invoice Items */}
                                   <div className="mb-6">
                                       <h5 className="font-medium text-slate-700 mb-2 flex items-center gap-2">
                                           <Pill size={16} />
                                           Medicines
                                       </h5>
                                       <div className="overflow-x-auto">
                                           <table className="w-full text-sm">
                                               <thead className="bg-slate-100">
                                                   <tr>
                                                       <th className="p-2 text-left">Product</th>
                                                       <th className="p-2 text-left">Generic</th>
                                                       <th className="p-2 text-right">Qty</th>
                                                       <th className="p-2 text-right">Rate</th>
                                                       <th className="p-2 text-right">Amount</th>
                                                   </tr>
                                               </thead>
                                               <tbody>
                                                   {selectedInvoice.items?.map((item: any, idx: number) => {
                                                       const product = products.find(p => p.id === item.productId);
                                                       return (
                                                           <tr key={idx} className="border-b border-slate-100 hover:bg-slate-50">
                                                               <td className="p-2 font-medium">{product?.name || item.productName}</td>
                                                               <td className="p-2 text-slate-600">{product?.genericName || item.genericName}</td>
                                                               <td className="p-2 text-right">{item.quantity}</td>
                                                               <td className="p-2 text-right">₹{item.rate?.toFixed(2)}</td>
                                                               <td className="p-2 text-right font-medium">₹{item.totalAmount?.toFixed(2)}</td>
                                                           </tr>
                                                       );
                                                   })}
                                               </tbody>
                                           </table>
                                       </div>
                                   </div>
                                   
                                   {/* Financial Summary */}
                                   <div className="bg-slate-50 p-4 rounded-lg border border-slate-200">
                                       <div className="grid grid-cols-2 gap-4">
                                           <div>
                                               <p className="text-slate-600">Sub Total</p>
                                               <p className="font-medium">₹{selectedInvoice.subTotal?.toLocaleString() || '0'}</p>
                                           </div>
                                           <div>
                                               <p className="text-slate-600">Tax Amount</p>
                                               <p className="font-medium">₹{selectedInvoice.totalGst?.toLocaleString() || '0'}</p>
                                           </div>
                                           <div>
                                               <p className="text-slate-600">Discount</p>
                                               <p className="font-medium">₹{selectedInvoice.totalDiscount?.toLocaleString() || '0'}</p>
                                           </div>
                                           <div>
                                               <p className="font-bold text-slate-800">Net Amount</p>
                                               <p className="font-bold text-lg text-slate-800">₹{selectedInvoice.netAmount?.toLocaleString() || selectedInvoice.totalAmount?.toLocaleString() || '0'}</p>
                                           </div>
                                       </div>
                                   </div>
                               </div>
                           </div>
                       ) : (
                           <div className="flex flex-col items-center justify-center h-full text-slate-400">
                               <FileText size={48} className="mb-4 opacity-20" />
                               <p>Select an invoice to view details</p>
                           </div>
                       )}
                   </div>
               </div>
           </div>
       )}
       
       {/* EXPENSES VIEW */}
       {activeTab === 'EXPENSES' && (
           <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 overflow-hidden flex flex-col">
               <div className="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                   <h3 className="font-bold text-slate-800">Operational Expenses</h3>
                   {canEdit && (
                        <button className="bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-sky-600 flex items-center gap-2">
                            <Plus size={16} /> Add Expense
                        </button>
                   )}
               </div>
               <div className="flex-1 overflow-auto">
                   <table className="w-full text-left">
                       <thead className="bg-white text-xs font-bold text-slate-500 uppercase border-b border-slate-100">
                           <tr>
                               <th className="p-4">Date</th>
                               <th className="p-4">Category</th>
                               <th className="p-4">Description</th>
                               <th className="p-4">Paid By</th>
                               <th className="p-4 text-right">Amount</th>
                           </tr>
                       </thead>
                       <tbody className="divide-y divide-slate-100">
                           {expenses.map(exp => (
                               <tr key={exp.id} className="hover:bg-slate-50">
                                   <td className="p-4 text-sm text-slate-600">{exp.date}</td>
                                   <td className="p-4">
                                       <span className="bg-slate-100 text-slate-700 px-2 py-1 rounded text-xs font-bold border border-slate-200">
                                           {exp.category}
                                       </span>
                                   </td>
                                   <td className="p-4 text-sm font-medium text-slate-800">{exp.description}</td>
                                   <td className="p-4 text-sm text-slate-600">{exp.paidBy}</td>
                                   <td className="p-4 text-right font-bold text-slate-800">₹{exp.amount.toLocaleString()}</td>
                               </tr>
                           ))}
                       </tbody>
                   </table>
               </div>
           </div>
       )}

       {activeTab === 'CHART_OF_ACCOUNTS' && <ChartOfAccountsView />}
       {activeTab === 'JOURNAL_VOUCHERS' && <JournalVouchersView />}
       {activeTab === 'GENERAL_LEDGER' && <GeneralLedgerView />}
       {(activeTab === 'TRIAL_BALANCE' || activeTab === 'BALANCE_SHEET' || activeTab === 'PROFIT_LOSS') && <FinancialReportsView />}

      {/* COST CENTERS */}
      {activeTab === 'COST_CENTERS' && (
        <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 overflow-hidden flex flex-col">
          <div className="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h3 className="font-bold text-slate-800 flex items-center gap-2"><Target size={20} /> Cost Centers</h3>
            <span className="text-sm text-slate-500">Total: {costCenters.length}</span>
          </div>
          <div className="flex-1 overflow-auto p-4">
            <div className="grid grid-cols-3 gap-4">
              {costCenters.map(cc => (
                <div key={cc.id} className="border border-slate-200 rounded-lg p-4 hover:shadow-md transition-shadow">
                  <div className="flex items-center gap-2 mb-2">
                    <span className="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-bold">{cc.costCenterCode}</span>
                    <span className="text-xs text-slate-500">{cc.category}</span>
                  </div>
                  <h4 className="font-bold text-slate-800 mb-1">{cc.costCenterName}</h4>
                  <p className="text-sm text-slate-500 mb-3">{cc.description}</p>
                  <div className="text-sm">
                    <div className="flex justify-between py-1">
                      <span className="text-slate-600">Manager:</span>
                      <span className="font-medium">{cc.manager}</span>
                    </div>
                    <div className="flex justify-between py-1">
                      <span className="text-slate-600">Budget:</span>
                      <span className="font-medium">₹{cc.budget?.toLocaleString()}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* BANK RECONCILIATION */}
      {activeTab === 'BANK_RECONCILIATION' && (
        <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 overflow-hidden flex flex-col">
          <div className="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h3 className="font-bold text-slate-800 flex items-center gap-2"><Landmark size={20} /> Bank Reconciliation</h3>
          </div>
          <div className="flex-1 overflow-auto p-4 space-y-4">
            {bankReconciliations.map(br => (
              <div key={br.id} className="border border-slate-200 rounded-lg p-4">
                <div className="flex justify-between items-start mb-4">
                  <div>
                    <h4 className="font-bold text-slate-800">{br.bankName}</h4>
                    <p className="text-sm text-slate-500">A/c: {br.accountNumber}</p>
                  </div>
                  <span className={`px-3 py-1 rounded text-xs font-bold ${
                    br.status === 'Completed' ? 'bg-green-100 text-green-700' :
                    br.status === 'In Progress' ? 'bg-yellow-100 text-yellow-700' :
                    'bg-slate-100 text-slate-600'
                  }`}>
                    {br.status}
                  </span>
                </div>
                <div className="grid grid-cols-3 gap-4 mb-4">
                  <div className="bg-slate-50 p-3 rounded">
                    <div className="text-xs text-slate-500">Bank Statement</div>
                    <div className="font-bold">₹{br.bankStatementBalance.toLocaleString()}</div>
                  </div>
                  <div className="bg-slate-50 p-3 rounded">
                    <div className="text-xs text-slate-500">Book Balance</div>
                    <div className="font-bold">₹{br.bookBalance.toLocaleString()}</div>
                  </div>
                  <div className={`p-3 rounded ${br.isReconciled ? 'bg-green-50' : 'bg-red-50'}`}>
                    <div className="text-xs text-slate-500">Difference</div>
                    <div className={`font-bold ${br.isReconciled ? 'text-green-700' : 'text-red-700'}`}>
                      ₹{Math.abs(br.bankStatementBalance - br.bookBalance).toLocaleString()}
                    </div>
                  </div>
                </div>
                {br.differences.length > 0 && (
                  <div className="mt-4">
                    <h5 className="font-medium text-slate-700 mb-2">Differences:</h5>
                    <table className="w-full text-sm">
                      <thead className="bg-slate-50">
                        <tr>
                          <th className="p-2 text-left">Type</th>
                          <th className="p-2 text-left">Description</th>
                          <th className="p-2 text-right">Amount</th>
                          <th className="p-2 text-center">Status</th>
                        </tr>
                      </thead>
                      <tbody>
                        {br.differences.map(diff => (
                          <tr key={diff.id} className="border-b border-slate-100">
                            <td className="p-2">{diff.type}</td>
                            <td className="p-2">{diff.description}</td>
                            <td className="p-2 text-right">₹{diff.amount.toLocaleString()}</td>
                            <td className="p-2 text-center">
                              <span className={`px-2 py-1 rounded text-xs ${
                                diff.status === 'Resolved' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'
                              }`}>
                                {diff.status}
                              </span>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* AUDIT TRAIL */}
      {activeTab === 'AUDIT_TRAIL' && (
        <div className="bg-white rounded-xl border border-slate-200 shadow-sm flex-1 overflow-hidden flex flex-col">
          <div className="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
            <h3 className="font-bold text-slate-800 flex items-center gap-2"><History size={20} /> Audit Trail</h3>
          </div>
          <div className="flex-1 overflow-auto">
            <table className="w-full text-left text-sm">
              <thead className="bg-white text-xs font-bold text-slate-500 uppercase border-b border-slate-100">
                <tr>
                  <th className="p-3">Date & Time</th>
                  <th className="p-3">User</th>
                  <th className="p-3">Action</th>
                  <th className="p-3">Voucher</th>
                  <th className="p-3">Account</th>
                  <th className="p-3 text-right">Amount</th>
                  <th className="p-3">Status</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100">
                {auditTrail.map((entry, idx) => (
                  <tr key={entry.id} className="hover:bg-slate-50">
                    <td className="p-3">{new Date(entry.createdAt).toLocaleString()}</td>
                    <td className="p-3">{entry.createdBy}</td>
                    <td className="p-3">
                      <span className="text-xs bg-slate-100 px-2 py-1 rounded">{entry.voucherType}</span>
                    </td>
                    <td className="p-3">{entry.voucherNo}</td>
                    <td className="p-3">{entry.accountName}</td>
                    <td className="p-3 text-right">
                      {entry.debit > 0 ? `Dr ₹${entry.debit.toLocaleString()}` : 
                       entry.credit > 0 ? `Cr ₹${entry.credit.toLocaleString()}` : '-'}
                    </td>
                    <td className="p-3">
                      <span className={`px-2 py-1 rounded text-xs ${
                        entry.isApproved ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'
                      }`}>
                        {entry.isApproved ? 'Approved' : 'Pending'}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

      {/* AI REPORTS */}
      {activeTab === 'AI_REPORTS' && (
        <AIReportGenerator
          chartOfAccounts={chartOfAccounts}
          journalVouchers={journalVouchers}
          generalLedger={generalLedger}
          trialBalance={trialBalance}
          balanceSheet={balanceSheet}
          profitLoss={profitLoss}
          costCenters={costCenters}
          bankReconciliations={bankReconciliations}
          auditTrail={auditTrail}
          invoices={invoices}
          parties={parties}
        />
      )}

      {/* POWER BI EXCEL REPORTS */}
      {activeTab === 'POWER_BI_REPORTS' && (
        <PowerBIExcelReports
          chartOfAccounts={chartOfAccounts}
          journalVouchers={journalVouchers}
          generalLedger={generalLedger}
          trialBalance={trialBalance}
          balanceSheet={balanceSheet}
          profitLoss={profitLoss}
          costCenters={costCenters}
          bankReconciliations={bankReconciliations}
          auditTrail={auditTrail}
          invoices={invoices}
          parties={parties}
        />
      )}

      {/* GST RETURN FILING */}
      {activeTab === 'GST_FILING' && (
        <GSTReturnFiling />
      )}

      {/* TDS MANAGEMENT */}
      {activeTab === 'TDS_MANAGEMENT' && (
        <TDSManagement />
      )}

      {/* MULTI CURRENCY */}
      {activeTab === 'MULTI_CURRENCY' && (
        <MultiCurrency />
      )}

      {/* BUDGETING & VARIANCE */}
      {activeTab === 'BUDGETING' && (
        <BudgetingVariance />
      )}

       {/* Payment Modal */}
       {showPaymentModal && selectedParty && (
           <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
               <div className="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden animate-fadeIn">
                   <div className="bg-slate-900 text-white p-4 flex justify-between items-center">
                       <h3 className="font-bold flex items-center gap-2"><CreditCard size={18} /> {transactionType} Entry</h3>
                       <button onClick={() => setShowPaymentModal(false)} className="hover:bg-slate-700 p-1 rounded transition-colors"><X size={18} /></button>
                   </div>
                   <div className="p-6 space-y-4">
                       <div>
                           <label className="block text-xs font-semibold text-slate-500 mb-1">Party</label>
                           <p className="font-bold text-slate-800 text-lg">{selectedParty.name}</p>
                           <p className="text-xs text-slate-500">Current Balance: ₹{Math.abs(selectedParty.currentBalance).toLocaleString()} {selectedParty.currentBalance >= 0 ? 'Dr' : 'Cr'}</p>
                       </div>
                       
                       <div>
                           <label className="block text-sm font-medium text-slate-700 mb-1">Amount (₹)</label>
                           <input 
                                type="number" 
                                value={paymentAmount} 
                                onChange={(e) => setPaymentAmount(e.target.value)}
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none font-bold text-lg"
                                placeholder="0.00"
                                autoFocus
                           />
                       </div>

                       <div className="grid grid-cols-2 gap-4">
                            <div>
                                <label className="block text-sm font-medium text-slate-700 mb-1">Date</label>
                                <div className="relative">
                                    <Calendar className="absolute left-3 top-2.5 text-slate-400" size={16} />
                                    <input 
                                        type="date" 
                                        value={new Date().toISOString().split('T')[0]}
                                        disabled
                                        className="w-full border border-slate-300 rounded-lg pl-9 pr-3 py-2 bg-slate-50 text-slate-500"
                                    />
                                </div>
                            </div>
                            <div>
                                <label className="block text-sm font-medium text-slate-700 mb-1">Mode</label>
                                <select 
                                    value={paymentMode}
                                    onChange={(e: any) => setPaymentMode(e.target.value)}
                                    className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none bg-white"
                                >
                                    <option>Bank Transfer</option>
                                    <option>Cheque</option>
                                    <option>Cash</option>
                                    <option>UPI</option>
                                </select>
                            </div>
                       </div>

                       <div>
                           <label className="block text-sm font-medium text-slate-700 mb-1">Reference No. / Note</label>
                           <input 
                                type="text" 
                                value={paymentRef} 
                                onChange={(e) => setPaymentRef(e.target.value)}
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-primary outline-none text-sm"
                                placeholder="e.g. Cheque No / UPI ID"
                           />
                       </div>
                   </div>
                   <div className="p-4 bg-slate-50 border-t border-slate-100 flex justify-end gap-3">
                       <button onClick={() => setShowPaymentModal(false)} className="px-4 py-2 text-slate-600 font-medium hover:bg-slate-200 rounded-lg transition-colors">Cancel</button>
                       <button onClick={handlePayment} className="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:bg-sky-600 transition-colors shadow-lg shadow-primary/30 flex items-center gap-2">
                           <Check size={18} /> Confirm {transactionType}
                       </button>
                   </div>
               </div>
           </div>
       )}

      {/* PRINT INVOICE MODAL */}
      {showPrintModal && invoiceToPrint && (
        <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
          <div className="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden flex flex-col">
            <div className="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
              <h3 className="font-bold text-slate-800 flex items-center gap-2">
                <Printer size={20} /> Print Invoice Preview
              </h3>
              <button onClick={() => setShowPrintModal(false)} className="p-2 hover:bg-slate-200 rounded-lg">
                <X size={20} />
              </button>
            </div>
            
            <div className="flex-1 overflow-auto p-4 bg-slate-100">
              {/* Printable Invoice Content */}
              <div id="printable-invoice" className="bg-white p-8 shadow-lg">
                {/* Header */}
                <div className="header" style={{textAlign: 'center', borderBottom: '3px double #0f172a', paddingBottom: '20px', marginBottom: '20px'}}>
                  <div className="company-name" style={{fontSize: '28px', fontWeight: 'bold', color: '#0f172a'}}>METAPHARSIC PHARMA</div>
                  <div className="company-tagline" style={{fontSize: '14px', color: '#64748b'}}>Quality Healthcare Solutions</div>
                  <div className="company-details" style={{fontSize: '12px', color: '#475569', marginTop: '10px'}}>
                    123 Pharma Hub, Industrial Area, Mumbai - 400001<br/>
                    GST: 27AABCU9603R1ZX | Phone: +91-22-12345678<br/>
                    Email: info@metapharsic.com | www.metapharsic.com
                  </div>
                </div>

                {/* Invoice Title */}
                <div className="invoice-title" style={{fontSize: '24px', fontWeight: 'bold', textAlign: 'center', margin: '20px 0', color: '#0f172a', textTransform: 'uppercase', letterSpacing: '2px'}}>
                  TAX INVOICE
                </div>

                {/* Invoice Info Grid */}
                <div style={{display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px', marginBottom: '20px'}}>
                  <div className="info-box" style={{border: '1px solid #e2e8f0', padding: '15px', borderRadius: '8px'}}>
                    <div className="info-label" style={{fontSize: '11px', color: '#64748b', textTransform: 'uppercase', letterSpacing: '1px'}}>Invoice Number</div>
                    <div className="info-value" style={{fontSize: '16px', fontWeight: '600', color: '#0f172a'}}>#{invoiceToPrint.id}</div>
                  </div>
                  <div className="info-box" style={{border: '1px solid #e2e8f0', padding: '15px', borderRadius: '8px'}}>
                    <div className="info-label" style={{fontSize: '11px', color: '#64748b', textTransform: 'uppercase', letterSpacing: '1px'}}>Date & Time</div>
                    <div className="info-value" style={{fontSize: '14px', fontWeight: '600', color: '#0f172a'}}>{invoiceToPrint.date} {invoiceToPrint.time}</div>
                  </div>
                </div>

                {/* Customer & Doctor Info */}
                <div style={{display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px', marginBottom: '20px'}}>
                  <div className="info-box" style={{border: '1px solid #e2e8f0', padding: '15px', borderRadius: '8px'}}>
                    <div className="info-label" style={{fontSize: '11px', color: '#64748b', textTransform: 'uppercase', letterSpacing: '1px'}}>Bill To</div>
                    <div className="info-value" style={{fontSize: '16px', fontWeight: '600', color: '#0f172a'}}>{invoiceToPrint.customerName}</div>
                    <div style={{fontSize: '13px', color: '#475569', marginTop: '5px'}}>
                      {invoiceToPrint.customerMobile && <div>📞 {invoiceToPrint.customerMobile}</div>}
                      {invoiceToPrint.customerAddress && <div>📍 {invoiceToPrint.customerAddress}</div>}
                    </div>
                  </div>
                  {invoiceToPrint.doctorName && (
                    <div className="info-box" style={{border: '1px solid #e2e8f0', padding: '15px', borderRadius: '8px'}}>
                      <div className="info-label" style={{fontSize: '11px', color: '#64748b', textTransform: 'uppercase', letterSpacing: '1px'}}>Prescribing Doctor</div>
                      <div className="info-value" style={{fontSize: '16px', fontWeight: '600', color: '#0f172a'}}>Dr. {invoiceToPrint.doctorName}</div>
                      {invoiceToPrint.patientName && (
                        <div style={{fontSize: '13px', color: '#475569', marginTop: '5px'}}>Patient: {invoiceToPrint.patientName}</div>
                      )}
                    </div>
                  )}
                </div>

                {/* Items Table */}
                <table className="items-table" style={{width: '100%', borderCollapse: 'collapse', margin: '20px 0'}}>
                  <thead>
                    <tr style={{background: '#0f172a', color: 'white'}}>
                      <th style={{padding: '12px 8px', textAlign: 'left', fontSize: '12px', textTransform: 'uppercase'}}>#</th>
                      <th style={{padding: '12px 8px', textAlign: 'left', fontSize: '12px', textTransform: 'uppercase'}}>Product</th>
                      <th style={{padding: '12px 8px', textAlign: 'left', fontSize: '12px', textTransform: 'uppercase'}}>Generic</th>
                      <th style={{padding: '12px 8px', textAlign: 'center', fontSize: '12px', textTransform: 'uppercase'}}>Batch</th>
                      <th style={{padding: '12px 8px', textAlign: 'center', fontSize: '12px', textTransform: 'uppercase'}}>Exp</th>
                      <th style={{padding: '12px 8px', textAlign: 'right', fontSize: '12px', textTransform: 'uppercase'}}>Qty</th>
                      <th style={{padding: '12px 8px', textAlign: 'right', fontSize: '12px', textTransform: 'uppercase'}}>Rate</th>
                      <th style={{padding: '12px 8px', textAlign: 'right', fontSize: '12px', textTransform: 'uppercase'}}>GST%</th>
                      <th style={{padding: '12px 8px', textAlign: 'right', fontSize: '12px', textTransform: 'uppercase'}}>Amount</th>
                    </tr>
                  </thead>
                  <tbody>
                    {invoiceToPrint.items?.map((item: any, idx: number) => {
                      const product = products.find(p => p.id === item.productId);
                      return (
                        <tr key={idx} style={{borderBottom: '1px solid #e2e8f0', background: idx % 2 === 0 ? '#f8fafc' : 'white'}}>
                          <td style={{padding: '10px 8px', fontSize: '13px'}}>{idx + 1}</td>
                          <td style={{padding: '10px 8px', fontSize: '13px', fontWeight: 500}}>{product?.name || item.productName}</td>
                          <td style={{padding: '10px 8px', fontSize: '12px', color: '#64748b'}}>{product?.genericName || item.genericName}</td>
                          <td style={{padding: '10px 8px', fontSize: '12px', textAlign: 'center'}}>{item.batchNo || '-'}</td>
                          <td style={{padding: '10px 8px', fontSize: '12px', textAlign: 'center'}}>{item.expiryDate || '-'}</td>
                          <td style={{padding: '10px 8px', fontSize: '13px', textAlign: 'right'}}>{item.quantity}</td>
                          <td style={{padding: '10px 8px', fontSize: '13px', textAlign: 'right'}}>₹{item.rate?.toFixed(2)}</td>
                          <td style={{padding: '10px 8px', fontSize: '13px', textAlign: 'right'}}>{item.gstPercent || product?.gst || 12}%</td>
                          <td style={{padding: '10px 8px', fontSize: '13px', textAlign: 'right', fontWeight: 500}}>₹{item.totalAmount?.toFixed(2)}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>

                {/* Financial Summary */}
                <div className="summary-section" style={{marginTop: '20px', borderTop: '2px solid #0f172a', paddingTop: '20px'}}>
                  <div style={{display: 'flex', justifyContent: 'space-between', padding: '8px 0', borderBottom: '1px dashed #e2e8f0'}}>
                    <span style={{color: '#64748b'}}>Sub Total</span>
                    <span style={{fontWeight: 500}}>₹{invoiceToPrint.subTotal?.toLocaleString() || '0'}</span>
                  </div>
                  <div style={{display: 'flex', justifyContent: 'space-between', padding: '8px 0', borderBottom: '1px dashed #e2e8f0'}}>
                    <span style={{color: '#64748b'}}>CGST</span>
                    <span style={{fontWeight: 500}}>₹{((invoiceToPrint.totalGst || 0) / 2).toLocaleString()}</span>
                  </div>
                  <div style={{display: 'flex', justifyContent: 'space-between', padding: '8px 0', borderBottom: '1px dashed #e2e8f0'}}>
                    <span style={{color: '#64748b'}}>SGST</span>
                    <span style={{fontWeight: 500}}>₹{((invoiceToPrint.totalGst || 0) / 2).toLocaleString()}</span>
                  </div>
                  {invoiceToPrint.totalDiscount > 0 && (
                    <div style={{display: 'flex', justifyContent: 'space-between', padding: '8px 0', borderBottom: '1px dashed #e2e8f0'}}>
                      <span style={{color: '#64748b'}}>Discount</span>
                      <span style={{fontWeight: 500, color: '#16a34a'}}>-₹{invoiceToPrint.totalDiscount?.toLocaleString()}</span>
                    </div>
                  )}
                  <div style={{display: 'flex', justifyContent: 'space-between', padding: '15px 0', borderTop: '2px solid #0f172a', marginTop: '10px'}}>
                    <span style={{fontSize: '18px', fontWeight: 'bold', color: '#0f172a'}}>NET AMOUNT</span>
                    <span style={{fontSize: '18px', fontWeight: 'bold', color: '#0f172a'}}>₹{invoiceToPrint.netAmount?.toLocaleString() || invoiceToPrint.totalAmount?.toLocaleString() || '0'}</span>
                  </div>
                  <div style={{fontSize: '12px', color: '#64748b', fontStyle: 'italic', marginTop: '5px'}}>
                    Amount in Words: {numberToWords(invoiceToPrint.netAmount || invoiceToPrint.totalAmount || 0)} Rupees Only
                  </div>
                </div>

                {/* GST Info */}
                <div className="gst-info" style={{background: '#f1f5f9', padding: '10px', borderRadius: '6px', margin: '15px 0', fontSize: '12px'}}>
                  <strong>GST Summary:</strong> HSN Code: 3004 (Medicaments) | Taxable Value: ₹{invoiceToPrint.subTotal?.toLocaleString()} | 
                  Total GST: ₹{invoiceToPrint.totalGst?.toLocaleString()} | 
                  GST Rate: {invoiceToPrint.items?.[0]?.gstPercent || 12}% (CGST + SGST)
                </div>

                {/* QR Code Placeholder */}
                <div style={{textAlign: 'center', margin: '20px 0'}}>
                  <div style={{width: '100px', height: '100px', border: '2px dashed #cbd5e1', display: 'flex', alignItems: 'center', justifyContent: 'center', margin: '10px auto', fontSize: '10px', color: '#64748b'}}>
                    QR Code<br/>for e-Invoice
                  </div>
                  <div style={{fontSize: '11px', color: '#64748b'}}>Scan for digital verification</div>
                </div>

                {/* Signature Section */}
                <div style={{display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '40px', marginTop: '60px'}}>
                  <div style={{borderTop: '1px solid #0f172a', paddingTop: '10px', textAlign: 'center'}}>
                    <div style={{fontSize: '12px', color: '#64748b'}}>Customer Signature</div>
                  </div>
                  <div style={{borderTop: '1px solid #0f172a', paddingTop: '10px', textAlign: 'center'}}>
                    <div style={{fontSize: '12px', color: '#64748b'}}>Authorized Signatory</div>
                    <div style={{fontSize: '11px', color: '#94a3b8', marginTop: '5px'}}>For Metapharsic Pharma</div>
                  </div>
                </div>

                {/* Footer */}
                <div className="footer" style={{marginTop: '40px', textAlign: 'center', fontSize: '12px', color: '#64748b', borderTop: '1px solid #e2e8f0', paddingTop: '20px'}}>
                  <p>Thank you for your business!</p>
                  <p style={{marginTop: '10px'}}>
                    This is a computer generated invoice and does not require signature.<br/>
                    For queries, contact: support@metapharsic.com | +91-22-12345678
                  </p>
                </div>
              </div>
            </div>
            
            <div className="p-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
              <button 
                onClick={() => setShowPrintModal(false)} 
                className="px-4 py-2 text-slate-600 font-medium hover:bg-slate-200 rounded-lg transition-colors"
              >
                Close
              </button>
              <button 
                onClick={downloadInvoicePDF}
                className="px-4 py-2 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors flex items-center gap-2"
              >
                <Download size={18} /> Download PDF
              </button>
              <button 
                onClick={printInvoice}
                className="px-6 py-2 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors shadow-lg flex items-center gap-2"
              >
                <Printer size={18} /> Print Invoice
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ADD ACCOUNT MODAL */}
      {showAccountModal && (
        <div className="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
          <div className="bg-white rounded-xl shadow-2xl max-w-lg w-full">
            <div className="p-4 border-b border-slate-200 flex justify-between items-center bg-slate-50">
              <h3 className="font-bold text-slate-800 flex items-center gap-2">
                <Plus size={20} /> Add New Account
              </h3>
              <button onClick={() => setShowAccountModal(false)} className="p-2 hover:bg-slate-200 rounded-lg">
                <X size={20} />
              </button>
            </div>
            
            <div className="p-6 space-y-4">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-1">Account Code *</label>
                  <input
                    type="text"
                    value={newAccount.accountCode}
                    onChange={(e) => setNewAccount({...newAccount, accountCode: e.target.value})}
                    className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                    placeholder="e.g., 1005"
                  />
                </div>
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-1">Account Type *</label>
                  <select
                    value={newAccount.accountType}
                    onChange={(e) => setNewAccount({...newAccount, accountType: e.target.value as AccountType})}
                    className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none bg-white"
                  >
                    <option value="Asset">Asset</option>
                    <option value="Liability">Liability</option>
                    <option value="Equity">Equity</option>
                    <option value="Income">Income</option>
                    <option value="Expense">Expense</option>
                  </select>
                </div>
              </div>
              
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">Account Name *</label>
                <input
                  type="text"
                  value={newAccount.accountName}
                  onChange={(e) => setNewAccount({...newAccount, accountName: e.target.value})}
                  className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                  placeholder="Enter account name"
                />
              </div>
              
              <div>
                <label className="block text-sm font-medium text-slate-700 mb-1">Description</label>
                <input
                  type="text"
                  value={newAccount.description}
                  onChange={(e) => setNewAccount({...newAccount, description: e.target.value})}
                  className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                  placeholder="Optional description"
                />
              </div>
              
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-1">Opening Balance</label>
                  <input
                    type="number"
                    value={newAccount.openingBalance}
                    onChange={(e) => setNewAccount({...newAccount, openingBalance: parseFloat(e.target.value) || 0})}
                    className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                  />
                </div>
                <div>
                  <label className="block text-sm font-medium text-slate-700 mb-1">Opening Date</label>
                  <input
                    type="date"
                    value={newAccount.openingBalanceDate}
                    onChange={(e) => setNewAccount({...newAccount, openingBalanceDate: e.target.value})}
                    className="w-full border border-slate-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none"
                  />
                </div>
              </div>
              
              <div className="flex items-center gap-2">
                <input
                  type="checkbox"
                  id="isActive"
                  checked={newAccount.isActive}
                  onChange={(e) => setNewAccount({...newAccount, isActive: e.target.checked})}
                  className="w-4 h-4 text-blue-600 rounded focus:ring-blue-500"
                />
                <label htmlFor="isActive" className="text-sm text-slate-700">Account is Active</label>
              </div>
            </div>
            
            <div className="p-4 bg-slate-50 border-t border-slate-200 flex justify-end gap-3">
              <button 
                onClick={() => setShowAccountModal(false)} 
                className="px-4 py-2 text-slate-600 font-medium hover:bg-slate-200 rounded-lg transition-colors"
              >
                Cancel
              </button>
              <button 
                onClick={handleAddAccount}
                disabled={!newAccount.accountCode || !newAccount.accountName}
                className="px-6 py-2 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors shadow-lg flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <Check size={18} /> Create Account
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

// Helper function to convert number to words
function numberToWords(num: number): string {
  const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten', 
                'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];
  const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
  
  if (num === 0) return 'Zero';
  
  function convert(n: number): string {
    if (n < 20) return ones[n];
    if (n < 100) return tens[Math.floor(n / 10)] + (n % 10 ? ' ' + ones[n % 10] : '');
    if (n < 1000) return ones[Math.floor(n / 100)] + ' Hundred' + (n % 100 ? ' and ' + convert(n % 100) : '');
    if (n < 100000) return convert(Math.floor(n / 1000)) + ' Thousand' + (n % 1000 ? ' ' + convert(n % 1000) : '');
    if (n < 10000000) return convert(Math.floor(n / 100000)) + ' Lakh' + (n % 100000 ? ' ' + convert(n % 100000) : '');
    return convert(Math.floor(n / 10000000)) + ' Crore' + (n % 10000000 ? ' ' + convert(n % 10000000) : '');
  }
  
  return convert(Math.floor(num));
}

export default Accounts;
