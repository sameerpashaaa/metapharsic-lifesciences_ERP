      profitMargin: -57.5
    };

    // Cost Centers - 6 departments
    const demoCostCenters: CostCenter[] = [
      { id: 'CC001', costCenterCode: 'PROD', costCenterName: 'Production', category: 'Department', description: 'Manufacturing operations', manager: 'Rajesh Kumar', budget: 500000, isActive: true, createdAt: '2024-04-01' },
      { id: 'CC002', costCenterCode: 'SALES', costCenterName: 'Sales & Marketing', category: 'Department', description: 'Sales team and marketing', manager: 'Priya Sharma', budget: 300000, isActive: true, createdAt: '2024-04-01' },
      { id: 'CC003', costCenterCode: 'ADMIN', costCenterName: 'Administration', category: 'Department', description: 'General administration', manager: 'Amit Patel', budget: 200000, isActive: true, createdAt: '2024-04-01' },
      { id: 'CC004', costCenterCode: 'HR', costCenterName: 'Human Resources', category: 'Department', description: 'HR and payroll', manager: 'Sneha Gupta', budget: 150000, isActive: true, createdAt: '2024-04-01' },
      { id: 'CC005', costCenterCode: 'MUM', costCenterName: 'Mumbai HQ', category: 'Location', description: 'Headquarters', manager: 'Vikram Shah', budget: 400000, isActive: true, createdAt: '2024-04-01' },
      { id: 'CC006', costCenterCode: 'PUNE', costCenterName: 'Pune Factory', category: 'Location', description: 'Manufacturing unit', manager: 'Deepak Rao', budget: 600000, isActive: true, createdAt: '2024-04-01' },
    ];

    // Bank Reconciliation
    const demoBankReconciliation: BankReconciliation[] = [
      {
        id: 'BR001',
        bankAccountId: 'A1002',
        bankName: 'HDFC Bank',
        accountNumber: '50200012345678',
