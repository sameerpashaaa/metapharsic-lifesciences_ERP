        total: 1225000
      },
      totalAssets: 2054500,
      totalLiabilities: 829500,
      totalEquity: 1225000,
      balanceCheck: true
    };

    // Profit & Loss
    const demoProfitLoss: ProfitLossReport = {
      period: 'Apr 2024 - Mar 2025',
      company: 'Metapharsic Pharma Pvt Ltd',
      revenue: {
        items: [
          { accountId: 'I4001', accountName: 'Sales - Domestic', currentPeriod: 175000, previousPeriod: 150000, variance: 25000, percentageOfRevenue: 100 },
          { accountId: 'I4101', accountName: 'Other Income', currentPeriod: 5000, previousPeriod: 3000, variance: 2000, percentageOfRevenue: 2.9 },
        ],
        subtotal: 180000,
        percentage: 100
      },
      expenses: {
        items: [
          { accountId: 'X5001', accountName: 'Purchase - Raw Materials', currentPeriod: 88500, previousPeriod: 75000, variance: 13500, percentageOfRevenue: 49.2 },
          { accountId: 'X5101', accountName: 'Salaries & Wages', currentPeriod: 125000, previousPeriod: 115000, variance: 10000, percentageOfRevenue: 69.4 },
          { accountId: 'X5201', accountName: 'Rent Expense', currentPeriod: 45000, previousPeriod: 45000, variance: 0, percentageOfRevenue: 25.0 },
          { accountId: 'X5301', accountName: 'Marketing Expense', currentPeriod: 25000, previousPeriod: 20000, variance: 5000, percentageOfRevenue: 13.9 },
        ],
        subtotal: 283500,
        percentage: 157.5
      },
      grossProfit: 91500,
      operatingIncome: -103500,
      netProfit: -103500,
      otherIncome: 5000,
      otherExpenses: 0,
      taxExpense: 0,
