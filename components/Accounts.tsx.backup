  useEffect(() => {
    loadAccountingData();
  }, []);

  // Load accounting data from localStorage or initialize demo data
  const loadAccountingData = () => {
    const storedChartOfAccounts = localStorage.getItem('erp_chart_of_accounts');
    const storedJournalVouchers = localStorage.getItem('erp_journal_vouchers');
    const storedGeneralLedger = localStorage.getItem('erp_general_ledger');
    const storedTrialBalance = localStorage.getItem('erp_trial_balance');
    const storedBalanceSheet = localStorage.getItem('erp_balance_sheet');
    const storedProfitLoss = localStorage.getItem('erp_profit_loss');
    const storedCostCenters = localStorage.getItem('erp_cost_centers');
    const storedBankReconciliations = localStorage.getItem('erp_bank_reconciliations');
    const storedAuditTrail = localStorage.getItem('erp_audit_trail');

    if (storedChartOfAccounts) {
      setChartOfAccounts(JSON.parse(storedChartOfAccounts));
      setJournalVouchers(JSON.parse(storedJournalVouchers || '[]'));
      setGeneralLedger(JSON.parse(storedGeneralLedger || '[]'));
      setTrialBalance(JSON.parse(storedTrialBalance || '[]'));
      setBalanceSheet(storedBalanceSheet ? JSON.parse(storedBalanceSheet) : null);
      setProfitLoss(storedProfitLoss ? JSON.parse(storedProfitLoss) : null);
      setCostCenters(JSON.parse(storedCostCenters || '[]'));
      setBankReconciliations(JSON.parse(storedBankReconciliations || '[]'));
      setAuditTrail(JSON.parse(storedAuditTrail || '[]'));
    } else {
      initializeAccountingDemoData();
    }
  };

