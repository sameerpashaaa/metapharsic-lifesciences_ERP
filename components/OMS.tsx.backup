
import React, { useState } from 'react';
import { 
  ShoppingCart, Package, CheckCircle, Clock, Truck, XCircle, Search, 
  Filter, AlertTriangle, ChevronRight, Eye, MoreHorizontal, Plus, 
  ArrowRight, Box, CreditCard, Send, CheckSquare, Tag, FileText, ClipboardList
} from 'lucide-react';
import { MOCK_DISTRIBUTOR_ORDERS, MOCK_PRODUCTS, MOCK_PCD_PARTNERS } from '../constants';
import { DistributorOrder, Product, OrderStatus } from '../types';

const OMS: React.FC = () => {
  const [activeTab, setActiveTab] = useState<'LIST' | 'CREATE'>('LIST');
  const [orders, setOrders] = useState<DistributorOrder[]>(MOCK_DISTRIBUTOR_ORDERS);
  const [searchTerm, setSearchTerm] = useState('');
  const [statusFilter, setStatusFilter] = useState<string>('All');
  const [selectedOrder, setSelectedOrder] = useState<DistributorOrder | null>(null);

  // Create Order State
  const [selectedDistributorId, setSelectedDistributorId] = useState('');
  const [packingInstructions, setPackingInstructions] = useState('');
  const [labelingInstructions, setLabelingInstructions] = useState('');
  const [cart, setCart] = useState<{product: Product, quantity: number}[]>([]);
  
  // Helpers
  const getStatusColor = (status: string) => {
    switch(status) {
      case 'Pending Approval': return 'bg-yellow-100 text-yellow-700 border-yellow-200';
      case 'Approved': return 'bg-blue-100 text-blue-700 border-blue-200';
      case 'Processing': return 'bg-purple-100 text-purple-700 border-purple-200';
      case 'Shipped': return 'bg-indigo-100 text-indigo-700 border-indigo-200';
      case 'Delivered': return 'bg-green-100 text-green-700 border-green-200';
      case 'Rejected': return 'bg-red-100 text-red-700 border-red-200';
      default: return 'bg-slate-100 text-slate-700';
    }
  };

  const getWorkflowStep = (status: OrderStatus) => {
    const steps = ['Pending Approval', 'Approved', 'Processing', 'Shipped', 'Delivered'];
    return steps.indexOf(status);
  };

  const filteredOrders = orders.filter(o => {
    const matchesSearch = o.distributorName.toLowerCase().includes(searchTerm.toLowerCase()) || o.id.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesStatus = statusFilter === 'All' || o.status === statusFilter;
    return matchesSearch && matchesStatus;
  });

  // --- Handlers ---

  const handleStatusChange = (orderId: string, newStatus: OrderStatus) => {
    setOrders(orders.map(o => o.id === orderId ? { ...o, status: newStatus } : o));
    if (selectedOrder && selectedOrder.id === orderId) {
      setSelectedOrder({ ...selectedOrder, status: newStatus });
    }
  };

  const updateApprovedQuantity = (orderId: string, productId: string, newQty: number) => {
      setOrders(prevOrders => prevOrders.map(order => {
          if (order.id === orderId) {
              const updatedItems = order.items.map(item => 
                  item.productId === productId ? { ...item, approvedQuantity: newQty } : item
              );
              // Update selected order view as well
              if (selectedOrder?.id === orderId) {
                  setSelectedOrder({ ...order, items: updatedItems });
              }
              return { ...order, items: updatedItems };
          }
          return order;
      }));
  };

  const addToCart = (product: Product) => {
    const existing = cart.find(item => item.product.id === product.id);
    if (existing) {
      setCart(cart.map(item => item.product.id === product.id ? { ...item, quantity: item.quantity + 1 } : item));
    } else {
      setCart([...cart, { product, quantity: 1 }]);
    }
  };

  const removeFromCart = (productId: string) => {
    setCart(cart.filter(item => item.product.id !== productId));
  };

  const updateCartQty = (productId: string, qty: number) => {
    if (qty <= 0) {
      removeFromCart(productId);
    } else {
      setCart(cart.map(item => item.product.id === productId ? { ...item, quantity: qty } : item));
    }
  };

  const handlePlaceOrder = () => {
    if (!selectedDistributorId || cart.length === 0) return;
    
    const distributor = MOCK_PCD_PARTNERS.find(p => p.id === selectedDistributorId);
    if (!distributor) return;

    const totalAmount = cart.reduce((sum, item) => sum + (item.quantity * (item.product.rate || item.product.mrp * 0.7)), 0); // Mock Rate Logic

    const newOrder: DistributorOrder = {
      id: `ORD-${Date.now()}`,
      distributorId: distributor.id,
      distributorName: distributor.name,
      date: new Date().toISOString().split('T')[0],
      items: cart.map(i => ({
        productId: i.product.id,
        productName: i.product.name,
        quantity: i.quantity,
        approvedQuantity: i.quantity, // Default approved is requested qty
        rate: i.product.rate || i.product.mrp * 0.7,
        amount: i.quantity * (i.product.rate || i.product.mrp * 0.7)
      })),
      totalAmount,
      status: 'Pending Approval',
      priority: 'Normal',
      creditStatus: 'Clear',
      packingSpecs: packingInstructions,
      labelingSpecs: labelingInstructions
    };

    setOrders([newOrder, ...orders]);
    setCart([]);
    setSelectedDistributorId('');
    setPackingInstructions('');
    setLabelingInstructions('');
    setActiveTab('LIST');
    alert(`Order ${newOrder.id} placed successfully!`);
  };

  return (
    <div className="space-y-6 animate-fadeIn">
      {/* Header */}
      <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h2 className="text-2xl font-bold text-slate-800">Order Management System (OMS)</h2>
          <p className="text-slate-500 text-sm">B2B Order Processing, Approval Workflows & Fulfillment</p>
        </div>
        <div className="bg-white border border-slate-200 rounded-lg p-1 flex">
            <button 
                onClick={() => setActiveTab('LIST')}
                className={`px-4 py-1.5 text-sm font-medium rounded transition-colors flex items-center gap-2 ${activeTab === 'LIST' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}
            >
                <CheckSquare size={16} /> Manage Orders
            </button>
            <button 
                onClick={() => setActiveTab('CREATE')}
                className={`px-4 py-1.5 text-sm font-medium rounded transition-colors flex items-center gap-2 ${activeTab === 'CREATE' ? 'bg-slate-800 text-white' : 'text-slate-600 hover:bg-slate-50'}`}
            >
                <ShoppingCart size={16} /> Create Order
            </button>
        </div>
      </div>

      {/* --- ORDER LIST VIEW --- */}
      {activeTab === 'LIST' && (
        <>
          {/* Stats */}
          <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase">Pending Approval</p>
                <h3 className="text-xl font-bold text-yellow-600">{orders.filter(o => o.status === 'Pending Approval').length}</h3>
              </div>
              <div className="p-2 bg-yellow-50 text-yellow-600 rounded-lg"><Clock size={20}/></div>
            </div>
            <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase">Ready to Ship</p>
                <h3 className="text-xl font-bold text-blue-600">{orders.filter(o => o.status === 'Processing').length}</h3>
              </div>
              <div className="p-2 bg-blue-50 text-blue-600 rounded-lg"><Package size={20}/></div>
            </div>
            <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase">Dispatched Today</p>
                <h3 className="text-xl font-bold text-green-600">{orders.filter(o => o.status === 'Shipped').length}</h3>
              </div>
              <div className="p-2 bg-green-50 text-green-600 rounded-lg"><Truck size={20}/></div>
            </div>
            <div className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
              <div>
                <p className="text-slate-500 text-xs font-bold uppercase">Total Order Value</p>
                <h3 className="text-xl font-bold text-slate-800">₹{orders.reduce((acc,o) => acc + o.totalAmount, 0).toLocaleString()}</h3>
              </div>
              <div className="p-2 bg-slate-100 text-slate-600 rounded-lg"><CreditCard size={20}/></div>
            </div>
          </div>

          <div className="flex gap-4 h-[600px]">
            {/* List Sidebar */}
            <div className="w-full lg:w-1/3 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col">
              <div className="p-4 border-b border-slate-100 space-y-3">
                <div className="relative">
                  <Search className="absolute left-3 top-2.5 text-slate-400" size={16} />
                  <input
                    type="text"
                    placeholder="Search orders..."
                    className="w-full pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-1 focus:ring-primary"
                    value={searchTerm}
                    onChange={(e) => setSearchTerm(e.target.value)}
                  />
                </div>
                <div className="flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
                  {['All', 'Pending Approval', 'Approved', 'Shipped'].map(status => (
                    <button 
                      key={status}
                      onClick={() => setStatusFilter(status)}
                      className={`px-3 py-1 text-xs font-medium rounded-full whitespace-nowrap transition-colors ${statusFilter === status ? 'bg-slate-800 text-white' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'}`}
                    >
                      {status === 'Pending Approval' ? 'Pending' : status}
                    </button>
                  ))}
                </div>
              </div>
              <div className="flex-1 overflow-y-auto">
                {filteredOrders.length === 0 ? (
                  <div className="p-8 text-center text-slate-400">No orders found</div>
                ) : (
                  <div className="divide-y divide-slate-100">
                    {filteredOrders.map(order => (
                      <div 
                        key={order.id}
                        onClick={() => setSelectedOrder(order)}
                        className={`p-4 cursor-pointer hover:bg-slate-50 transition-colors ${selectedOrder?.id === order.id ? 'bg-blue-50 border-l-4 border-primary' : ''}`}
                      >
                        <div className="flex justify-between items-start mb-1">
                          <span className="font-bold text-slate-800 text-sm">{order.id}</span>
                          <span className="text-xs text-slate-500">{order.date}</span>
                        </div>
                        <div className="flex justify-between items-center mb-2">
                          <span className="text-sm font-medium text-slate-700 truncate max-w-[120px]">{order.distributorName}</span>
                          <span className="font-bold text-slate-800 text-sm">₹{order.totalAmount.toLocaleString()}</span>
                        </div>
                        <div className="flex justify-between items-center">
                          <span className={`text-[10px] px-2 py-0.5 rounded border font-bold ${getStatusColor(order.status)}`}>
                            {order.status}
                          </span>
                          {order.priority === 'High' && (
                            <span className="text-[10px] px-1.5 py-0.5 rounded bg-red-100 text-red-600 font-bold flex items-center gap-1">
                              <AlertTriangle size={10} /> High Prio
                            </span>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>

            {/* Detail View */}
            <div className="flex-1 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col overflow-hidden">
              {selectedOrder ? (
                <>
                  <div className="p-6 border-b border-slate-100 bg-slate-50 flex justify-between items-start">
                    <div>
                      <div className="flex items-center gap-3 mb-1">
                        <h3 className="text-xl font-bold text-slate-800">Order #{selectedOrder.id}</h3>
                        <span className={`px-2 py-0.5 rounded text-xs font-bold border ${getStatusColor(selectedOrder.status)}`}>
                          {selectedOrder.status}
                        </span>
                      </div>
                      <p className="text-slate-500 text-sm">{selectedOrder.distributorName} • Placed on {selectedOrder.date}</p>
                    </div>
                    <div className="text-right">
                      <p className="text-xs text-slate-500 font-bold uppercase mb-1">Total Value</p>
                      <p className="text-2xl font-bold text-slate-800">₹{selectedOrder.totalAmount.toLocaleString()}</p>
                    </div>
                  </div>

                  {/* Workflow Stepper */}
                  <div className="p-6 border-b border-slate-100">
                    <div className="flex items-center justify-between relative">
                      <div className="absolute left-0 top-1/2 -translate-y-1/2 w-full h-1 bg-slate-200 -z-10"></div>
                      {['Pending Approval', 'Approved', 'Processing', 'Shipped', 'Delivered'].map((step, idx) => {
                        const currentStep = getWorkflowStep(selectedOrder.status);
                        const isCompleted = idx <= currentStep;
                        const isCurrent = idx === currentStep;
                        
                        return (
                          <div key={step} className="flex flex-col items-center bg-white px-2">
                            <div className={`w-8 h-8 rounded-full flex items-center justify-center border-2 transition-all ${isCompleted ? 'bg-green-500 border-green-500 text-white' : 'bg-white border-slate-300 text-slate-300'}`}>
                              {isCompleted ? <CheckCircle size={16} /> : <span className="text-xs font-bold">{idx + 1}</span>}
                            </div>
                            <span className={`text-[10px] font-bold mt-2 uppercase ${isCurrent ? 'text-slate-800' : 'text-slate-400'}`}>{step.split(' ')[0]}</span>
                          </div>
                        );
                      })}
                    </div>
                  </div>

                  <div className="flex-1 overflow-y-auto p-6">
                    {/* Alerts */}
                    {selectedOrder.creditStatus === 'Limit Exceeded' && (
                      <div className="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg flex gap-3 items-start">
                        <AlertTriangle className="text-red-600 shrink-0" size={20} />
                        <div>
                          <h4 className="font-bold text-red-800 text-sm">Credit Limit Warning</h4>
                          <p className="text-xs text-red-700 mt-1">This distributor has exceeded their credit limit. Approval requires Sales Manager override.</p>
                        </div>
                      </div>
                    )}

                    {/* Order Comparison & Items */}
                    <div className="mb-6">
                        <h4 className="font-bold text-slate-700 mb-4 text-sm uppercase flex items-center gap-2"><ClipboardList size={16}/> Order Items & Comparison</h4>
                        <table className="w-full text-left text-sm border-collapse border border-slate-200 rounded-lg overflow-hidden">
                        <thead className="bg-slate-50 text-slate-500 uppercase">
                            <tr>
                            <th className="p-3 pl-4 border-b border-r border-slate-200">Product</th>
                            <th className="p-3 text-center border-b border-r border-slate-200">Requested Qty</th>
                            <th className="p-3 text-center border-b border-r border-slate-200 bg-blue-50/50">Approved Qty</th>
                            <th className="p-3 text-right border-b border-slate-200">Rate</th>
                            <th className="p-3 text-right pr-4 border-b border-slate-200">Amount</th>
                            </tr>
                        </thead>
                        <tbody className="divide-y divide-slate-100">
                            {selectedOrder.items.map((item, idx) => {
                                const isShort = (item.approvedQuantity || 0) < item.quantity;
                                return (
                                <tr key={idx} className={isShort ? 'bg-orange-50/30' : ''}>
                                    <td className="p-3 pl-4 font-medium text-slate-800 border-r border-slate-100">{item.productName}</td>
                                    <td className="p-3 text-center text-slate-600 border-r border-slate-100">{item.quantity}</td>
                                    <td className="p-3 text-center border-r border-slate-100 bg-blue-50/30">
                                        {selectedOrder.status === 'Pending Approval' || selectedOrder.status === 'Approved' ? (
                                            <input 
                                                type="number" 
                                                min="0"
                                                max={item.quantity}
                                                className={`w-16 text-center border rounded py-1 text-sm font-bold outline-none focus:ring-1 ${isShort ? 'border-orange-300 text-orange-700 bg-white' : 'border-slate-300 text-slate-800'}`}
                                                value={item.approvedQuantity ?? item.quantity}
                                                onChange={(e) => updateApprovedQuantity(selectedOrder.id, item.productId, parseInt(e.target.value) || 0)}
                                            />
                                        ) : (
                                            <span className={`font-bold ${isShort ? 'text-red-600' : 'text-slate-800'}`}>
                                                {item.approvedQuantity ?? item.quantity}
                                            </span>
                                        )}
                                        {isShort && <div className="text-[10px] text-red-500 font-bold mt-1">SHORT: {item.quantity - (item.approvedQuantity || 0)}</div>}
                                    </td>
                                    <td className="p-3 text-right text-slate-600">₹{item.rate}</td>
                                    <td className="p-3 text-right pr-4 font-bold text-slate-800">₹{((item.approvedQuantity || item.quantity) * item.rate).toLocaleString()}</td>
                                </tr>
                                )
                            })}
                        </tbody>
                        </table>
                    </div>

                    {/* Specs Card */}
                    <div className="grid grid-cols-2 gap-4">
                        <div className="p-4 bg-slate-50 border border-slate-200 rounded-lg">
                            <h5 className="text-xs font-bold text-slate-500 uppercase mb-2 flex items-center gap-2">
                                <Box size={14} className="text-slate-400"/> Packing Instructions
                            </h5>
                            <p className="text-sm text-slate-700 italic">
                                {selectedOrder.packingSpecs || "No specific packing instructions provided."}
                            </p>
                        </div>
                        <div className="p-4 bg-slate-50 border border-slate-200 rounded-lg">
                            <h5 className="text-xs font-bold text-slate-500 uppercase mb-2 flex items-center gap-2">
                                <Tag size={14} className="text-slate-400"/> Labeling & Marking
                            </h5>
                            <p className="text-sm text-slate-700 italic">
                                {selectedOrder.labelingSpecs || "Standard labeling applies."}
                            </p>
                        </div>
                    </div>

                  </div>

                  {/* Actions Footer */}
                  <div className="p-4 border-t border-slate-200 bg-slate-50 flex justify-end gap-3">
                    {selectedOrder.status === 'Pending Approval' && (
                      <>
                        <button 
                          onClick={() => handleStatusChange(selectedOrder.id, 'Rejected')}
                          className="px-4 py-2 border border-red-200 text-red-600 font-bold rounded-lg hover:bg-red-50 text-sm flex items-center gap-2"
                        >
                          <XCircle size={16}/> Reject
                        </button>
                        <button 
                          onClick={() => handleStatusChange(selectedOrder.id, 'Approved')}
                          className="px-6 py-2 bg-green-600 text-white font-bold rounded-lg hover:bg-green-700 text-sm flex items-center gap-2 shadow-sm"
                        >
                          <CheckCircle size={16}/> Approve Order
                        </button>
                      </>
                    )}
                    {selectedOrder.status === 'Approved' && (
                      <button 
                        onClick={() => handleStatusChange(selectedOrder.id, 'Processing')}
                        className="px-6 py-2 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 text-sm flex items-center gap-2 shadow-sm"
                      >
                        <Package size={16}/> Start Processing
                      </button>
                    )}
                    {selectedOrder.status === 'Processing' && (
                      <button 
                        onClick={() => handleStatusChange(selectedOrder.id, 'Shipped')}
                        className="px-6 py-2 bg-indigo-600 text-white font-bold rounded-lg hover:bg-indigo-700 text-sm flex items-center gap-2 shadow-sm"
                      >
                        <Truck size={16}/> Mark Shipped
                      </button>
                    )}
                  </div>
                </>
              ) : (
                <div className="flex-1 flex flex-col items-center justify-center text-slate-400">
                  <ShoppingCart size={48} className="mb-4 opacity-20" />
                  <p>Select an order to view details and manage workflow.</p>
                </div>
              )}
            </div>
          </div>
        </>
      )}

      {/* --- CREATE ORDER (PORTAL VIEW) --- */}
      {activeTab === 'CREATE' && (
        <div className="flex gap-6 h-[calc(100vh-180px)]">
          {/* Catalog */}
          <div className="flex-1 flex flex-col bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div className="p-4 border-b border-slate-100 bg-slate-50 flex justify-between items-center gap-4">
              <div className="flex-1 relative">
                <Search className="absolute left-3 top-2.5 text-slate-400" size={18} />
                <input
                  type="text"
                  placeholder="Search Product Catalog..."
                  className="w-full pl-10 pr-4 py-2 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary"
                />
              </div>
              <select 
                className="border border-slate-200 rounded-lg px-3 py-2 bg-white text-sm focus:ring-primary focus:outline-none w-64"
                value={selectedDistributorId}
                onChange={(e) => setSelectedDistributorId(e.target.value)}
              >
                <option value="">Select Distributor / Partner</option>
                {MOCK_PCD_PARTNERS.map(p => (
                  <option key={p.id} value={p.id}>{p.name} ({p.territory})</option>
                ))}
              </select>
            </div>
            
            <div className="flex-1 overflow-y-auto p-4 bg-slate-50">
              <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                {MOCK_PRODUCTS.map(product => (
                  <div key={product.id} className="bg-white p-4 rounded-xl border border-slate-200 shadow-sm hover:border-primary transition-all group flex flex-col">
                    <div className="flex justify-between items-start mb-2">
                      <h4 className="font-bold text-slate-800 text-sm group-hover:text-primary transition-colors">{product.name}</h4>
                      <span className="text-xs bg-slate-100 px-2 py-1 rounded text-slate-600">{product.packing}</span>
                    </div>
                    <p className="text-xs text-slate-500 mb-4">{product.genericName}</p>
                    <div className="mt-auto flex justify-between items-center">
                      <div>
                        <p className="text-[10px] text-slate-400 uppercase">PTR</p>
                        <p className="font-bold text-slate-800">₹{(product.batches?.[0]?.purchaseRate || product.rate).toFixed(2)}</p>
                      </div>
                      <button 
                        onClick={() => addToCart(product)}
                        className="bg-slate-900 text-white p-2 rounded-lg hover:bg-primary transition-colors"
                      >
                        <Plus size={16} />
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Cart Sidebar */}
          <div className="w-96 bg-white rounded-xl border border-slate-200 shadow-sm flex flex-col overflow-hidden">
            <div className="p-4 border-b border-slate-100 bg-slate-50 font-bold text-slate-800 flex items-center gap-2">
              <ShoppingCart size={18} /> New Order Cart
            </div>
            
            <div className="flex-1 overflow-y-auto p-4 space-y-3">
              {cart.length === 0 ? (
                <div className="text-center py-10 text-slate-400">
                  <Box size={40} className="mx-auto mb-2 opacity-30"/>
                  <p className="text-sm">Cart is empty</p>
                </div>
              ) : (
                cart.map((item, idx) => (
                  <div key={idx} className="flex items-center gap-3 bg-slate-50 p-3 rounded-lg border border-slate-100">
                    <div className="flex-1 min-w-0">
                      <p className="font-bold text-slate-800 text-sm truncate">{item.product.name}</p>
                      <p className="text-xs text-slate-500">₹{item.product.rate || item.product.mrp * 0.7}</p>
                    </div>
                    <div className="flex items-center gap-2 bg-white rounded border border-slate-200">
                      <button 
                        onClick={() => updateCartQty(item.product.id, item.quantity - 1)}
                        className="px-2 py-1 text-slate-600 hover:bg-slate-100"
                      >-</button>
                      <span className="text-sm font-bold w-4 text-center">{item.quantity}</span>
                      <button 
                        onClick={() => updateCartQty(item.product.id, item.quantity + 1)}
                        className="px-2 py-1 text-slate-600 hover:bg-slate-100"
                      >+</button>
                    </div>
                  </div>
                ))
              )}
            </div>

            {/* Specifications Input */}
            <div className="p-4 border-t border-slate-100 bg-slate-50 space-y-3">
                <div className="space-y-1">
                    <label className="text-xs font-bold text-slate-500 uppercase flex items-center gap-1"><Box size={12}/> Packing Specs</label>
                    <input 
                        type="text" 
                        placeholder="e.g. 7 Ply Box, Bubble Wrap" 
                        className="w-full text-sm border border-slate-300 rounded px-2 py-1.5 focus:ring-1 focus:ring-primary outline-none"
                        value={packingInstructions}
                        onChange={(e) => setPackingInstructions(e.target.value)}
                    />
                </div>
                <div className="space-y-1">
                    <label className="text-xs font-bold text-slate-500 uppercase flex items-center gap-1"><Tag size={12}/> Labeling Specs</label>
                    <input 
                        type="text" 
                        placeholder="e.g. Print 'Fragile'" 
                        className="w-full text-sm border border-slate-300 rounded px-2 py-1.5 focus:ring-1 focus:ring-primary outline-none"
                        value={labelingInstructions}
                        onChange={(e) => setLabelingInstructions(e.target.value)}
                    />
                </div>
            </div>

            <div className="p-4 bg-slate-50 border-t border-slate-200">
              <div className="flex justify-between items-center mb-4">
                <span className="text-slate-600 text-sm font-medium">Total Amount</span>
                <span className="text-xl font-bold text-slate-900">
                  ₹{cart.reduce((sum, item) => sum + (item.quantity * (item.product.rate || item.product.mrp * 0.7)), 0).toLocaleString()}
                </span>
              </div>
              <button 
                onClick={handlePlaceOrder}
                disabled={cart.length === 0 || !selectedDistributorId}
                className="w-full py-3 bg-primary text-white font-bold rounded-xl hover:bg-sky-600 shadow-lg shadow-primary/30 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed transition-all"
              >
                Place Order <ArrowRight size={18} />
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default OMS;
