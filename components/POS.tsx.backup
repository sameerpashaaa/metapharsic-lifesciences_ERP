import React, { useState, useEffect, useRef } from 'react';
import { Search, Plus, Save, Printer, X, Trash2, AlertCircle, Package, Gift, ChevronDown, User, Phone, MapPin, Calendar, CreditCard, Truck, FileText, Calculator, History, TrendingUp } from 'lucide-react';
import { MOCK_PRODUCTS } from '../constants';
import { Product, Batch, SalesInvoice, SalesInvoiceItem, Party } from '../types';
import { useAuth } from '../context/AuthContext';
import { useKeyboardShortcuts } from '../context/KeyboardShortcutContext';
import { saveInvoice, getAllInvoices, searchProducts, getAllParties, saveParty, getLastRate } from '../services/databaseService';

const POS: React.FC = () => {
  // --- State: Invoice Header ---
  const [invoiceNumber, setInvoiceNumber] = useState('');
  const [invoiceDate, setInvoiceDate] = useState(new Date().toISOString().split('T')[0]);
  const [invoiceType, setInvoiceType] = useState<'Retail' | 'Wholesale' | 'Tax Invoice' | 'Bill of Supply' | 'Debit Note' | 'Credit Note'>('Retail');
  const [financialYear, setFinancialYear] = useState('2024-25');
  const [seriesPrefix, setSeriesPrefix] = useState('INV/2024-25/');
  
  // --- State: Customer Details ---
  const [customerName, setCustomerName] = useState('');
  const [customerCode, setCustomerCode] = useState('');
  const [billingAddress, setBillingAddress] = useState('');
  const [shippingAddress, setShippingAddress] = useState('');
  const [customerState, setCustomerState] = useState('');
  const [stateCode, setStateCode] = useState('');
  const [gstin, setGstin] = useState('');
  const [drugLicenseNo, setDrugLicenseNo] = useState('');
  const [contactNumber, setContactNumber] = useState('');
  const [email, setEmail] = useState('');
  const [routeArea, setRouteArea] = useState('');
  const [salesmanName, setSalesmanName] = useState('');
  const [existingParties, setExistingParties] = useState<Party[]>([]);
  const [showCustomerModal, setShowCustomerModal] = useState(false);
  
  // --- State: Payment Details ---
  const [paymentMode, setPaymentMode] = useState<'Cash' | 'UPI' | 'Card' | 'Credit' | 'Multi'>('Cash');
  const [creditDays, setCreditDays] = useState(0);
  const [dueDate, setDueDate] = useState('');
  const [outstandingBalance, setOutstandingBalance] = useState(0);
  const [creditLimit, setCreditLimit] = useState(0);
  const [transportMode, setTransportMode] = useState('');
  const [ewayBillNo, setEwayBillNo] = useState('');
  
  // --- State: Payment Split ---
  const [paymentSplit, setPaymentSplit] = useState({ cash: 0, upi: 0, card: 0, credit: 0 });
  
  // --- State: Line Items ---
  const [cartItems, setCartItems] = useState<SalesInvoiceItem[]>([]);
  const [selectedProduct, setSelectedProduct] = useState<Product | null>(null);
  const [selectedProductId, setSelectedProductId] = useState<string>(''); // Track dropdown selection
  const [showBatchModal, setShowBatchModal] = useState(false);
  const [showProductModal, setShowProductModal] = useState(false);
  const [showCalculator, setShowCalculator] = useState(false);
  const [calcValue, setCalcValue] = useState('');
  
  const [recentInvoices, setRecentInvoices] = useState<SalesInvoice[]>([]);
  const [showTallySync, setShowTallySync] = useState(false);

  // Load initial data
  useEffect(() => {
    const loadData = async () => {
      const invoices = await getAllInvoices();
      setRecentInvoices(invoices.slice(-5).reverse());
    };
    loadData();
  }, []);
  useEffect(() => {
    console.log('cartItems updated:', cartItems);
  }, [cartItems]);
  
  const [searchTerm, setSearchTerm] = useState('');
  const [searchResults, setSearchResults] = useState<Product[]>(MOCK_PRODUCTS);
  const [barcodeInput, setBarcodeInput] = useState('');
  const [isBarcodeMode, setIsBarcodeMode] = useState(true);
  const barcodeRef = useRef<HTMLInputElement>(null);
  const [hoveredProduct, setHoveredProduct] = useState<Product | null>(null);
  const [lastRateInfo, setLastRateInfo] = useState<{rate: number, discount: number} | null>(null);
  const [showSettlementModal, setShowSettlementModal] = useState(false);
  const [focusedSearchIndex, setFocusedSearchIndex] = useState(-1);
  
  // --- State: Calculations ---
  const [totalTaxable, setTotalTaxable] = useState(0);
  const [totalCgst, setTotalCgst] = useState(0);
  const [totalSgst, setTotalSgst] = useState(0);
  const [totalIgst, setTotalIgst] = useState(0);
  const [roundOff, setRoundOff] = useState(0);
  const [freightCharges, setFreightCharges] = useState(0);
  const [otherCharges, setOtherCharges] = useState(0);
  const [tcs, setTcs] = useState(0);
  const [tds, setTds] = useState(0);
  const [netPayable, setNetPayable] = useState(0);
  const [amountInWords, setAmountInWords] = useState('');
  
  const [doctorName, setDoctorName] = useState('');
  const [patientName, setPatientName] = useState('');
  const [isH1Invoice, setIsH1Invoice] = useState(false);
  
  const { hasPermission } = useAuth();
  const canGiveDiscount = hasPermission(['ADMIN', 'PHARMACIST']);
  const canReturn = hasPermission(['ADMIN', 'PHARMACIST']);
  const invoiceRef = useRef<HTMLDivElement>(null);

  // Generate invoice number
  useEffect(() => {
    const generateInvoiceNumber = () => {
      const date = new Date();
      const year = date.getFullYear().toString().slice(-2);
      const month = (date.getMonth() + 1).toString().padStart(2, '0');
      const day = date.getDate().toString().padStart(2, '0');
      const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
      return `${seriesPrefix}${year}${month}${day}${random}`;
    };
    
    if (!invoiceNumber) {
      setInvoiceNumber(generateInvoiceNumber());
    }
  }, [seriesPrefix, invoiceNumber]);

  // Load data on component mount
  useEffect(() => {
    const loadData = async () => {
      try {
        const [products, parties] = await Promise.all([
          searchProducts(''),
          getAllParties()
        ]);
        
        if (products.length > 0) {
          setSearchResults(products);
        }
        setExistingParties(parties);
      } catch (error) {
        console.error('Error loading data:', error);
        setSearchResults(MOCK_PRODUCTS);
      }
    };
    
    loadData();
  }, []);

  // Calculate totals
  useEffect(() => {
    const taxable = cartItems.reduce((sum, item) => sum + item.taxableValue, 0);
    const cgst = cartItems.reduce((sum, item) => sum + item.cgstAmount, 0);
    const sgst = cartItems.reduce((sum, item) => sum + item.sgstAmount, 0);
    const igst = cartItems.reduce((sum, item) => sum + item.igstAmount, 0);
    const total = taxable + cgst + sgst + igst + freightCharges + otherCharges + tcs - tds + roundOff;
    
    setTotalTaxable(taxable);
    setTotalCgst(cgst);
    setTotalSgst(sgst);
    setTotalIgst(igst);
    setNetPayable(total);
    
    // Convert to words
    setAmountInWords(numberToWords(Math.round(total)));
  }, [cartItems, freightCharges, otherCharges, tcs, tds, roundOff]);

  // Update search results when search term changes
  useEffect(() => {
    const performSearch = async () => {
      if (searchTerm.trim() === '') {
        setSearchResults(MOCK_PRODUCTS);
        return;
      }
      
      try {
        const results = await searchProducts(searchTerm);
        setSearchResults(results.length > 0 ? results : MOCK_PRODUCTS);
      } catch (error) {
        console.error('Error searching products:', error);
        // Fallback to local search with alias support
        const term = searchTerm.toLowerCase();
        const localResults = MOCK_PRODUCTS.filter(p =>
          p.name.toLowerCase().includes(term) ||
          p.genericName?.toLowerCase().includes(term) ||
          p.manufacturer?.toLowerCase().includes(term) ||
          p.alias?.some(alias => alias.toLowerCase().includes(term)) ||
          p.therapeuticCategory?.toLowerCase().includes(term) ||
          p.hsn?.toLowerCase().includes(term)
        );
        setSearchResults(localResults);
      }
    };
    
    const timeoutId = setTimeout(performSearch, 300);
    return () => clearTimeout(timeoutId);
  }, [searchTerm]);

  // Number to words conversion
  const numberToWords = (num: number): string => {
    const units = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
    const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];
    const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
    
    if (num === 0) return 'Zero';
    if (num < 0) return 'Minus ' + numberToWords(Math.abs(num));
    
    let words = '';
    
    if (Math.floor(num / 10000000) > 0) {
      words += numberToWords(Math.floor(num / 10000000)) + ' Crore ';
      num %= 10000000;
    }
    
    if (Math.floor(num / 100000) > 0) {
      words += numberToWords(Math.floor(num / 100000)) + ' Lakh ';
      num %= 100000;
    }
    
    if (Math.floor(num / 1000) > 0) {
      words += numberToWords(Math.floor(num / 1000)) + ' Thousand ';
      num %= 1000;
    }
    
    if (Math.floor(num / 100) > 0) {
      words += numberToWords(Math.floor(num / 100)) + ' Hundred ';
      num %= 100;
    }
    
    if (num > 0) {
      if (num < 10) {
        words += units[num];
      } else if (num < 20) {
        words += teens[num - 10];
      } else {
        words += tens[Math.floor(num / 10)];
        if (num % 10 > 0) {
          words += ' ' + units[num % 10];
        }
      }
    }
    
    return words.trim();
  };
  
  // --- Barcode Function ---
  const handleBarcodeScan = async (code: string) => {
    if (!code) return;
    try {
      // Find product by barcode or batch barcode
      const results = await searchProducts(code);
      const product = results.find(p => 
        p.barcode === code || 
        p.batches?.some(b => b.barcode === code)
      );
      
      if (product) {
        // Find specific batch if barcode matches batch
        const specificBatch = product.batches?.find(b => b.barcode === code);
        
        if (specificBatch) {
          addBatchToCartInternal(product, specificBatch);
        } else if (product.batches && product.batches.length > 0) {
          // FEFO selection: Sort by expiry and pick first with stock
          const fefoBatch = [...product.batches]
            .sort((a, b) => new Date(a.expiryDate).getTime() - new Date(b.expiryDate).getTime())
            .find(b => b.stock > 0 && new Date(b.expiryDate) > new Date());
            
          if (fefoBatch) {
            addBatchToCartInternal(product, fefoBatch);
          } else {
            handleProductClick(product);
          }
        }
      } else {
        console.warn('No product found for barcode:', code);
      }
    } catch (error) {
      console.error('Barcode scan error:', error);
    }
    setBarcodeInput('');
  };

  const addBatchToCartInternal = (product: Product, batch: Batch) => {
    const existingIndex = cartItems.findIndex(item => 
      item.productId === product.id && item.batchId === batch.id
    );
    
    if (existingIndex >= 0) {
      const updatedCart = [...cartItems];
      const item = updatedCart[existingIndex];
      if (item.quantity + 1 > batch.stock) {
        alert("Stock limit reached!");
        return;
      }
      const newQty = item.quantity + 1;
      const total = item.rate * newQty;
      const disc = total * (item.discountPercent / 100);
      const net = total - disc;
      const taxable = net / (1 + (item.gstPercent / 100));
      const gst = net - taxable;
      
      updatedCart[existingIndex] = {
        ...item,
        quantity: newQty,
        discountAmount: disc,
        taxableValue: taxable,
        cgstAmount: gst/2,
        sgstAmount: gst/2,
        totalAmount: net
      };
      setCartItems(updatedCart);
    } else {
      const newItem: SalesInvoiceItem = {
        id: `item-${Date.now()}`,
        productId: product.id,
        productName: product.name,
        genericName: product.genericName,
        hsn: product.hsn,
        batchId: batch.id,
        batchNumber: batch.batchNumber,
        expiryDate: batch.expiryDate,
        quantity: 1,
        freeQuantity: 0,
        mrp: batch.mrp,
        rate: batch.mrp,
        discountPercent: 0,
        discountAmount: 0,
        taxableValue: batch.mrp / (1 + (product.gst / 100)),
        gstPercent: product.gst,
        cgstAmount: (batch.mrp * product.gst / 2) / 100,
        sgstAmount: (batch.mrp * product.gst / 2) / 100,
        igstAmount: 0,
        totalAmount: batch.mrp,
        schemeApplied: product.scheme,
        uom: product.uom,
        purchaseRate: batch.purchaseRate,
        maxStock: batch.stock
      };
      setCartItems(prev => [...prev, newItem]);
    }
  };

  // --- Cart Functions ---
  const handleProductClick = async (product: Product) => {
    console.log('handleProductClick called with product:', product);
    const totalAvailableStock = product.batches?.reduce((acc, b) => acc + b.stock, 0) || 0;
    
    if (totalAvailableStock <= 0) {
      alert("No stock available for this product.");
      return;
    }
    
    // Fetch last rate if customer is selected
    if (customerName) {
      const lastRate = await getLastRate(customerName, product.id);
      setLastRateInfo(lastRate);
    } else {
      setLastRateInfo(null);
    }
    
    setSelectedProduct(product);
    setShowBatchModal(true);
  };

  const addBatchToCart = (batch: Batch) => {
    console.log('addBatchToCart called with batch:', batch);
    console.log('selectedProduct:', selectedProduct);
    
    if (!selectedProduct) {
      console.log('No selected product');
      return;
    }
    
    const existingIndex = cartItems.findIndex(item => 
      item.productId === selectedProduct.id && item.batchId === batch.id
    );
    
    console.log('existingIndex:', existingIndex);
    console.log('cartItems before:', cartItems);
    
    if (existingIndex >= 0) {
      // Update existing line
      const updatedCart = [...cartItems];
      const existingItem = updatedCart[existingIndex];
      
      if (existingItem.quantity + 1 > batch.stock) {
        alert("Insufficient stock in batch.");
        return;
      }
      
      const newQty = existingItem.quantity + 1;
      
      // --- INDUSTRIAL SCHEME LOGIC ---
      let freeQty = 0;
      if (existingItem.schemeApplied === '10+1' && newQty >= 10) {
        freeQty = Math.floor(newQty / 10);
      } else if (existingItem.schemeApplied === '10+2' && newQty >= 10) {
        freeQty = Math.floor(newQty / 10) * 2;
      }

      const itemTotalGross = existingItem.rate * newQty;
      const discAmt = itemTotalGross * (existingItem.discountPercent / 100);
      const net = itemTotalGross - discAmt;
      const taxable = net / (1 + (existingItem.gstPercent / 100));
      const gstAmt = net - taxable;
      
      updatedCart[existingIndex] = {
        ...existingItem,
        quantity: newQty,
        freeQuantity: freeQty,
        discountAmount: discAmt,
        taxableValue: taxable,
        cgstAmount: gstAmt / 2,
        sgstAmount: gstAmt / 2,
        totalAmount: net
      };
      
      setCartItems(updatedCart);
      console.log('Updated existing item, cartItems after:', updatedCart);
    } else {
      // Add new line
      if (batch.stock <= 0) {
        alert("No stock available in this batch.");
        return;
      }
      
      const newItem: SalesInvoiceItem = {
        id: `item-${Date.now()}`,
        productId: selectedProduct.id,
        productName: selectedProduct.name,
        genericName: selectedProduct.genericName,
        hsn: selectedProduct.hsn,
        batchId: batch.id,
        batchNumber: batch.batchNumber,
        expiryDate: batch.expiryDate,
        quantity: 1,
        freeQuantity: 0,
        mrp: batch.mrp,
        rate: batch.mrp,
        discountPercent: 0,
        discountAmount: 0,
        taxableValue: batch.mrp / (1 + (selectedProduct.gst / 100)),
        gstPercent: selectedProduct.gst,
        cgstAmount: (batch.mrp * selectedProduct.gst / 2) / 100,
        sgstAmount: (batch.mrp * selectedProduct.gst / 2) / 100,
        igstAmount: 0,
        totalAmount: batch.mrp,
        schemeApplied: selectedProduct.scheme,
        uom: selectedProduct.uom,
        purchaseRate: batch.purchaseRate,
        maxStock: batch.stock
      };
      
      if (selectedProduct.scheduleType === 'H1') {
        setIsH1Invoice(true);
      }
      
      setCartItems(prev => {
        const newCart = [...prev, newItem];
        console.log('Added new item, cartItems after:', newCart);
        return newCart;
      });
    }
    
    setShowBatchModal(false);
  };

  const updateLineItem = (index: number, updates: Partial<SalesInvoiceItem>) => {
    setCartItems(prev => {
      const updated = [...prev];
      const item = updated[index];
      
      // Stock Validation
      if ('quantity' in updates) {
        const newQty = updates.quantity as number;
        if (newQty > item.maxStock) {
          alert(`Insufficient stock! Max available: ${item.maxStock}`);
          return prev; // Don't update
        }
      }

      // Apply updates
      Object.assign(item, updates);
      
      // Recalculate if quantity or discount changed
      if ('quantity' in updates || 'discountPercent' in updates || 'rate' in updates) {
        const itemTotalGross = item.rate * item.quantity;
        
        // --- INDUSTRIAL SCHEME LOGIC ---
        let freeQty = 0;
        if (item.schemeApplied === '10+1' && item.quantity >= 10) {
          freeQty = Math.floor(item.quantity / 10);
        } else if (item.schemeApplied === '10+2' && item.quantity >= 10) {
          freeQty = Math.floor(item.quantity / 10) * 2;
        }
        item.freeQuantity = freeQty;

        const discAmt = itemTotalGross * (item.discountPercent / 100);
        const net = itemTotalGross - discAmt;
        const taxable = net / (1 + (item.gstPercent / 100));
        const gstAmt = net - taxable;
        
        item.discountAmount = discAmt;
        item.taxableValue = taxable;
        item.cgstAmount = gstAmt / 2;
        item.sgstAmount = gstAmt / 2;
        item.totalAmount = net;
      }
      
      return updated;
    });
  };

  const removeLineItem = (index: number) => {
    setCartItems(prev => prev.filter((_, i) => i !== index));
  };

  // Save invoice to database
  const handleSaveInvoice = async () => {
    if (cartItems.length === 0) {
      alert("Please add at least one item to the invoice.");
      return;
    }
    
    if (!customerName.trim()) {
      alert("Please enter customer name.");
      return;
    }
    
    const invoice: SalesInvoice = {
      id: `inv-${Date.now()}`,
      invoiceNumber,
      date: invoiceDate,
      time: new Date().toLocaleTimeString(),
      customerName,
      customerMobile: contactNumber,
      customerGstin: gstin,
      billingAddress,
      doctorName,
      patientName,
      isH1: isH1Invoice,
      items: cartItems,
      totalItems: cartItems.length,
      totalQuantity: cartItems.reduce((sum, item) => sum + item.quantity + item.freeQuantity, 0),
      subTotal: cartItems.reduce((sum, item) => sum + (item.rate * item.quantity), 0),
      taxableValue: totalTaxable,
      totalDiscount: cartItems.reduce((sum, item) => sum + item.discountAmount, 0),
      totalGst: totalCgst + totalSgst + totalIgst,
      roundOff,
      netAmount: netPayable,
      paymentMode,
      paymentSplit: paymentMode === 'Multi' ? paymentSplit : undefined,
      amountReceived: paymentMode === 'Credit' ? 0 : (paymentMode === 'Multi' ? (paymentSplit.cash + paymentSplit.upi + paymentSplit.card) : netPayable),
      balanceDue: paymentMode === 'Credit' ? netPayable : (paymentMode === 'Multi' ? paymentSplit.credit : 0),
      status: 'Completed'
    };
    
    try {
      const success = await saveInvoice(invoice);
      if (success) {
        alert("Invoice saved successfully!");
        // Reset form
        setCartItems([]);
        setInvoiceDate(new Date().toISOString().split('T')[0]);
        setDoctorName('');
        setPatientName('');
        setIsH1Invoice(false);
        setPaymentSplit({ cash: 0, upi: 0, card: 0, credit: 0 });
        setShowSettlementModal(false);
      } else {
        alert("Failed to save invoice. Please try again.");
      }
    } catch (error) {
      console.error("Error saving invoice:", error);
      alert("Error saving invoice. Please try again.");
    }
  };

  // Print invoice
  const handlePrintInvoice = () => {
    if (!invoiceRef.current) return;
    
    const printContent = invoiceRef.current.innerHTML;
    const printWindow = window.open('', '_blank');
    if (printWindow) {
      printWindow.document.write(`
        <html>
          <head>
            <title>Invoice ${invoiceNumber}</title>
            <style>
              body { font-family: Arial, sans-serif; margin: 20px; }
              .invoice-header { text-align: center; margin-bottom: 20px; }
              .invoice-details { margin-bottom: 20px; }
              .items-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
              .items-table th, .items-table td { border: 1px solid #000; padding: 8px; text-align: left; }
              .items-table th { background-color: #f0f0f0; }
              .totals { margin-top: 20px; }
              .signature { margin-top: 40px; text-align: right; }
            </style>
          </head>
          <body>
            ${printContent}
          </body>
        </html>
      `);
      printWindow.document.close();
      printWindow.print();
    }
  };

  // Register keyboard shortcuts for POS
  useEffect(() => {
    const handleKeyDown = (event: KeyboardEvent) => {
      // Barcode focus (F9 or Alt+B)
      if (event.key === 'F9' || (event.altKey && event.key === 'b')) {
        event.preventDefault();
        setIsBarcodeMode(true);
        barcodeRef.current?.focus();
      }

      // Prevent shortcuts from triggering when typing in inputs (except for global hotkeys like F2, F8)
      if (['INPUT', 'TEXTAREA', 'SELECT'].includes((event.target as HTMLElement).tagName)) {
         // Allow F-keys even in inputs
         if (!event.key.startsWith('F') && !event.ctrlKey && !event.altKey) return;
      }

      // Save invoice (Ctrl+S or Ctrl+A)
      if (event.ctrlKey && (event.key === 's' || event.key === 'a')) {
        event.preventDefault();
        if (cartItems.length > 0 && customerName.trim()) {
          handleSaveInvoice();
        }
      }
      
      // Print invoice (Alt+P or Ctrl+Shift+P)
      if ((event.altKey && event.key === 'p') || (event.ctrlKey && event.shiftKey && event.key === 'P')) {
        event.preventDefault();
        if (cartItems.length > 0) {
          handlePrintInvoice();
        }
      }
      
      // Focus search (Alt+S or Ins)
      if ((event.altKey && event.key === 's') || event.key === 'Insert') {
        event.preventDefault();
        setIsBarcodeMode(false);
        const searchInput = document.querySelector('input[placeholder*="Search"]') as HTMLInputElement;
        if (searchInput) searchInput.focus();
      }

      // F2: Set focus to Date
      if (event.key === 'F2') {
        event.preventDefault();
        const dateInput = document.querySelector('input[type="date"]') as HTMLInputElement;
        if (dateInput) dateInput.focus();
      }

      // F1: Select Party
      if (event.key === 'F1') {
        event.preventDefault();
        setShowCustomerModal(true);
      }

      // F8: Toggle Bill type
      if (event.key === 'F8') {
        event.preventDefault();
        setInvoiceType(prev => prev === 'Retail' ? 'Wholesale' : 'Retail');
      }

      // F10: Open Settlement Modal
      if (event.key === 'F10') {
        event.preventDefault();
        setShowSettlementModal(true);
      }
      
      // Clear invoice (Ctrl+Shift+X)
      if (event.ctrlKey && event.shiftKey && event.key === 'X') {
        event.preventDefault();
        if (window.confirm('Clear all invoice items?')) {
          setCartItems([]);
        }
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [cartItems, customerName]);

  return (
    <div className="flex flex-col lg:flex-row h-[calc(100vh-2rem)] gap-4 animate-fadeIn p-4 bg-slate-50/50">
      
      {/* ─── LEFT COLUMN: TRANSACTION ENTRY ─── */}
      <div className="flex-1 flex flex-col gap-4 overflow-hidden">
        
        {/* Top Action Bar: Barcode & Quick Search */}
        <div className="bg-white rounded-xl border border-slate-200 shadow-sm p-3 flex flex-wrap items-center gap-4">
          <div className="flex-1 min-w-[300px] relative">
            <div className={`absolute left-3 top-2.5 transition-colors ${isBarcodeMode ? 'text-blue-600' : 'text-slate-400'}`}>
              {isBarcodeMode ? <div className="animate-pulse"><Package size={20} /></div> : <Search size={20} />}
            </div>
            <input
              ref={barcodeRef}
              type="text"
              placeholder={isBarcodeMode ? "RESCAN BARCODE / QR CODE..." : "Search Product (Alt+S)..."}
              className={`w-full pl-10 pr-32 py-2.5 border-2 rounded-lg outline-none transition-all ${isBarcodeMode ? 'border-blue-500 bg-blue-50/30 focus:ring-4 focus:ring-blue-100' : 'border-slate-200 focus:border-blue-400 font-bold'}`}
              value={isBarcodeMode ? barcodeInput : searchTerm}
              onChange={(e) => {
                const val = e.target.value;
                if (isBarcodeMode) setBarcodeInput(val);
                else {
                  setSearchTerm(val);
                  setFocusedSearchIndex(-1);
                }
              }}
              onKeyDown={(e) => {
                if (e.key === 'Enter') {
                  if (isBarcodeMode) handleBarcodeScan(barcodeInput);
                  else if (focusedSearchIndex >= 0 && searchResults[focusedSearchIndex]) {
                    handleProductClick(searchResults[focusedSearchIndex]);
                  }
                }
                if (!isBarcodeMode) {
                  if (e.key === 'ArrowDown') {
                    setFocusedSearchIndex(prev => Math.min(prev + 1, searchResults.length - 1));
                    e.preventDefault();
                  }
                  if (e.key === 'ArrowUp') {
                    setFocusedSearchIndex(prev => Math.max(prev - 1, 0));
                    e.preventDefault();
                  }
                }
              }}
              autoFocus
            />
            
            {/* ─── FLOATING SEARCH RESULTS (MARG STYLE DENSITY) ─── */}
            {!isBarcodeMode && searchTerm && (
              <div className="absolute left-0 right-0 top-full mt-1 bg-white border border-slate-200 shadow-2xl rounded-xl z-50 overflow-hidden max-h-[60vh] flex flex-col">
                <div className="bg-slate-900 text-slate-400 text-[10px] font-bold uppercase p-2 flex justify-between">
                   <span>Product / Medicine Search</span>
                   <span>Results: {searchResults.length}</span>
                </div>
                <div className="overflow-y-auto">
                  {searchResults.map((p, idx) => (
                    <div 
                      key={p.id}
                      onMouseEnter={() => setHoveredProduct(p)}
                      onClick={() => handleProductClick(p)}
                      className={`p-3 border-b border-slate-100 flex items-center justify-between cursor-pointer transition-colors ${focusedSearchIndex === idx ? 'bg-blue-600 text-white' : 'hover:bg-blue-50'}`}
                    >
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center gap-2">
                          <span className="font-bold truncate">{p.name}</span>
                          <span className={`text-[10px] px-1.5 rounded font-bold ${focusedSearchIndex === idx ? 'bg-white/20 text-white' : 'bg-slate-100 text-slate-500'}`}>{p.packing}</span>
                        </div>
                        <div className={`text-[10px] uppercase truncate ${focusedSearchIndex === idx ? 'text-blue-100' : 'text-slate-500'}`}>
                          {p.genericName} • {p.manufacturer}
                        </div>
                        {p.composition && (
                          <div className={`text-[10px] italic truncate ${focusedSearchIndex === idx ? 'text-blue-200' : 'text-slate-400'}`}>
                            Salt: {p.composition}
                          </div>
                        )}
                      </div>
                      <div className="text-right ml-4">
                        <div className="font-bold">₹{p.batches?.[0]?.mrp.toFixed(2)}</div>
                        <div className={`text-[10px] font-bold ${p.totalStock > 0 ? (focusedSearchIndex === idx ? 'text-green-200' : 'text-green-600') : 'text-red-500'}`}>
                          Stock: {p.totalStock} {p.uom}s
                        </div>
                      </div>
                    </div>
                  ))}
                  {searchResults.length === 0 && (
                    <div className="p-10 text-center text-slate-400 italic">No products matched "{searchTerm}"</div>
                  )}
                </div>
                
                {/* ─── SIDE INFO PANE (HOVER DETAILS) ─── */}
                {hoveredProduct && (
                  <div className="bg-slate-50 border-t border-slate-200 p-3 grid grid-cols-3 gap-4 text-[11px] animate-fadeIn">
                    <div className="col-span-2">
                       <div className="font-bold text-slate-800 uppercase mb-1">Batch Availability (FEFO)</div>
                       <div className="flex flex-wrap gap-2">
                         {hoveredProduct.batches?.map(b => (
                           <div key={b.id} className="bg-white border border-slate-200 p-1.5 rounded shadow-sm">
                             <div className="font-bold text-blue-700">{b.batchNumber}</div>
                             <div className="text-slate-500">Exp: {b.expiryDate} | Stock: {b.stock}</div>
                             <div className="text-slate-900 font-bold">Rate: ₹{b.sellingRate}</div>
                           </div>
                         ))}
                       </div>
                    </div>
                    <div>
                       <div className="font-bold text-slate-800 uppercase mb-1 underline">Last Deal</div>
                       {customerName ? (
                         <div className="bg-blue-100/50 p-2 rounded border border-blue-200 text-blue-900">
                            <div className="font-bold">Rate: ₹22.50</div>
                            <div className="text-[10px]">Disc: 5% | Date: 10-Mar</div>
                         </div>
                       ) : (
                         <div className="text-slate-400 italic">Select party to view history</div>
                       )}
                    </div>
                  </div>
                )}
              </div>
            )}
            <div className="absolute right-2 top-1.5 flex gap-1">
              <button 
                onClick={() => setIsBarcodeMode(!isBarcodeMode)}
                className={`px-3 py-1.5 rounded-md text-xs font-bold uppercase transition-all ${isBarcodeMode ? 'bg-blue-600 text-white shadow-lg' : 'bg-slate-100 text-slate-500 hover:bg-slate-200'}`}
              >
                {isBarcodeMode ? 'Barcode Active' : 'Manual Search'}
              </button>
            </div>
          </div>

          <div className="flex gap-2">
            <button onClick={() => setShowCustomerModal(true)} className="bg-white border border-slate-200 text-slate-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-50 flex items-center gap-2">
              <User size={16} /> Select Party (F1)
            </button>
            <button onClick={() => setSearchTerm('')} className="bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-900 flex items-center gap-2">
              <Plus size={16} /> New Item (Ins)
            </button>
          </div>
        </div>

        {/* Invoice Header (Professional pharma-style details) */}
        <div className="bg-white rounded-xl border border-slate-200 shadow-sm p-4 text-xs">
          <div className="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6">
             <div className="border-r border-slate-100 pr-4">
               <label className="text-slate-400 font-bold uppercase mb-1 block">Invoice # (Auto)</label>
               <div className="font-black text-slate-800 text-sm tracking-tight">{invoiceNumber}</div>
               <div className="text-[10px] text-slate-400 font-bold mt-0.5">{financialYear} Series</div>
             </div>
             <div className="border-r border-slate-100 pr-4">
               <label className="text-slate-400 font-bold uppercase mb-1 block font-mono">Bill Date (F2)</label>
               <input type="date" value={invoiceDate} onChange={e => setInvoiceDate(e.target.value)} className="w-full font-black text-slate-800 bg-transparent outline-none text-sm" />
             </div>
             <div className="border-r border-slate-100 pr-4 drop-shadow-sm">
               <label className="text-slate-400 font-bold uppercase mb-1 block">Doctor Name</label>
               <input type="text" value={doctorName} onChange={e => setDoctorName(e.target.value)} placeholder="Dr. (Name)" className="w-full font-black text-slate-800 bg-transparent outline-none placeholder:font-normal placeholder:text-slate-300" />
             </div>
             <div className="border-r border-slate-100 pr-4">
               <label className="text-slate-400 font-bold uppercase mb-1 block">Patient Name</label>
               <input type="text" value={patientName} onChange={e => setPatientName(e.target.value)} placeholder="Patient Name" className="w-full font-black text-slate-800 bg-transparent outline-none placeholder:font-normal placeholder:text-slate-300" />
             </div>
             <div className="border-r border-slate-100 pr-4">
               <div className="flex justify-between items-center mb-1">
                 <label className="text-slate-400 font-bold uppercase block">Bill Type (F8)</label>
                 {isH1Invoice && <span className="bg-red-600 text-white px-1.5 py-0.5 rounded-[4px] font-black text-[9px] animate-pulse">H1 REQ</span>}
               </div>
               <select value={invoiceType} onChange={e => setInvoiceType(e.target.value as any)} className="w-full font-black text-blue-700 bg-transparent outline-none appearance-none cursor-pointer">
                  <option>Retail</option>
                  <option>Wholesale</option>
                  <option>Tax Invoice</option>
               </select>
             </div>
             <div>
                <label className="text-slate-400 font-bold uppercase mb-1 block">Outstanding</label>
                <div className={`font-black text-sm ${outstandingBalance > 0 ? 'text-red-600' : 'text-green-600'}`}>
                  ₹{outstandingBalance.toFixed(2)}
                </div>
             </div>
          </div>
        </div>

        {/* Main Items Table */}
        <div className="flex-1 bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
          <div className="overflow-x-auto flex-1">
            <table className="w-full text-sm">
              <thead className="bg-slate-900 text-slate-200 font-bold uppercase text-[11px] sticky top-0 z-10">
                <tr>
                  <th className="p-3 text-left w-12 text-center">#</th>
                  <th className="p-3 text-left min-w-[200px]">Product / Medicine</th>
                  <th className="p-3 text-center">Batch</th>
                  <th className="p-3 text-center">Expiry</th>
                  <th className="p-3 text-right">MRP</th>
                  <th className="p-3 text-right">Rate</th>
                  <th className="p-3 text-right">Qty</th>
                  <th className="p-3 text-right">Free</th>
                  <th className="p-3 text-right">Disc %</th>
                   <th className="p-3 text-right">GST %</th>
                   <th className="p-3 text-right">Margin %</th>
                   <th className="p-3 text-right">Net Amt</th>
                   <th className="p-3 text-center"></th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100">
                {cartItems.map((item, index) => (
                  <tr key={item.id} className="hover:bg-blue-50/50 group transition-colors">
                    <td className="p-3 text-center text-slate-400 font-mono">{index + 1}</td>
                    <td className="p-3">
                      <div className="font-bold text-slate-800">{item.productName}</div>
                      <div className="text-[10px] text-slate-500 uppercase font-medium">{item.genericName} • HSN: {item.hsn}</div>
                    </td>
                    <td className="p-3 text-center font-mono text-slate-600 bg-slate-50/50">{item.batchNumber}</td>
                    <td className="p-3 text-center">
                      <span className={`px-2 py-0.5 rounded-full text-[10px] font-bold ${new Date(item.expiryDate) < new Date() ? 'bg-red-100 text-red-600' : 'bg-slate-100 text-slate-600'}`}>
                        {item.expiryDate}
                      </span>
                    </td>
                    <td className="p-3 text-right text-slate-400">₹{item.mrp.toFixed(2)}</td>
                    <td className="p-3 text-right">
                      <input
                        type="number"
                        value={item.rate}
                        onChange={(e) => updateLineItem(index, { rate: parseFloat(e.target.value) || 0 })}
                        className="w-20 p-1 border border-slate-200 rounded text-right font-bold text-blue-700 bg-transparent focus:bg-white"
                      />
                    </td>
                    <td className="p-3 text-right">
                      <input
                        type="number"
                        value={item.quantity}
                        onChange={(e) => updateLineItem(index, { quantity: parseInt(e.target.value) || 0 })}
                        className="w-16 p-1 border-2 border-slate-200 rounded text-right font-bold focus:border-blue-500 outline-none"
                      />
                    </td>
                    <td className="p-3 text-right">
                      <input
                        type="number"
                        value={item.freeQuantity}
                        onChange={(e) => updateLineItem(index, { freeQuantity: parseInt(e.target.value) || 0 })}
                        className="w-12 p-1 border border-slate-200 rounded text-right text-slate-500"
                      />
                    </td>
                    <td className="p-3 text-right">
                      <input
                        type="number"
                        value={item.discountPercent}
                        onChange={(e) => updateLineItem(index, { discountPercent: parseFloat(e.target.value) || 0 })}
                        className="w-16 p-1 border border-slate-200 rounded text-right font-medium text-emerald-600"
                        disabled={!canGiveDiscount}
                      />
                    </td>
                     <td className="p-3 text-right text-slate-500 font-medium">{item.gstPercent}%</td>
                     <td className="p-3 text-right">
                       {(() => {
                         const margin = ((item.rate - item.purchaseRate) / item.rate) * 100;
                         return (
                           <span className={`text-[10px] font-bold px-1.5 py-0.5 rounded ${margin > 20 ? 'bg-emerald-100 text-emerald-700' : margin > 10 ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-700'}`}>
                             {margin.toFixed(1)}%
                           </span>
                         );
                       })()}
                     </td>
                     <td className="p-3 text-right font-bold text-slate-900">₹{item.totalAmount.toLocaleString(undefined, { minimumFractionDigits: 2 })}</td>
                    <td className="p-3 text-center">
                      <button onClick={() => removeLineItem(index)} className="p-1.5 text-slate-300 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100">
                        <Trash2 size={16} />
                      </button>
                    </td>
                  </tr>
                ))}
                {cartItems.length === 0 && (
                  <tr>
                    <td colSpan={12} className="p-20 text-center">
                       <div className="flex flex-col items-center gap-4 text-slate-300">
                          <Package size={64} className="opacity-20" />
                          <div className="text-lg font-medium opacity-50">Transaction Entry Area</div>
                          <p className="text-sm max-w-xs opacity-40">Scan barcodes or use manual search to start building this invoice.</p>
                       </div>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>

          {/* Table Footer Activity / Hot Keys */}
          <div className="bg-slate-900 text-[10px] text-slate-400 p-2 flex justify-between items-center font-mono">
            <div className="flex gap-4">
               <span>[F1] PARTY</span>
               <span>[F2] DATE</span>
               <span>[F8] TYPE</span>
               <span>[INS] SEARCH</span>
               <span>[F10] SETTLE</span>
               <span>[CTRL+S] SAVE</span>
            </div>
            <div className="text-blue-400 font-bold uppercase">
               {cartItems.length} ITEMS | TOTAL QTY: {cartItems.reduce((s,i) => s + i.quantity + (i.freeQuantity || 0), 0)}
            </div>
          </div>
        </div>
      </div>

      {/* ─── RIGHT COLUMN: BILLING SIDEBAR ─── */}
      <div className="w-full lg:w-96 flex flex-col gap-4">
        
        {/* Real-time Totals Card */}
        <div className="bg-slate-900 text-white rounded-2xl p-6 shadow-2xl flex flex-col gap-6">
          <div className="flex justify-between items-start border-b border-white/10 pb-4">
             <div className="uppercase text-[10px] tracking-widest font-bold text-slate-400">Net Payable Amount</div>
             <div className="text-4xl font-black text-blue-400">
               ₹{netPayable.toLocaleString(undefined, { minimumFractionDigits: 2 })}
             </div>
          </div>

          <div className="space-y-3 text-sm">
            <div className="flex justify-between text-slate-400">
              <span>Gross Total:</span>
              <span className="font-bold text-slate-200">₹{totalTaxable.toFixed(2)}</span>
            </div>
            <div className="flex justify-between text-slate-400">
              <span>Total GST:</span>
              <span className="font-bold text-slate-200">₹{(totalCgst + totalSgst + totalIgst).toFixed(2)}</span>
            </div>
            <div className="flex justify-between text-slate-400">
              <span>Round Off:</span>
              <span className="font-bold text-slate-200">₹{roundOff.toFixed(2)}</span>
            </div>
          </div>

          <div className="bg-white/5 rounded-xl p-3 border border-white/10 italic text-[11px] text-slate-400 text-center uppercase tracking-wide">
             {amountInWords} Only
          </div>
        </div>

        {/* Payment Configuration Card */}
        <div className="bg-white rounded-xl border border-slate-200 shadow-sm p-5 flex-1 flex flex-col">
          <h4 className="font-bold text-slate-800 flex items-center gap-2 mb-4">
            <CreditCard size={18} className="text-blue-600" /> Payment & Settlement
          </h4>
          
          <div className="flex flex-col gap-4 flex-1">
            <div className="grid grid-cols-2 gap-2">
              {['Cash', 'UPI', 'Card', 'Credit', 'Multi'].map(mode => (
                <button
                  key={mode}
                  onClick={() => setPaymentMode(mode as any)}
                  className={`py-2 rounded-lg text-xs font-bold transition-all ${paymentMode === mode ? 'bg-blue-600 text-white shadow-md scale-105' : 'bg-slate-100 text-slate-500 hover:bg-slate-200'}`}
                >
                  {mode}
                </button>
              ))}
            </div>

            {paymentMode === 'Multi' ? (
              <div className="bg-slate-50 rounded-xl p-3 border border-slate-200 space-y-3">
                {(['cash', 'upi', 'card', 'credit'] as const).map(field => (
                  <div key={field} className="flex items-center justify-between gap-4">
                    <label className="text-[10px] font-bold uppercase text-slate-500 w-12">{field}</label>
                    <input 
                      type="number"
                      value={paymentSplit[field]}
                      onChange={e => setPaymentSplit({...paymentSplit, [field]: parseFloat(e.target.value) || 0})}
                      className="flex-1 bg-white border border-slate-200 rounded p-1 text-right font-bold text-sm"
                    />
                  </div>
                ))}
                <div className={`text-center py-1 rounded text-[10px] font-black uppercase ${Math.abs((paymentSplit.cash + paymentSplit.upi + paymentSplit.card + paymentSplit.credit) - netPayable) < 0.1 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                   Difference: ₹{(netPayable - (paymentSplit.cash + paymentSplit.upi + paymentSplit.card + paymentSplit.credit)).toFixed(2)}
                </div>
              </div>
            ) : paymentMode === 'Credit' && (
              <div className="space-y-3 animate-slideIn">
                <div>
                  <label className="text-[10px] font-bold text-slate-400 uppercase">Credit Days</label>
                  <input type="number" value={creditDays} onChange={e => setCreditDays(parseInt(e.target.value))} className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 font-bold" />
                </div>
                <div>
                  <label className="text-[10px] font-bold text-slate-400 uppercase">Due Date</label>
                  <input type="date" value={dueDate} onChange={e => setDueDate(e.target.value)} className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 font-bold" />
                </div>
              </div>
            )}

            {/* Est. Profit Indicator */}
            <div className="flex justify-between items-center text-slate-400 text-[10px] font-bold tracking-tight px-1">
              <span>Estimated Session Profit:</span>
              <span className="text-emerald-500 font-extrabold flex items-center gap-1">
                <TrendingUp size={12} />
                ₹{cartItems.reduce((acc, item) => acc + (item.rate - item.purchaseRate) * item.quantity, 0).toFixed(2)}
              </span>
            </div>

            {/* Recent Invoices Sidebar */}
            <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
              <div className="p-3 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <h3 className="font-bold text-slate-800 text-[11px] flex items-center gap-2 uppercase tracking-tight">
                  <History size={14} className="text-slate-500" />
                  Recent Bills
                </h3>
                <button 
                  onClick={() => setShowTallySync(true)}
                  className="text-[9px] font-black text-blue-600 hover:underline uppercase tracking-tighter bg-blue-50 px-1.5 py-0.5 rounded border border-blue-100"
                >
                  Tally Sync
                </button>
              </div>
              <div className="p-1 space-y-0.5 max-h-32 overflow-y-auto">
                {recentInvoices.length > 0 ? (
                  recentInvoices.map(inv => (
                    <div key={inv.id} className="p-1.5 rounded hover:bg-slate-50 border border-transparent hover:border-slate-100 transition-all cursor-pointer flex justify-between items-center text-[10px]">
                      <div className="flex flex-col">
                        <span className="font-bold text-slate-700">{inv.invoiceNumber}</span>
                        <span className="text-slate-400 truncate w-32">{inv.customerName}</span>
                      </div>
                      <div className="text-right">
                        <div className="font-black text-slate-800">₹{inv.netAmount.toLocaleString()}</div>
                      </div>
                    </div>
                  ))
                ) : (
                  <div className="p-3 text-center text-[9px] text-slate-400 italic">No recent sales</div>
                )}
              </div>
            </div>

            {/* Calculator Widget */}
            <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
              <button 
                onClick={() => setShowCalculator(!showCalculator)}
                className="flex items-center justify-between p-3 w-full hover:bg-slate-50 transition-colors"
              >
                <div className="flex items-center gap-2 font-bold text-slate-800 text-[11px] uppercase tracking-tight">
                  <Calculator size={14} className="text-blue-600" />
                  Quick Calculator
                </div>
                <ChevronDown size={14} className={`text-slate-400 transition-transform ${showCalculator ? 'rotate-180' : ''}`} />
              </button>
              
              {showCalculator && (
                <div className="p-3 bg-slate-50 border-t border-slate-100">
                  <div className="bg-slate-900 text-white p-2 rounded-lg flex flex-col items-end mb-2 shadow-inner">
                    <div className="text-xs font-mono font-bold">{calcValue || '0'}</div>
                  </div>
                  <div className="grid grid-cols-4 gap-1">
                    {['7','8','9','/','4','5','6','*','1','2','3','-','0','.','=','+'].map(btn => (
                      <button 
                        key={btn}
                        onClick={() => {
                           if (btn === '=') {
                             try { setCalcValue(eval(calcValue).toString()); } catch { setCalcValue('Error'); }
                           } else {
                             setCalcValue(prev => prev + btn);
                           }
                        }}
                        className={`p-1.5 rounded-md font-bold text-[10px] transition-all ${btn === '=' ? 'bg-blue-600 text-white' : 'bg-white border border-slate-200 text-slate-700 hover:bg-slate-100'}`}
                      >
                        {btn}
                      </button>
                    ))}
                    <button onClick={() => setCalcValue('')} className="col-span-4 p-1 bg-slate-200 text-slate-600 rounded text-[9px] font-bold uppercase hover:bg-slate-300">Clear</button>
                  </div>
                </div>
              )}
            </div>
          </div>

            <div className="mt-auto pt-6 space-y-3">
              <button 
                onClick={handlePrintInvoice}
                disabled={cartItems.length === 0}
                className="w-full bg-slate-100 text-slate-700 py-3 rounded-xl flex items-center justify-center gap-2 font-bold hover:bg-slate-200 transition-colors disabled:opacity-50"
              >
                <Printer size={18} /> Print Draft (Alt+P)
              </button>
              <button 
                onClick={handleSaveInvoice}
                disabled={cartItems.length === 0 || !customerName}
                className="w-full bg-blue-600 text-white py-4 rounded-xl flex items-center justify-center gap-3 font-black text-lg shadow-xl shadow-blue-200 hover:bg-blue-700 hover:-translate-y-1 transition-all active:scale-95 disabled:opacity-50 disabled:translate-y-0 disabled:shadow-none"
              >
                <Save size={20} /> SAVE & ACCEPT [Ctrl+A]
              </button>
          </div>
        </div>
      </div>

      {/* Hidden Printable Invoice */}
      <div ref={invoiceRef} className="hidden">
        <div className="invoice-header">
          <h1>MARG ERP - SALES INVOICE</h1>
          <p>Invoice No: {invoiceNumber}</p>
          <p>Date: {invoiceDate}</p>
        </div>
        
        <div className="invoice-details">
          <p><strong>Customer:</strong> {customerName}</p>
          <p><strong>Billing Address:</strong> {billingAddress}</p>
          {gstin && <p><strong>GSTIN:</strong> {gstin}</p>}
        </div>
        
        <table className="items-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Batch</th>
              <th>HSN</th>
              <th>Qty</th>
              <th>Rate</th>
              <th>Amount</th>
              <th>GST%</th>
              <th>Tax Amt</th>
            </tr>
          </thead>
          <tbody>
            {cartItems.map((item) => (
              <tr key={item.id}>
                <td>{item.productName}</td>
                <td>{item.batchNumber}</td>
                <td>{item.hsn}</td>
                <td>{item.quantity}</td>
                <td>₹{item.rate.toFixed(2)}</td>
                <td>₹{item.totalAmount.toFixed(2)}</td>
                <td>{item.gstPercent}%</td>
                <td>₹{(item.cgstAmount + item.sgstAmount).toFixed(2)}</td>
              </tr>
            ))}
          </tbody>
        </table>
        
        <div className="totals">
          <p><strong>Net Payable:</strong> ₹{netPayable.toFixed(2)}</p>
          <p><strong>Amount in Words:</strong> {numberToWords(Math.round(netPayable))} Only</p>
        </div>
        
        <div className="signature">
          <p>Authorized Signatory</p>
        </div>
      </div>

      {/* Batch Selection Modal */}
      {showBatchModal && selectedProduct && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-xl shadow-2xl w-full max-w-2xl overflow-hidden animate-fadeIn">
            <div className="bg-slate-900 text-white p-4 flex justify-between items-center">
              <div>
                <h3 className="font-bold flex items-center gap-2">
                  <Package size={18} />
                  Select Batch
                </h3>
                <div className="flex items-center gap-2 mt-1">
                  <p className="text-xs text-slate-400">{selectedProduct.name} - {selectedProduct.genericName}</p>
                  {selectedProduct.scheme && (
                    <span className="text-[9px] bg-yellow-500/20 text-yellow-300 px-1.5 rounded font-bold border border-yellow-500/50 flex items-center gap-1">
                      <Gift size={8} /> {selectedProduct.scheme} Offer
                    </span>
                  )}
                </div>
              </div>
              <button onClick={() => setShowBatchModal(false)} className="hover:bg-slate-700 p-1 rounded">
                <X size={18} />
              </button>
            </div>
            
            <div className="p-4 bg-yellow-50 border-b border-yellow-100 flex items-start gap-3">
              <AlertCircle className="text-yellow-600 shrink-0 mt-0.5" size={18} />
              <p className="text-xs text-yellow-800">
                System automatically sorts batches by <strong>FEFO (First Expiry First Out)</strong>. 
                Please prioritize the top batch.
              </p>
            </div>

            <div className="max-h-[400px] overflow-y-auto">
              <table className="w-full text-left text-sm">
                <thead className="bg-slate-50 text-slate-600 font-semibold sticky top-0">
                  <tr>
                    <th className="p-3">Batch No</th>
                    <th className="p-3">Expiry</th>
                    <th className="p-3 text-right">MRP</th>
                    <th className="p-3 text-right">Stock</th>
                    <th className="p-3 text-center">Status</th>
                    <th className="p-3 text-center">Action</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-100">
                  {selectedProduct.batches?.sort((a,b) => new Date(a.expiryDate).getTime() - new Date(b.expiryDate).getTime()).map((batch, idx) => {
                    const daysToExpiry = Math.ceil((new Date(batch.expiryDate).getTime() - new Date().getTime()) / (1000 * 3600 * 24));
                    const isExpired = daysToExpiry < 0;
                    const isNearExpiry = daysToExpiry < 90 && !isExpired;
                    const hasStock = batch.stock > 0;

                    return (
                      <tr key={batch.id} className={`hover:bg-slate-50 ${idx === 0 && hasStock ? 'bg-green-50/50' : ''}`}>
                        <td className="p-3 font-mono font-medium text-slate-700">
                          {batch.batchNumber}
                          {idx === 0 && hasStock && <span className="ml-2 text-[10px] bg-green-100 text-green-700 px-1.5 py-0.5 rounded border border-green-200 font-bold">FEFO</span>}
                        </td>
                        <td className="p-3">
                          <span className={isExpired ? 'text-red-600 font-bold' : isNearExpiry ? 'text-orange-600 font-bold' : 'text-slate-600'}>
                            {batch.expiryDate}
                          </span>
                        </td>
                        <td className="p-3 text-right">₹{batch.mrp}</td>
                        <td className="p-3 text-right font-bold">{batch.stock}</td>
                        <td className="p-3 text-center">
                          {isExpired ? (
                            <span className="text-[10px] bg-red-100 text-red-600 px-2 py-0.5 rounded font-bold">EXPIRED</span>
                          ) : !hasStock ? (
                            <span className="text-[10px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded font-bold">NO STOCK</span>
                          ) : isNearExpiry ? (
                            <span className="text-[10px] bg-orange-100 text-orange-600 px-2 py-0.5 rounded font-bold">NEAR EXPIRY</span>
                          ) : (
                            <span className="text-[10px] bg-green-100 text-green-600 px-2 py-0.5 rounded font-bold">ACTIVE</span>
                          )}
                        </td>
                        <td className="p-3 text-center">
                          <button 
                            onClick={() => addBatchToCart(batch)}
                            disabled={!hasStock || isExpired}
                            className={`px-3 py-1 text-xs font-bold rounded transition-colors ${
                              !hasStock || isExpired 
                                ? 'bg-slate-100 text-slate-400 cursor-not-allowed' 
                                : 'bg-green-600 text-white hover:bg-green-700'
                            }`}
                          >
                            Add
                          </button>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}

      {/* Customer Selection Modal */}
      {showCustomerModal && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-xl shadow-2xl w-full max-w-2xl overflow-hidden animate-fadeIn">
            <div className="bg-slate-900 text-white p-4 flex justify-between items-center">
              <h3 className="font-bold flex items-center gap-2">
                <User size={18} />
                Select Customer
              </h3>
              <button onClick={() => setShowCustomerModal(false)} className="hover:bg-slate-700 p-1 rounded">
                <X size={18} />
              </button>
            </div>
            
            <div className="p-4 max-h-[400px] overflow-y-auto">
              <div className="space-y-2">
                {existingParties.map(party => (
                  <div 
                    key={party.id}
                    className="p-3 border border-slate-200 rounded-lg hover:bg-blue-50 cursor-pointer"
                    onClick={() => {
                      setCustomerName(party.name);
                      setContactNumber(party.mobile);
                      setGstin(party.gstin || '');
                      setShowCustomerModal(false);
                    }}
                  >
                    <div className="font-medium text-slate-800">{party.name}</div>
                    <div className="text-sm text-slate-600">{party.mobile}</div>
                    {party.gstin && <div className="text-xs text-slate-500">GSTIN: {party.gstin}</div>}
                  </div>
                ))}
                {existingParties.length === 0 && (
                  <div className="text-center py-8 text-slate-500">
                    <User size={32} className="mx-auto mb-2" />
                    <p>No customers found</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      )}
      {/* ─── SETTLEMENT MODAL (F10) ─── */}
      {showSettlementModal && (
        <div className="fixed inset-0 bg-slate-900/80 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
          <div className="bg-white rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden animate-in zoom-in-95 duration-200">
            <div className="bg-slate-900 p-6 text-white flex justify-between items-center">
              <div>
                <h2 className="text-2xl font-black flex items-center gap-2">
                  <CreditCard className="w-8 h-8 text-blue-400" />
                  SETTLEMENT / PAYMENT
                </h2>
                <p className="text-slate-400 text-sm font-bold mt-1">Invoice: {invoiceNumber} | Party: {customerName || 'CASH CUSTOMER'}</p>
              </div>
              <button onClick={() => setShowSettlementModal(false)} className="bg-white/10 p-2 rounded-full hover:bg-white/20 transition-colors">
                <X className="w-6 h-6" />
              </button>
            </div>

            <div className="p-8 grid grid-cols-2 gap-8">
              <div className="space-y-6">
                <div>
                  <label className="block text-xs font-black text-slate-500 uppercase mb-2">Grand Total</label>
                  <div className="text-4xl font-black text-slate-900">₹{netPayable.toFixed(2)}</div>
                </div>

                <div className="space-y-4">
                  <div>
                    <label className="block text-xs font-bold text-slate-600 mb-1 flex items-center gap-2">
                      <div className="w-2 h-2 rounded-full bg-green-500" /> CASH RECEIVED
                    </label>
                    <input 
                      type="number" 
                      className="w-full text-2xl font-bold p-3 border-2 border-slate-200 rounded-xl focus:border-green-500 focus:ring-4 focus:ring-green-100 outline-none transition-all"
                      value={paymentSplit.cash || ''}
                      onChange={(e) => setPaymentSplit(prev => ({ ...prev, cash: parseFloat(e.target.value) || 0 }))}
                      autoFocus
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-slate-600 mb-1 flex items-center gap-2">
                      <div className="w-2 h-2 rounded-full bg-blue-500" /> UPI / ONLINE
                    </label>
                    <input 
                      type="number" 
                      className="w-full text-2xl font-bold p-3 border-2 border-slate-200 rounded-xl focus:border-blue-500 focus:ring-4 focus:ring-blue-100 outline-none transition-all"
                      value={paymentSplit.upi || ''}
                      onChange={(e) => setPaymentSplit(prev => ({ ...prev, upi: parseFloat(e.target.value) || 0 }))}
                    />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-slate-600 mb-1 flex items-center gap-2">
                      <div className="w-2 h-2 rounded-full bg-purple-500" /> CARD PAYMENT
                    </label>
                    <input 
                      type="number" 
                      className="w-full text-2xl font-bold p-3 border-2 border-slate-200 rounded-xl focus:border-purple-500 focus:ring-4 focus:ring-purple-100 outline-none transition-all"
                      value={paymentSplit.card || ''}
                      onChange={(e) => setPaymentSplit(prev => ({ ...prev, card: parseFloat(e.target.value) || 0 }))}
                    />
                  </div>
                </div>
              </div>

              <div className="bg-slate-50 rounded-2xl p-6 border-2 border-slate-100 flex flex-col justify-between">
                <div className="space-y-6">
                  <div className="flex justify-between items-end border-b-2 border-slate-200 pb-4">
                    <span className="text-slate-500 font-bold uppercase text-xs">Total Collected</span>
                    <span className="text-2xl font-black text-slate-900">₹{(paymentSplit.cash + paymentSplit.upi + paymentSplit.card).toFixed(2)}</span>
                  </div>

                  <div className={`p-4 rounded-xl border-2 flex flex-col items-center justify-center transition-all ${
                    (paymentSplit.cash + paymentSplit.upi + paymentSplit.card) >= netPayable 
                    ? 'bg-green-100 border-green-200 text-green-700' 
                    : 'bg-red-100 border-red-200 text-red-700'
                  }`}>
                    <span className="text-xs font-black uppercase mb-1">
                      {(paymentSplit.cash + paymentSplit.upi + paymentSplit.card) >= netPayable ? 'Balance to Return' : 'Short / Remaining'}
                    </span>
                    <span className="text-3xl font-black tracking-tighter">
                      ₹{Math.abs((paymentSplit.cash + paymentSplit.upi + paymentSplit.card) - netPayable).toFixed(2)}
                    </span>
                  </div>
                </div>

                <div className="space-y-3">
                  <button 
                    onClick={handleSaveInvoice}
                    disabled={(paymentSplit.cash + paymentSplit.upi + paymentSplit.card) < netPayable && !customerName}
                    className="w-full py-4 bg-slate-900 text-white rounded-xl font-black text-lg shadow-xl hover:bg-slate-800 active:scale-95 transition-all flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
                  >
                    <Save className="w-6 h-6" />
                    FINALIZE & SAVE
                  </button>
                  <p className="text-[10px] text-center text-slate-400 font-bold uppercase tracking-widest">Shortcut: CTRL + ENTER to Save</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default POS;