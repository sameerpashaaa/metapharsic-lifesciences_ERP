
import React, { useState } from 'react';
import { Truck, Plus, RefreshCcw, Download, X, Calendar, FileText, CheckCircle, AlertCircle, Clock } from 'lucide-react';
import { MOCK_PURCHASES, MOCK_SUPPLIERS, MOCK_PURCHASE_RETURNS, MOCK_PRODUCTS, MOCK_PAYMENTS } from '../constants';
import { Purchase as PurchaseModel, PurchaseReturn, PurchaseReturnItem, Supplier, PurchaseItem, Payment } from '../types';
import { useAuth } from '../context/AuthContext';

const Purchase: React.FC = () => {
  const [viewMode, setViewMode] = useState<'PURCHASE' | 'RETURN'>('PURCHASE');
  const [searchTerm, setSearchTerm] = useState('');
  const [statusFilter, setStatusFilter] = useState<'All' | 'Received' | 'Pending' | 'Ordered'>('All');
  
  // Data States
  const [suppliers, setSuppliers] = useState<Supplier[]>(MOCK_SUPPLIERS);
  const [purchases, setPurchases] = useState<PurchaseModel[]>(MOCK_PURCHASES);
  const [returns, setReturns] = useState<PurchaseReturn[]>(MOCK_PURCHASE_RETURNS);

  // Modal States
  const [selectedPurchase, setSelectedPurchase] = useState<PurchaseModel | null>(null);
  const [showReturnModal, setShowReturnModal] = useState(false);
  const [showPurchaseModal, setShowPurchaseModal] = useState(false);
  
  // New Purchase Form State
  const [newPurchaseData, setNewPurchaseData] = useState({
    supplierId: '',
    invoiceNo: '',
    date: new Date().toISOString().split('T')[0]
  });
  const [purchaseItems, setPurchaseItems] = useState<PurchaseItem[]>([]);
  
  // New Purchase Item Input State
  const [newPurchaseItem, setNewPurchaseItem] = useState({
    productId: '',
    batchNo: '',
    expiryDate: '',
    quantity: 1,
    purchaseRate: 0,
    mrp: 0,
    gst: 0
  });

  // New Return Form State
  const [returnSupplierId, setReturnSupplierId] = useState('');
  const [returnReferenceInvoice, setReturnReferenceInvoice] = useState(''); 
  const [returnItems, setReturnItems] = useState<PurchaseReturnItem[]>([]);
  const [newReturnItemId, setNewReturnItemId] = useState('');
  const [newReturnItemBatch, setNewReturnItemBatch] = useState(''); // Added Batch Selection
  const [newReturnItemQty, setNewReturnItemQty] = useState(1);
  const [newReturnItemReason, setNewReturnItemReason] = useState(''); // Mandatory reason
  const [returnFormErrors, setReturnFormErrors] = useState<Record<string, string>>({}); // Validation errors

  const { hasPermission } = useAuth();
  const canEdit = hasPermission(['ADMIN', 'PHARMACIST', 'INVENTORY_MANAGER']);

  // Filters
  const filteredPurchases = purchases.filter(p => {
    const matchesSearch = 
      p.supplierName.toLowerCase().includes(searchTerm.toLowerCase()) || 
      p.invoiceNo.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesStatus = statusFilter === 'All' || p.status === statusFilter;
    return matchesSearch && matchesStatus;
  });

  const filteredReturns = returns.filter(r => 
    r.supplierName.toLowerCase().includes(searchTerm.toLowerCase()) ||
    r.returnNo.toLowerCase().includes(searchTerm.toLowerCase())
  );

  // Derived state for return logic
  const purchaseForReturn = purchases.find(p => p.invoiceNo === returnReferenceInvoice);

  // Auto-detect expiry reason
  useEffect(() => {
    if (newReturnItemId && newReturnItemBatch) {
      const product = MOCK_PRODUCTS.find(p => p.id === newReturnItemId);
      const batch = product?.batches?.find(b => b.batchNumber === newReturnItemBatch);
      
      // If we find the batch via invoice items (when purchaseForReturn is active)
      let expiryDateStr = batch?.expiryDate;
      if (!expiryDateStr && purchaseForReturn) {
         const invoiceItem = purchaseForReturn.items.find(i => i.productId === newReturnItemId && i.batchNo === newReturnItemBatch);
         if (invoiceItem) expiryDateStr = invoiceItem.expiryDate;
      }

      if (expiryDateStr) {
        const expiry = new Date(expiryDateStr);
        const today = new Date();
        if (expiry < today) {
          setNewReturnItemReason('Expired');
        } else if (newReturnItemReason === 'Expired') {
           setNewReturnItemReason(''); // Reset if switched to non-expired batch and reason was expired
        }
      }
    }
  }, [newReturnItemId, newReturnItemBatch, purchaseForReturn]);

  // Helper functions
  const getStatusColor = (status: string) => {
    switch(status) {
      case 'Received': case 'Completed': return 'bg-green-100 text-green-700 border-green-200';
      case 'Pending': return 'bg-orange-100 text-orange-700 border-orange-200';
      case 'Ordered': return 'bg-blue-100 text-blue-700 border-blue-200';
      default: return 'bg-slate-100 text-slate-700 border-slate-200';
    }
  };

  const getPaymentStatusColor = (status: string) => {
     switch(status) {
      case 'Paid': return 'text-green-600 font-bold';
      case 'Partial': return 'text-orange-600 font-bold';
      case 'Unpaid': return 'text-red-600 font-bold';
      default: return 'text-slate-600';
    }
  };

  const totalOutstanding = suppliers.reduce((acc, s) => acc + s.outstanding, 0);

  // --- Purchase Entry Handlers ---

  const handleProductSelect = (productId: string) => {
    const product = MOCK_PRODUCTS.find(p => p.id === productId);
    if (product) {
      // Pre-fill data from the most recent batch
      const lastBatch = product.batches?.[0];
      const defaultPurchaseRate = lastBatch?.purchaseRate || 0;
      
      setNewPurchaseItem({
        ...newPurchaseItem,
        productId,
        batchNo: lastBatch?.batchNumber || '', 
        expiryDate: lastBatch?.expiryDate || '',
        purchaseRate: defaultPurchaseRate,
        mrp: lastBatch?.mrp || product.mrp,
        gst: product.gst,
      });
    } else {
       setNewPurchaseItem({ 
           productId: '', batchNo: '', expiryDate: '', quantity: 1, purchaseRate: 0, mrp: 0, gst: 0 
       });
    }
  };

  const handleAddPurchaseItem = () => {
    if (!newPurchaseItem.productId) return;

    if (!newPurchaseItem.batchNo.trim()) {
        alert("Batch Number is mandatory.");
        return;
    }
    if (!newPurchaseItem.expiryDate.trim()) {
        alert("Expiry Date is mandatory.");
        return;
    }
    if (newPurchaseItem.quantity <= 0) {
        alert("Quantity must be greater than 0.");
        return;
    }
    
    const product = MOCK_PRODUCTS.find(p => p.id === newPurchaseItem.productId);
    if (!product) return;

    const taxableAmount = newPurchaseItem.purchaseRate * newPurchaseItem.quantity;
    const gstAmount = taxableAmount * (newPurchaseItem.gst / 100);
    const totalAmount = taxableAmount + gstAmount;

    const newItem: PurchaseItem = {
      productId: product.id,
      productName: product.name,
      batchNo: newPurchaseItem.batchNo,
      expiryDate: newPurchaseItem.expiryDate,
      quantity: newPurchaseItem.quantity,
      purchaseRate: newPurchaseItem.purchaseRate,
      mrp: newPurchaseItem.mrp,
      gst: newPurchaseItem.gst,
      gstAmount: gstAmount,
      amount: totalAmount
    };

    setPurchaseItems([...purchaseItems, newItem]);
    
    setNewPurchaseItem({
      productId: '',
      batchNo: '',
      expiryDate: '',
      quantity: 1,
      purchaseRate: 0,
      mrp: 0,
      gst: 0
    });
  };

  const removePurchaseItem = (index: number) => {
    setPurchaseItems(purchaseItems.filter((_, i) => i !== index));
  };

  const handleSubmitPurchase = () => {
    if (!newPurchaseData.supplierId || purchaseItems.length === 0) return;

    const supplier = suppliers.find(s => s.id === newPurchaseData.supplierId);
    if (!supplier) return;

    const totalAmount = purchaseItems.reduce((acc, item) => acc + item.amount, 0);

    const newPurchase: PurchaseModel = {
      id: `PUR-${Date.now()}`,
      invoiceNo: newPurchaseData.invoiceNo || `INV-${Date.now()}`,
      supplierId: supplier.id,
      supplierName: supplier.name,
      date: newPurchaseData.date,
      items: purchaseItems,
      totalAmount: totalAmount,
      status: 'Received',
      paymentStatus: 'Unpaid'
    };

    setPurchases([newPurchase, ...purchases]);
    MOCK_PURCHASES.unshift(newPurchase); 

    const newOutstanding = supplier.outstanding + totalAmount;
    
    setSuppliers(suppliers.map(s => 
      s.id === supplier.id ? { ...s, outstanding: newOutstanding } : s
    ));
    
    const mockSupplier = MOCK_SUPPLIERS.find(s => s.id === supplier.id);
    if(mockSupplier) mockSupplier.outstanding = newOutstanding;

    // Optional: Add Stock Logic for Purchase (mock app specific)
    purchaseItems.forEach(item => {
        const prod = MOCK_PRODUCTS.find(p => p.id === item.productId);
        if(prod) {
            let batch = prod.batches?.find(b => b.batchNumber === item.batchNo);
            if(batch) {
                batch.stock += item.quantity;
            } else {
                if(!prod.batches) prod.batches = [];
                prod.batches.push({
                    id: `b-${Date.now()}-${Math.random()}`,
                    batchNumber: item.batchNo,
                    expiryDate: item.expiryDate,
                    stock: item.quantity,
                    mrp: item.mrp,
                    purchaseRate: item.purchaseRate,
                    sellingRate: item.mrp,
                    location: prod.rack || 'General'
                });
            }
            prod.totalStock = prod.batches?.reduce((acc, b) => acc + b.stock, 0) || 0;
            prod.stock = prod.totalStock;
        }
    });

    setShowPurchaseModal(false);
    setNewPurchaseData({ supplierId: '', invoiceNo: '', date: new Date().toISOString().split('T')[0] });
    setPurchaseItems([]);
  };

  // --- Return Handlers ---

  const handleAddReturnItem = () => {
    // Validation
    const errors: Record<string, string> = {};
    if (!newReturnItemId) errors.product = "Product is required";
    if (!newReturnItemBatch) errors.batch = "Batch is required";
    if (newReturnItemQty <= 0) errors.qty = "Valid quantity required";
    if (!newReturnItemReason) errors.reason = "Reason is mandatory";

    if (Object.keys(errors).length > 0) {
        setReturnFormErrors(errors);
        return;
    }
    setReturnFormErrors({}); // Clear errors

    const product = MOCK_PRODUCTS.find(p => p.id === newReturnItemId);
    if (!product) return;

    let batchNoToUse = newReturnItemBatch;
    let returnRate = 0;

    if (purchaseForReturn) {
        // If invoice is selected, ensure the item exists in it
        const invoiceItem = purchaseForReturn.items.find(i => i.productId === newReturnItemId);
        if (invoiceItem) {
            batchNoToUse = invoiceItem.batchNo;
            returnRate = invoiceItem.purchaseRate;
        } else {
            // Fallback if somehow mismatched
            batchNoToUse = newReturnItemBatch || 'N/A';
            returnRate = 0;
        }
    } else {
        // Fallback to manual selection or master
        batchNoToUse = newReturnItemBatch || product.batches?.[0]?.batchNumber || 'N/A';
        const batch = product.batches?.find(b => b.batchNumber === batchNoToUse);
        returnRate = batch?.purchaseRate || product.rate || 0;
    }

    const newItem: PurchaseReturnItem = {
      productId: product.id,
      productName: product.name,
      batchNo: batchNoToUse,
      quantity: newReturnItemQty,
      returnRate: returnRate,
      amount: returnRate * newReturnItemQty,
      reason: newReturnItemReason
    };

    setReturnItems([...returnItems, newItem]);
    setNewReturnItemId('');
    setNewReturnItemBatch('');
    setNewReturnItemQty(1);
    setNewReturnItemReason(''); // Reset reason
  };

  const handleRemoveReturnItem = (idx: number) => {
    setReturnItems(returnItems.filter((_, i) => i !== idx));
  };

  const handleSubmitReturn = () => {
    if (!returnSupplierId || returnItems.length === 0) return;
    
    const supplier = suppliers.find(s => s.id === returnSupplierId);
    if (!supplier) return;

    const totalAmount = returnItems.reduce((acc, item) => acc + item.amount, 0);

    const newReturn: PurchaseReturn = {
        id: `PR-${Date.now()}`,
        returnNo: `RET-${Date.now().toString().slice(-6)}`,
        date: new Date().toISOString().split('T')[0],
        supplierId: supplier.id,
        supplierName: supplier.name,
        referenceInvoiceNo: returnReferenceInvoice || 'Direct Return',
        items: returnItems,
        totalAmount: totalAmount,
        status: 'Completed'
    };

    // 1. Create Return Record
    setReturns([newReturn, ...returns]);
    MOCK_PURCHASE_RETURNS.unshift(newReturn); 

    // 2. Update Supplier Outstanding (Reduce it)
    const newOutstanding = Math.max(0, supplier.outstanding - totalAmount);

    setSuppliers(suppliers.map(s => 
        s.id === supplier.id 
        ? { ...s, outstanding: newOutstanding }
        : s
    ));

    const mockSupplier = MOCK_SUPPLIERS.find(s => s.id === supplier.id);
    if(mockSupplier) mockSupplier.outstanding = newOutstanding;

    // 3. Update Stock (Reduce it)
    returnItems.forEach(item => {
        const product = MOCK_PRODUCTS.find(p => p.id === item.productId);
        if (product && product.batches) {
            const batch = product.batches.find(b => b.batchNumber === item.batchNo);
            if (batch) {
                batch.stock = Math.max(0, batch.stock - item.quantity);
            }
            // Update total stock
            product.totalStock = product.batches.reduce((acc, b) => acc + b.stock, 0);
            product.stock = product.totalStock; // Sync legacy field
        }
    });

    // 4. Generate Credit Note
    const creditNote: Payment = {
        id: `CN-${Date.now()}`,
        supplierId: supplier.id,
        supplierName: supplier.name,
        amount: totalAmount,
        date: new Date().toISOString().split('T')[0],
        mode: 'Credit Note',
        referenceNo: newReturn.returnNo,
        notes: `Generated from Purchase Return ${newReturn.returnNo}`
    };
    
    MOCK_PAYMENTS.push(creditNote); 
    
    alert(`Purchase Return Processed!\n\nStock adjusted and Credit Note of ₹${totalAmount.toLocaleString()} generated.`);

    setShowReturnModal(false);
    setReturnItems([]);
    setReturnSupplierId('');
    setReturnReferenceInvoice('');
  };

  return (
    <div className="space-y-6">
      {/* Header Stats */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div className="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
           <div>
              <p className="text-slate-500 text-sm font-medium">Total Purchases (Oct)</p>
              <h3 className="text-2xl font-bold text-slate-800">₹{purchases.reduce((a,b) => a + b.totalAmount, 0).toLocaleString()}</h3>
           </div>
           <div className="p-3 bg-blue-50 text-blue-600 rounded-lg">
             <Truck size={24} />
           </div>
        </div>
        <div className="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
           <div>
              <p className="text-slate-500 text-sm font-medium">Total Returns Value</p>
              <h3 className="text-2xl font-bold text-slate-800">₹{returns.reduce((a,b) => a + b.totalAmount, 0).toLocaleString()}</h3>
           </div>
           <div className="p-3 bg-orange-50 text-orange-600 rounded-lg">
             <RefreshCcw size={24} />
           </div>
        </div>
        <div className="bg-white p-6 rounded-xl border border-slate-100 shadow-sm flex items-center justify-between">
           <div>
              <p className="text-slate-500 text-sm font-medium">Supplier Outstanding</p>
              <h3 className="text-2xl font-bold text-red-600">₹{totalOutstanding.toLocaleString()}</h3>
           </div>
           <div className="p-3 bg-red-50 text-red-600 rounded-lg">
             <AlertCircle size={24} />
           </div>
        </div>
      </div>

      <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div className="flex gap-4 items-center">
            <h2 className="text-2xl font-bold text-slate-800">Purchase Management</h2>
            <div className="bg-white border border-slate-200 rounded-lg p-1 flex">
                <button 
                    onClick={() => setViewMode('PURCHASE')}
                    className={`px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${viewMode === 'PURCHASE' ? 'bg-slate-800 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-50'}`}
                >
                    Invoices
                </button>
                <button 
                    onClick={() => setViewMode('RETURN')}
                    className={`px-3 py-1.5 text-sm font-medium rounded-md transition-colors ${viewMode === 'RETURN' ? 'bg-slate-800 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-50'}`}
                >
                    Returns
                </button>
            </div>
        </div>
        
        {canEdit && (
          <button 
            onClick={() => viewMode === 'RETURN' ? setShowReturnModal(true) : setShowPurchaseModal(true)}
            className="bg-primary text-white px-4 py-2 rounded-lg font-medium flex items-center gap-2 hover:bg-sky-600 transition-colors shadow-sm"
          >
            {viewMode === 'RETURN' ? <RefreshCcw size={18} /> : <Plus size={18} />} 
            {viewMode === 'RETURN' ? 'New Return Entry' : 'New Purchase Entry'}
          </button>
        )}
      </div>

      <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        {/* Toolbar */}
        <div className="p-4 border-b border-slate-100 flex flex-col sm:flex-row gap-4 justify-between">
          <div className="relative flex-1 max-w-md">
            <Search className="absolute left-3 top-2.5 text-slate-400" size={18} />
            <input
              type="text"
              placeholder={viewMode === 'PURCHASE' ? "Search Supplier, Invoice No..." : "Search Return No, Supplier..."}
              className="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-1 focus:ring-primary outline-none"
              value={searchTerm}
              onChange={(e) => setSearchTerm(e.target.value)}
            />
          </div>
          {viewMode === 'PURCHASE' && (
             <div className="flex gap-2">
                {(['All', 'Received', 'Ordered'] as const).map(status => (
                    <button 
                        key={status}
                        onClick={() => setStatusFilter(status)}
                        className={`px-4 py-2 text-sm font-medium rounded-lg border transition-colors ${
                            statusFilter === status 
                            ? 'bg-slate-800 text-white border-slate-800' 
                            : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'
                        }`}
                    >
                        {status}
                    </button>
                ))}
            </div>
          )}
        </div>

        {/* Purchase Table */}
        {viewMode === 'PURCHASE' && (
          <div className="overflow-x-auto">
            <table className="w-full text-left border-collapse">
              <thead className="bg-slate-50 text-slate-500 text-xs font-semibold uppercase tracking-wider">
                <tr>
                  <th className="p-4 border-b">Date</th>
                  <th className="p-4 border-b">Invoice No</th>
                  <th className="p-4 border-b">Supplier</th>
                  <th className="p-4 border-b">Items</th>
                  <th className="p-4 border-b text-right">Amount</th>
                  <th className="p-4 border-b text-center">Payment</th>
                  <th className="p-4 border-b text-center">Status</th>
                  <th className="p-4 border-b text-center">Actions</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100">
                {filteredPurchases.map(purchase => (
                  <tr key={purchase.id} className="hover:bg-slate-50 transition-colors">
                    <td className="p-4 text-sm text-slate-700">
                       <div className="flex items-center gap-2">
                          <Calendar size={14} className="text-slate-400"/>
                          {purchase.date}
                       </div>
                    </td>
                    <td className="p-4 text-sm font-medium text-slate-800">{purchase.invoiceNo}</td>
                    <td className="p-4 text-sm text-slate-700">{purchase.supplierName}</td>
                    <td className="p-4 text-sm text-slate-500">{purchase.items.length} Items</td>
                    <td className="p-4 text-right font-bold text-slate-700">₹{purchase.totalAmount.toLocaleString()}</td>
                    <td className={`p-4 text-center text-xs ${getPaymentStatusColor(purchase.paymentStatus)}`}>
                        {purchase.paymentStatus}
                    </td>
                    <td className="p-4 text-center">
                      <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${getStatusColor(purchase.status)}`}>
                        {purchase.status}
                      </span>
                    </td>
                    <td className="p-4 text-center">
                      <button 
                          onClick={() => setSelectedPurchase(purchase)}
                          className="text-primary hover:text-sky-700 text-sm font-medium"
                      >
                          View
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
            {filteredPurchases.length === 0 && (
                <div className="p-10 text-center text-slate-400">
                    <FileText size={48} className="mx-auto mb-2 opacity-30"/>
                    <p>No purchase records found.</p>
                </div>
            )}
          </div>
        )}

        {/* Returns Table */}
        {viewMode === 'RETURN' && (
          <div className="overflow-x-auto">
            <table className="w-full text-left border-collapse">
              <thead className="bg-slate-50 text-slate-500 text-xs font-semibold uppercase tracking-wider">
                <tr>
                  <th className="p-4 border-b">Date</th>
                  <th className="p-4 border-b">Return No</th>
                  <th className="p-4 border-b">Supplier</th>
                  <th className="p-4 border-b">Ref. Invoice</th>
                  <th className="p-4 border-b text-right">Amount</th>
                  <th className="p-4 border-b text-center">Status</th>
                  <th className="p-4 border-b text-center">Actions</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100">
                {filteredReturns.map(ret => (
                  <tr key={ret.id} className="hover:bg-slate-50 transition-colors">
                    <td className="p-4 text-sm text-slate-700">{ret.date}</td>
                    <td className="p-4 text-sm font-medium text-slate-800">{ret.returnNo}</td>
                    <td className="p-4 text-sm text-slate-700">{ret.supplierName}</td>
                    <td className="p-4 text-sm text-slate-500">{ret.referenceInvoiceNo}</td>
                    <td className="p-4 text-right font-bold text-slate-700">₹{ret.totalAmount.toLocaleString()}</td>
                    <td className="p-4 text-center">
                      <span className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${getStatusColor(ret.status)}`}>
                        {ret.status}
                      </span>
                    </td>
                    <td className="p-4 text-center">
                      <button className="text-primary hover:text-sky-700 text-sm font-medium">Print Note</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
             {filteredReturns.length === 0 && (
                <div className="p-10 text-center text-slate-400">
                    <RefreshCcw size={48} className="mx-auto mb-2 opacity-30"/>
                    <p>No return records found.</p>
                </div>
            )}
          </div>
        )}
      </div>

      {/* New Purchase Entry Modal */}
      {showPurchaseModal && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
             <div className="bg-white rounded-xl shadow-2xl w-full max-w-5xl overflow-hidden animate-fadeIn flex flex-col max-h-[90vh]">
                <div className="bg-slate-900 text-white p-4 flex justify-between items-center shrink-0">
                    <h3 className="font-bold flex items-center gap-2"><Truck size={18} /> New Purchase Entry</h3>
                    <button onClick={() => setShowPurchaseModal(false)} className="hover:bg-slate-700 p-1 rounded transition-colors"><X size={18} /></button>
                </div>
                <div className="p-6 overflow-y-auto">
                    <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                        <div>
                             <label className="block text-sm font-medium text-slate-700 mb-1">Supplier <span className="text-red-500">*</span></label>
                             <select 
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary outline-none"
                                value={newPurchaseData.supplierId}
                                onChange={(e) => setNewPurchaseData({...newPurchaseData, supplierId: e.target.value})}
                             >
                                 <option value="">Select Supplier</option>
                                 {suppliers.map(s => (
                                     <option key={s.id} value={s.id}>{s.name}</option>
                                 ))}
                             </select>
                        </div>
                        <div>
                             <label className="block text-sm font-medium text-slate-700 mb-1">Invoice No</label>
                             <input 
                                type="text"
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary outline-none"
                                value={newPurchaseData.invoiceNo}
                                onChange={(e) => setNewPurchaseData({...newPurchaseData, invoiceNo: e.target.value})}
                                placeholder="Enter Invoice No"
                             />
                        </div>
                        <div>
                             <label className="block text-sm font-medium text-slate-700 mb-1">Date</label>
                             <input 
                                type="date" 
                                value={newPurchaseData.date}
                                onChange={(e) => setNewPurchaseData({...newPurchaseData, date: e.target.value})}
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-500" 
                             />
                        </div>
                    </div>

                    <div className="border border-slate-200 rounded-lg p-4 mb-6 bg-slate-50">
                        <h4 className="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2"><Plus size={16}/> Add Items</h4>
                        <div className="grid grid-cols-2 md:grid-cols-10 gap-3 items-end">
                            <div className="col-span-2">
                                <label className="block text-xs font-medium text-slate-500 mb-1">Product</label>
                                <select 
                                    className="w-full border border-slate-300 rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none"
                                    value={newPurchaseItem.productId}
                                    onChange={(e) => handleProductSelect(e.target.value)}
                                >
                                    <option value="">Select Product</option>
                                    {MOCK_PRODUCTS.map(p => (
                                        <option key={p.id} value={p.id}>{p.name}</option>
                                    ))}
                                </select>
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-700 mb-1">Batch <span className="text-red-500">*</span></label>
                                <input 
                                    type="text" 
                                    className="w-full border border-slate-300 rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none"
                                    value={newPurchaseItem.batchNo}
                                    onChange={(e) => setNewPurchaseItem({...newPurchaseItem, batchNo: e.target.value})}
                                    placeholder="Batch"
                                />
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-700 mb-1">Expiry <span className="text-red-500">*</span></label>
                                <input 
                                    type="text" 
                                    className="w-full border border-slate-300 rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none"
                                    value={newPurchaseItem.expiryDate}
                                    onChange={(e) => setNewPurchaseItem({...newPurchaseItem, expiryDate: e.target.value})}
                                    placeholder="YYYY-MM-DD"
                                />
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-500 mb-1">Qty</label>
                                <input 
                                    type="number" 
                                    min="1"
                                    className="w-full border border-slate-300 rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none"
                                    value={newPurchaseItem.quantity}
                                    onChange={(e) => setNewPurchaseItem({...newPurchaseItem, quantity: parseInt(e.target.value) || 0})}
                                />
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-500 mb-1">Rate</label>
                                <input 
                                    type="number" 
                                    className="w-full border border-slate-300 rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none font-bold"
                                    value={newPurchaseItem.purchaseRate}
                                    onChange={(e) => setNewPurchaseItem({...newPurchaseItem, purchaseRate: parseFloat(e.target.value) || 0})}
                                    title="Edit specific purchase rate"
                                />
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-500 mb-1">GST%</label>
                                <input 
                                    type="number" 
                                    className="w-full bg-slate-100 border border-slate-200 rounded-lg px-2 py-2 text-sm text-slate-600 outline-none"
                                    value={newPurchaseItem.gst}
                                    readOnly
                                />
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-500 mb-1">GST Amt</label>
                                <div className="w-full bg-slate-100 border border-slate-200 rounded-lg px-2 py-2 text-sm text-slate-600 truncate">
                                    ₹{((newPurchaseItem.purchaseRate * newPurchaseItem.quantity) * (newPurchaseItem.gst / 100)).toFixed(2)}
                                </div>
                            </div>
                            <div className="col-span-1">
                                <label className="block text-xs font-medium text-slate-500 mb-1">Total</label>
                                <div className="w-full bg-slate-100 border border-slate-200 rounded-lg px-2 py-2 text-sm font-bold text-primary truncate">
                                    ₹{((newPurchaseItem.purchaseRate * newPurchaseItem.quantity) * (1 + (newPurchaseItem.gst / 100))).toFixed(2)}
                                </div>
                            </div>
                            <div className="col-span-1">
                                <button 
                                    onClick={handleAddPurchaseItem}
                                    disabled={!newPurchaseItem.productId}
                                    className="w-full bg-slate-800 text-white py-2 rounded-lg text-sm font-medium hover:bg-slate-700 disabled:opacity-50"
                                >
                                    Add
                                </button>
                            </div>
                        </div>
                        <p className="text-xs text-slate-400 mt-2 italic">* Rate entered here is the taxable rate (cost per unit). GST amount will be added to the Total.</p>
                    </div>

                    {purchaseItems.length > 0 && (
                        <div className="border border-slate-200 rounded-lg overflow-hidden">
                            <table className="w-full text-left text-sm">
                                <thead className="bg-slate-100 text-slate-600">
                                    <tr>
                                        <th className="p-3">Product</th>
                                        <th className="p-3">Batch</th>
                                        <th className="p-3 text-center">Qty</th>
                                        <th className="p-3 text-right">Rate</th>
                                        <th className="p-3 text-center">GST</th>
                                        <th className="p-3 text-right">GST Amt</th>
                                        <th className="p-3 text-right">Total</th>
                                        <th className="p-3 text-center"></th>
                                    </tr>
                                </thead>
                                <tbody className="divide-y divide-slate-100">
                                    {purchaseItems.map((item, idx) => (
                                        <tr key={idx}>
                                            <td className="p-3 font-medium">{item.productName}</td>
                                            <td className="p-3 text-slate-500 text-xs">{item.batchNo}</td>
                                            <td className="p-3 text-center">{item.quantity}</td>
                                            <td className="p-3 text-right">₹{item.purchaseRate}</td>
                                            <td className="p-3 text-center text-xs">{item.gst}%</td>
                                            <td className="p-3 text-right text-xs text-slate-500">₹{item.gstAmount?.toFixed(2)}</td>
                                            <td className="p-3 text-right font-bold">₹{item.amount.toLocaleString()}</td>
                                            <td className="p-3 text-center">
                                                <button onClick={() => removePurchaseItem(idx)} className="text-red-500 hover:bg-red-50 p-1 rounded"><Trash2 size={14}/></button>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                                <tfoot className="bg-slate-50 font-bold text-slate-800">
                                    <tr>
                                        <td colSpan={5} className="p-3 text-right text-slate-600">Total</td>
                                        <td className="p-3 text-right text-slate-600">₹{purchaseItems.reduce((acc, i) => acc + (i.gstAmount || 0), 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                                        <td className="p-3 text-right text-primary">₹{purchaseItems.reduce((acc, i) => acc + i.amount, 0).toLocaleString()}</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    )}
                </div>
                <div className="p-4 bg-slate-50 border-t border-slate-100 flex justify-end gap-3 shrink-0">
                    <button onClick={() => setShowPurchaseModal(false)} className="px-4 py-2 text-slate-600 hover:bg-slate-200 rounded-lg">Cancel</button>
                    <button 
                        onClick={handleSubmitPurchase}
                        disabled={!newPurchaseData.supplierId || purchaseItems.length === 0}
                        className="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:bg-sky-600 shadow-lg shadow-primary/30 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        <Save size={18} /> Save Purchase
                    </button>
                </div>
             </div>
        </div>
      )}

      {/* New Return Modal */}
      {showReturnModal && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
             <div className="bg-white rounded-xl shadow-2xl w-full max-w-4xl overflow-hidden animate-fadeIn flex flex-col max-h-[90vh]">
                <div className="bg-slate-900 text-white p-4 flex justify-between items-center shrink-0">
                    <h3 className="font-bold flex items-center gap-2"><RefreshCcw size={18} /> New Purchase Return</h3>
                    <button onClick={() => setShowReturnModal(false)} className="hover:bg-slate-700 p-1 rounded transition-colors"><X size={18} /></button>
                </div>
                <div className="p-6 overflow-y-auto">
                     <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                        <div>
                             <label className="block text-sm font-medium text-slate-700 mb-1">Supplier</label>
                             <select 
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary outline-none"
                                value={returnSupplierId}
                                onChange={(e) => {
                                    setReturnSupplierId(e.target.value);
                                    setReturnReferenceInvoice(''); // Reset invoice when supplier changes
                                }}
                             >
                                 <option value="">Select Supplier</option>
                                 {suppliers.map(s => (
                                     <option key={s.id} value={s.id}>{s.name}</option>
                                 ))}
                             </select>
                        </div>
                        <div>
                             <label className="block text-sm font-medium text-slate-700 mb-1">Reference Invoice (Optional)</label>
                             <select
                                className="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary outline-none"
                                value={returnReferenceInvoice}
                                onChange={(e) => setReturnReferenceInvoice(e.target.value)}
                                disabled={!returnSupplierId}
                             >
                                 <option value="">Select Invoice</option>
                                 {purchases
                                    .filter(p => p.supplierId === returnSupplierId)
                                    .map(p => (
                                        <option key={p.id} value={p.invoiceNo}>{p.invoiceNo} ({p.date})</option>
                                 ))}
                             </select>
                        </div>
                     </div>

                     <div className="border border-slate-200 rounded-lg p-4 mb-6 bg-slate-50">
                        <h4 className="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2"><Plus size={16}/> Return Items</h4>
                        
                        {/* Notification if Invoice Selected */}
                        {purchaseForReturn && (
                            <div className="mb-3 p-2 bg-blue-50 border border-blue-100 rounded text-xs text-blue-700">
                                Returning items against Invoice <strong>{purchaseForReturn.invoiceNo}</strong>. 
                                Only items from this invoice are available.
                            </div>
                        )}

                        <div className="grid grid-cols-1 md:grid-cols-5 gap-3 items-end">
                             <div className="md:col-span-2">
                                <label className="block text-xs font-medium text-slate-500 mb-1">Product <span className="text-red-500">*</span></label>
                                <select 
                                    className={`w-full border rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none ${returnFormErrors.product ? 'border-red-500 bg-red-50' : 'border-slate-300'}`}
                                    value={newReturnItemId}
                                    onChange={(e) => { 
                                        setNewReturnItemId(e.target.value); 
                                        // Auto-select batch if invoice is present
                                        if (purchaseForReturn) {
                                            const item = purchaseForReturn.items.find(i => i.productId === e.target.value);
                                            if(item) setNewReturnItemBatch(item.batchNo);
                                        } else {
                                            setNewReturnItemBatch('');
                                        }
                                    }}
                                >
                                    <option value="">Select Product</option>
                                    {purchaseForReturn 
                                        ? purchaseForReturn.items.map(item => (
                                            <option key={item.productId} value={item.productId}>{item.productName}</option>
                                          ))
                                        : MOCK_PRODUCTS.map(p => (
                                            <option key={p.id} value={p.id}>{p.name}</option>
                                          ))
                                    }
                                </select>
                                {returnFormErrors.product && <p className="text-xs text-red-500 mt-1">{returnFormErrors.product}</p>}
                            </div>
                            <div>
                                <label className="block text-xs font-medium text-slate-500 mb-1">Batch <span className="text-red-500">*</span></label>
                                {purchaseForReturn ? (
                                    <input 
                                        type="text" 
                                        value={newReturnItemBatch}
                                        readOnly
                                        className="w-full border border-slate-300 bg-slate-100 text-slate-500 rounded-lg px-2 py-2 text-sm focus:outline-none"
                                    />
                                ) : (
                                    <select 
                                        value={newReturnItemBatch}
                                        onChange={(e) => setNewReturnItemBatch(e.target.value)}
                                        className={`w-full border rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none ${returnFormErrors.batch ? 'border-red-500 bg-red-50' : 'border-slate-300'}`}
                                        disabled={!newReturnItemId}
                                    >
                                        <option value="">Select Batch</option>
                                        {MOCK_PRODUCTS.find(p => p.id === newReturnItemId)?.batches?.map(b => (
                                            <option key={b.id} value={b.batchNumber}>{b.batchNumber} (Stock: {b.stock})</option>
                                        ))}
                                    </select>
                                )}
                                {returnFormErrors.batch && <p className="text-xs text-red-500 mt-1">{returnFormErrors.batch}</p>}
                            </div>
                            <div>
                                <label className="block text-xs font-medium text-slate-500 mb-1">Qty</label>
                                <input 
                                    type="number" 
                                    min="1"
                                    className="w-full border border-slate-300 rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none"
                                    value={newReturnItemQty}
                                    onChange={(e) => setNewReturnItemQty(parseInt(e.target.value) || 0)}
                                />
                            </div>
                            <div>
                                <label className="block text-xs font-medium text-slate-500 mb-1">Reason for Return <span className="text-red-500">*</span></label>
                                <select 
                                    value={newReturnItemReason} 
                                    onChange={e => setNewReturnItemReason(e.target.value)}
                                    className={`w-full border rounded-lg px-2 py-2 text-sm focus:ring-1 focus:ring-primary outline-none ${returnFormErrors.reason ? 'border-red-500 bg-red-50' : 'border-slate-300'}`}
                                >
                                    <option value="">Select Reason</option>
                                    <option>Expired</option>
                                    <option>Damaged</option>
                                    <option>Excess Order</option>
                                    <option>Wrong Item</option>
                                    <option>Other</option>
                                </select>
                                {returnFormErrors.reason && <p className="text-xs text-red-500 mt-1">{returnFormErrors.reason}</p>}
                            </div>
                            <div className="md:col-span-5 flex justify-end mt-2">
                                <button 
                                    onClick={handleAddReturnItem}
                                    className="bg-slate-800 text-white py-2 px-4 rounded-lg text-sm font-medium hover:bg-slate-700"
                                >
                                    Add Item
                                </button>
                            </div>
                        </div>
                     </div>

                     {returnItems.length > 0 && (
                        <div className="border border-slate-200 rounded-lg overflow-hidden">
                            <table className="w-full text-left text-sm">
                                <thead className="bg-slate-100 text-slate-600">
                                    <tr>
                                        <th className="p-3">Product</th>
                                        <th className="p-3">Batch</th>
                                        <th className="p-3 text-center">Qty</th>
                                        <th className="p-3">Reason</th>
                                        <th className="p-3 text-right">Rate</th>
                                        <th className="p-3 text-right">Amount</th>
                                        <th className="p-3 text-center"></th>
                                    </tr>
                                </thead>
                                <tbody className="divide-y divide-slate-100">
                                    {returnItems.map((item, idx) => (
                                        <tr key={idx}>
                                            <td className="p-3 font-medium">{item.productName}</td>
                                            <td className="p-3 text-slate-500 text-xs">{item.batchNo}</td>
                                            <td className="p-3 text-center">{item.quantity}</td>
                                            <td className="p-3 text-xs text-slate-500">
                                                <span className={`px-2 py-0.5 rounded ${item.reason === 'Expired' ? 'bg-red-50 text-red-600' : 'bg-slate-50 text-slate-600'}`}>
                                                    {item.reason}
                                                </span>
                                            </td>
                                            <td className="p-3 text-right">₹{item.returnRate}</td>
                                            <td className="p-3 text-right font-bold">₹{item.amount.toLocaleString()}</td>
                                            <td className="p-3 text-center">
                                                <button onClick={() => handleRemoveReturnItem(idx)} className="text-red-500 hover:bg-red-50 p-1 rounded"><Trash2 size={14}/></button>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                            </table>
                        </div>
                     )}
                </div>
                 <div className="p-4 bg-slate-50 border-t border-slate-100 flex justify-end gap-3 shrink-0">
                    <button onClick={() => setShowReturnModal(false)} className="px-4 py-2 text-slate-600 hover:bg-slate-200 rounded-lg">Cancel</button>
                    <button 
                        onClick={handleSubmitReturn}
                        disabled={returnItems.length === 0}
                        className="px-6 py-2 bg-primary text-white font-bold rounded-lg hover:bg-sky-600 shadow-lg shadow-primary/30 flex items-center gap-2 disabled:opacity-50"
                    >
                        <CreditCard size={18} /> Process Return & Credit Note
                    </button>
                </div>
             </div>
        </div>
      )}

      {/* Purchase Details Modal (Existing) */}
      {selectedPurchase && (
        <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
            <div className="bg-white rounded-xl shadow-2xl w-full max-w-3xl overflow-hidden animate-fadeIn max-h-[90vh] flex flex-col">
                <div className="bg-slate-900 text-white p-4 flex justify-between items-center shrink-0">
                    <h3 className="font-bold flex items-center gap-2"><FileText size={18} /> Purchase Details</h3>
                    <button onClick={() => setSelectedPurchase(null)} className="hover:bg-slate-700 p-1 rounded transition-colors"><X size={18} /></button>
                </div>
                
                <div className="p-6 overflow-y-auto">
                    {/* Header Info */}
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 p-4 bg-slate-50 rounded-lg border border-slate-100">
                        <div>
                            <p className="text-xs text-slate-500 font-semibold uppercase">Invoice No</p>
                            <p className="font-medium text-slate-800">{selectedPurchase.invoiceNo}</p>
                        </div>
                        <div>
                            <p className="text-xs text-slate-500 font-semibold uppercase">Supplier</p>
                            <p className="font-medium text-slate-800">{selectedPurchase.supplierName}</p>
                        </div>
                        <div>
                            <p className="text-xs text-slate-500 font-semibold uppercase">Date</p>
                            <p className="font-medium text-slate-800">{selectedPurchase.date}</p>
                        </div>
                        <div>
                            <p className="text-xs text-slate-500 font-semibold uppercase">Status</p>
                            <span className={`inline-flex items-center px-2 py-0.5 rounded text-xs font-bold border ${getStatusColor(selectedPurchase.status)}`}>
                                {selectedPurchase.status}
                            </span>
                        </div>
                    </div>

                    {/* Items Table */}
                    <h4 className="font-bold text-slate-800 mb-3">Items</h4>
                    <div className="border border-slate-200 rounded-lg overflow-hidden mb-6">
                        <table className="w-full text-left text-sm">
                            <thead className="bg-slate-100 text-slate-600 font-semibold">
                                <tr>
                                    <th className="p-3">Product</th>
                                    <th className="p-3">Batch / Exp</th>
                                    <th className="p-3 text-center">Qty</th>
                                    <th className="p-3 text-right">Rate</th>
                                    <th className="p-3 text-center">GST</th>
                                    <th className="p-3 text-right">MRP</th>
                                    <th className="p-3 text-right">Amount</th>
                                </tr>
                            </thead>
                            <tbody className="divide-y divide-slate-100">
                                {selectedPurchase.items.map((item, idx) => (
                                    <tr key={idx}>
                                        <td className="p-3 font-medium text-slate-800">{item.productName}</td>
                                        <td className="p-3 text-slate-500">
                                            {item.batchNo} <br/> 
                                            <span className="text-xs text-slate-400">Exp: {item.expiryDate}</span>
                                        </td>
                                        <td className="p-3 text-center">{item.quantity}</td>
                                        <td className="p-3 text-right">₹{item.purchaseRate}</td>
                                        <td className="p-3 text-center">
                                            {item.gst ? `${item.gst}%` : '-'}
                                        </td>
                                        <td className="p-3 text-right text-slate-500">₹{item.mrp}</td>
                                        <td className="p-3 text-right font-bold">₹{item.amount.toLocaleString()}</td>
                                    </tr>
                                ))}
                            </tbody>
                            <tfoot className="bg-slate-50 font-bold text-slate-800 border-t border-slate-200">
                                <tr>
                                    <td colSpan={5} className="p-3 text-right text-slate-600">Total</td>
                                    <td className="p-3 text-right text-slate-600">
                                        ₹{selectedPurchase.items.reduce((acc, i) => acc + (i.gstAmount || 0), 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}
                                    </td>
                                    <td className="p-3 text-right text-primary">₹{selectedPurchase.totalAmount.toLocaleString()}</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                
                <div className="p-4 bg-slate-50 border-t border-slate-100 flex justify-end shrink-0">
                    <button 
                        onClick={() => setSelectedPurchase(null)} 
                        className="px-4 py-2 bg-white border border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors"
                    >
                        Close
                    </button>
                </div>
            </div>
        </div>
      )}
    </div>
  );
};

export default Purchase;
