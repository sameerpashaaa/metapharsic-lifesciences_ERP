
import React, { useState } from 'react';
import { ClipboardCheck, FlaskConical, CheckCircle, XCircle, FileText, Printer, AlertTriangle } from 'lucide-react';
import { QCRecord } from '../types';

const MOCK_QC_RECORDS: QCRecord[] = [
  {
    id: 'QC-101', batchNumber: 'B123', productName: 'MetaMol 650', testDate: '2023-10-25', testedBy: 'Dr. R. Singh',
    parameters: [
      { parameter: 'Description', standard: 'White circular tablet', result: 'Complies', status: 'Pass' },
      { parameter: 'Average Weight', standard: '650mg ± 5%', result: '652mg', status: 'Pass' },
      { parameter: 'Dissolution', standard: 'NLT 80% in 30 mins', result: '92%', status: 'Pass' },
      { parameter: 'Assay', standard: '90% - 110%', result: '99.8%', status: 'Pass' }
    ],
    finalStatus: 'Approved', coaGenerated: true
  },
  {
    id: 'QC-102', batchNumber: 'MC-202', productName: 'MetaClav 625', testDate: '2023-10-26', testedBy: 'Priya K',
    parameters: [
      { parameter: 'Description', standard: 'White oblong tablet', result: 'Complies', status: 'Pass' },
      { parameter: 'Assay', standard: '90% - 110%', result: '88.5%', status: 'Fail' }
    ],
    finalStatus: 'Rejected', coaGenerated: false
  }
];

const QualityControl: React.FC = () => {
  const [records, setRecords] = useState<QCRecord[]>(MOCK_QC_RECORDS);
  const [selectedRecord, setSelectedRecord] = useState<QCRecord | null>(null);

  return (
    <div className="space-y-6 animate-fadeIn">
      <div className="flex justify-between items-center">
        <div>
          <h2 className="text-2xl font-bold text-slate-800">Quality Control (QC) Lab</h2>
          <p className="text-slate-500 text-sm">Batch Testing, COA Generation & Release Approval</p>
        </div>
        <button className="bg-primary text-white px-4 py-2 rounded-lg font-medium flex items-center gap-2 hover:bg-sky-600 transition-colors shadow-sm">
           <FlaskConical size={18} /> New Test Request
        </button>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* List */}
          <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden lg:col-span-1">
              <div className="p-4 border-b border-slate-100 bg-slate-50 font-bold text-slate-700">
                  Recent Test Batches
              </div>
              <div className="divide-y divide-slate-100">
                  {records.map(rec => (
                      <div 
                        key={rec.id} 
                        onClick={() => setSelectedRecord(rec)}
                        className={`p-4 cursor-pointer hover:bg-blue-50 transition-colors ${selectedRecord?.id === rec.id ? 'bg-blue-50 border-l-4 border-primary' : ''}`}
                      >
                          <div className="flex justify-between items-start mb-1">
                              <h4 className="font-bold text-slate-800">{rec.batchNumber}</h4>
                              <span className={`px-2 py-0.5 rounded text-[10px] font-bold ${rec.finalStatus === 'Approved' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                                  {rec.finalStatus}
                              </span>
                          </div>
                          <p className="text-sm text-slate-600">{rec.productName}</p>
                          <p className="text-xs text-slate-400 mt-1">{rec.testDate}</p>
                      </div>
                  ))}
              </div>
          </div>

          {/* Details */}
          <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden lg:col-span-2 p-6">
              {selectedRecord ? (
                  <div className="space-y-6">
                      <div className="flex justify-between items-start border-b border-slate-100 pb-4">
                          <div>
                              <h3 className="text-xl font-bold text-slate-800 flex items-center gap-2">
                                  {selectedRecord.productName} 
                                  <span className="text-sm font-mono bg-slate-100 px-2 py-1 rounded text-slate-600">Batch: {selectedRecord.batchNumber}</span>
                              </h3>
                              <p className="text-slate-500 text-sm mt-1">Tested By: {selectedRecord.testedBy} on {selectedRecord.testDate}</p>
                          </div>
                          {selectedRecord.coaGenerated && (
                              <button className="flex items-center gap-2 px-3 py-1.5 border border-slate-200 rounded-lg text-slate-600 text-xs font-bold hover:bg-slate-50">
                                  <Printer size={14}/> Print COA
                              </button>
                          )}
                      </div>

                      <div>
                          <h4 className="font-bold text-slate-700 mb-3 flex items-center gap-2"><ClipboardCheck size={18} className="text-primary"/> Test Parameters</h4>
                          <table className="w-full text-left text-sm">
                              <thead className="bg-slate-50 text-slate-500 uppercase">
                                  <tr>
                                      <th className="p-3">Parameter</th>
                                      <th className="p-3">Standard Limit</th>
                                      <th className="p-3">Result</th>
                                      <th className="p-3 text-center">Status</th>
                                  </tr>
                              </thead>
                              <tbody className="divide-y divide-slate-100">
                                  {selectedRecord.parameters.map((param, idx) => (
                                      <tr key={idx}>
                                          <td className="p-3 font-medium text-slate-800">{param.parameter}</td>
                                          <td className="p-3 text-slate-500">{param.standard}</td>
                                          <td className="p-3 font-bold">{param.result}</td>
                                          <td className="p-3 text-center">
                                              {param.status === 'Pass' 
                                                ? <CheckCircle size={16} className="text-green-500 mx-auto"/> 
                                                : <XCircle size={16} className="text-red-500 mx-auto"/>
                                              }
                                          </td>
                                      </tr>
                                  ))}
                              </tbody>
                          </table>
                      </div>

                      <div className={`p-4 rounded-xl border ${selectedRecord.finalStatus === 'Approved' ? 'bg-green-50 border-green-100' : 'bg-red-50 border-red-100'} flex items-center gap-4`}>
                           {selectedRecord.finalStatus === 'Approved' ? <CheckCircle size={32} className="text-green-600" /> : <AlertTriangle size={32} className="text-red-600" />}
                           <div>
                               <h4 className={`font-bold ${selectedRecord.finalStatus === 'Approved' ? 'text-green-800' : 'text-red-800'}`}>
                                   Batch {selectedRecord.finalStatus}
                               </h4>
                               <p className={`text-sm ${selectedRecord.finalStatus === 'Approved' ? 'text-green-700' : 'text-red-700'}`}>
                                   {selectedRecord.finalStatus === 'Approved' 
                                    ? "This batch complies with IP/BP/USP standards and is released for sale."
                                    : "This batch failed critical parameters and is quarantined."}
                               </p>
                           </div>
                      </div>
                  </div>
              ) : (
                  <div className="h-full flex flex-col items-center justify-center text-slate-400">
                      <FlaskConical size={48} className="mb-4 opacity-20"/>
                      <p>Select a batch record to view details.</p>
                  </div>
              )}
          </div>
      </div>
    </div>
  );
};

export default QualityControl;
